@model List<GAMA.CO5.Models.Service>
@{
    ViewData["Title"] = "الخدمات";
    var services = Model ?? new List<GAMA.CO5.Models.Service>();
}

<section class="services-page-hero" style="background-image:url('@Url.Content("~/images/services-bg.jpg")')">
    <div class="services-page-overlay"></div>

    <div class="container services-page-hero-content">
        <span class="services-page-badge">الخدمات ✦</span>
        <h1>الخدمات</h1>
        <p>حلول تقنية متكاملة لتحقيق التحول الرقمي ودعم نمو أعمالك</p>
    </div>
</section>

<section class="services-page-section">
    <div class="container">

        <div class="services-page-grid">
            @foreach (var service in services)
            {
                <a asp-action="Details"
                   asp-route-id="@service.Id"
                   class="service-box">
                    <div class="service-box-top">
                        <span class="service-arrow">←</span>
                        <span class="service-icon">@service.Icon</span>
                    </div>

                    <h3>@service.Title</h3>
                </a>
            }
        </div>

        <div class="services-page-footer">
            <p>اضغط على أي خدمة لمعرفة المزيد من التفاصيل ومشاهدة الفيديو التعريفي</p>
            <a asp-controller="Contact" asp-action="Index" class="services-page-btn">
                اضغط لاستكشاف الخدمة ✦
            </a>
        </div>

    </div>
</section>

@section Styles {
    <style>
        .services-page-hero {
            position: relative;
            min-height: 320px;
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .services-page-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(9, 39, 84, 0.38), rgba(5, 24, 62, 0.78));
        }

        .services-page-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: #fff;
            padding: 40px 20px;
        }

        .services-page-badge {
            display: inline-block;
            padding: 8px 18px;
            border-radius: 999px;
            background: rgba(255,255,255,0.14);
            border: 1px solid rgba(255,255,255,0.16);
            color: #e0f2fe;
            font-size: 0.95rem;
            font-weight: 700;
            margin-bottom: 18px;
        }

        .services-page-hero-content h1 {
            font-size: 3.3rem;
            font-weight: 900;
            margin-bottom: 10px;
            color: #fff;
        }

        .services-page-hero-content p {
            font-size: 1.08rem;
            color: rgba(255,255,255,0.92);
            margin: 0;
        }

        .services-page-section {
            background: #f8fafc;
            padding: 80px 0 90px;
        }

        .services-page-grid {
            max-width: 860px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 18px;
        }

        .service-box {
            background: #fff;
            border: 1px solid #dbe7f3;
            border-radius: 18px;
            min-height: 128px;
            padding: 20px 18px;
            text-decoration: none;
            transition: all 0.22s ease;
            box-shadow: 0 4px 14px rgba(15, 23, 42, 0.03);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

            .service-box:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 30px rgba(15, 23, 42, 0.08);
                border-color: #b9d7ea;
            }

        .service-box-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
        }

        .service-arrow {
            font-size: 1.15rem;
            color: #0f172a;
            font-weight: 700;
        }

        .service-icon {
            width: 38px;
            height: 38px;
            min-width: 38px;
            border-radius: 50%;
            background: #1d9acb;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 8px 18px rgba(29, 154, 203, 0.22);
        }

        .service-box h3 {
            margin: 0;
            color: #0f172a;
            font-size: 1.15rem;
            font-weight: 800;
            line-height: 1.5;
            text-align: right;
        }

        .services-page-footer {
            text-align: center;
            margin-top: 42px;
        }

            .services-page-footer p {
                color: #64748b;
                font-size: 1rem;
                margin-bottom: 18px;
            }

        .services-page-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 11px 22px;
            border-radius: 999px;
            background: #efe7ff;
            color: #7c3aed;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s ease;
            border: 1px solid #e7dbff;
        }

            .services-page-btn:hover {
                background: #e8dbff;
            }

        @@media (max-width: 1100px) {
            .services-page-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 768px) {
            .services-page-hero {
                min-height: 250px;
            }

            .services-page-hero-content h1 {
                font-size: 2.3rem;
            }

            .services-page-grid {
                grid-template-columns: repeat(2, 1fr);
                max-width: 100%;
            }
        }

        @@media (max-width: 520px) {
            .services-page-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}