@model List<GAMA.CO5.Models.Service>

@{
    ViewData["Title"] = "الخدمات";
}

<!-- HERO -->
<section class="relative overflow-hidden bg-[#07142b]">
    <div class="absolute inset-0">
        <img src="@Url.Content("~/images/services-bg.jpg")"
             class="h-full w-full object-cover opacity-80 scale-105" />

        <div class="absolute inset-0 bg-gradient-to-br from-[#07142b]/60 via-[#0a1d3d]/50 to-[#020617]/70"></div>
    </div>

    <div class="relative mx-auto flex max-w-7xl flex-col items-end px-6 py-24" dir="rtl">
        <h1 class="text-5xl font-black text-white text-right">
            الخدمات
        </h1>
    </div>
</section>

<!-- SERVICES -->
<section class="relative overflow-hidden bg-[#eef4ff] py-24" dir="rtl">

    <div class="relative z-10 mx-auto max-w-7xl px-6">

        <h2 class="mb-14 text-right text-3xl font-black text-[#020617]">
            خدمات تقنية احترافية
        </h2>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 gap-10 md:grid-cols-2 xl:grid-cols-3" dir="rtl">

                @foreach (var service in Model)
                {
                    <a asp-action="Details"
                       asp-route-id="@service.Id"
                       class="group block rounded-[26px]
                                              bg-[#f8fbff]
                                              border border-[#b6c2d2]
                                              p-4
                                              transition duration-500 hover:-translate-y-1">

                        <!-- IMAGE -->
                        <div class="mb-4 overflow-hidden rounded-[18px] bg-[#f1f5ff]">
                            @if (!string.IsNullOrWhiteSpace(service.ImageUrl))
                            {
                                <img src="@service.ImageUrl"
                                     class="h-[200px] w-full object-cover transition duration-700 group-hover:scale-105" />
                            }
                            else
                            {
                                <div class="flex h-[200px] items-center justify-center text-slate-400 text-sm">
                                    NO IMAGE
                                </div>
                            }
                    </div>

                    <!-- CONTENT -->
                    <div class="px-1 pb-2 text-right">

                        <h3 class="text-[24px] font-black text-[#020617]">
                            @service.Title
                        </h3>

                        <p class="mt-2 min-h-[60px] text-sm leading-6 text-slate-700">
                            @(service.Description != null && service.Description.Length > 90
                                                    ? service.Description.Substring(0, 90) + "..."
                                                    : service.Description)
                    </p>

                            <!-- BUTTON -->
                            <div class="mt-5 flex justify-end border-t border-[#e6edf5] pt-4">

                                <div class="inline-flex items-center gap-2 ml-auto
                        px-4 py-2 rounded-xl
                        bg-[#1e293b] text-white text-sm font-bold
                        transition group-hover:bg-[#334155]">

                                    عرض التفاصيل
                                    <span>←</span>
                                </div>

                            </div>

                        </div>
                    </a>
                        }

            </div>
        }
        else
        {
            <div class="py-16 text-center text-slate-500">
                لا توجد خدمات حالياً
            </div>
        }

    </div>
</section>