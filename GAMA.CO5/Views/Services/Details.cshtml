@model GAMA.CO5.Models.Service
@{
    ViewData["Title"] = Model.Title;
}

<section class="relative overflow-hidden bg-[#07142b]">
    <div class="absolute inset-0">
        <img src="@Url.Content("~/images/services-bg.jpg")"
             alt="@Model.Title"
             class="h-full w-full object-cover opacity-10" />
        <div class="absolute inset-0 bg-gradient-to-br from-[#07142b] via-[#0a1d3d] to-[#07142b]"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6 py-24 lg:px-8 lg:py-28">
        <div class="max-w-4xl">
            <span class="inline-flex items-center rounded-full border border-[#1d3d75] bg-[#102347] px-4 py-2 text-sm font-semibold tracking-[0.18em] text-slate-200">
                SERVICE DETAILS
            </span>

            <h1 class="mt-6 text-5xl font-black tracking-tight text-white md:text-6xl lg:text-7xl">
                @Model.Title
            </h1>

            <p class="mt-6 text-lg leading-9 text-slate-300">
                @Model.Description
            </p>
        </div>
    </div>
</section>

<section class="bg-[#f8fafc] py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-12">

            <div class="lg:col-span-4">
                <div class="relative overflow-hidden rounded-[22px] border border-[#11294f] bg-white p-6 shadow-[0_10px_25px_rgba(2,6,23,0.04)]">
                    <div class="absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-[#07142b] via-[#16386e] to-[#07142b]"></div>

                    <div class="flex h-16 w-16 items-center justify-center rounded-2xl border border-[#d4deed] bg-[#f8fbff] text-2xl text-[#07142b]">
                        @if (!string.IsNullOrWhiteSpace(Model.Icon) && Model.Icon.Contains("fa-"))
                        {
                            <i class="@Model.Icon"></i>
                        }
                        else
                        {
                            @Model.Icon
                        }
                    </div>

                    <div class="mt-6 overflow-hidden rounded-[18px] border border-[#d8e1ee] bg-slate-100">
                        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl"
                                 alt="@Model.Title"
                                 class="h-64 w-full object-cover" />
                        }
                        else
                        {
                            <div class="flex h-64 w-full items-center justify-center bg-[linear-gradient(135deg,#eef4ff,#f8fbff)] text-sm font-bold tracking-[0.18em] text-slate-400">
                                NO IMAGE
                            </div>
                        }
                    </div>

                    <div class="mt-6 border-t border-[#e3eaf5] pt-6">
                        <p class="text-xs font-bold tracking-[0.24em] text-slate-500">
                            SERVICE
                        </p>

                        <h2 class="mt-3 text-2xl font-black leading-10 text-[#07142b]">
                            @Model.Title
                        </h2>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-8">
                <div class="relative overflow-hidden rounded-[22px] border border-[#11294f] bg-white p-8 shadow-[0_10px_25px_rgba(2,6,23,0.04)] lg:p-10">
                    <div class="absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-[#07142b] via-[#16386e] to-[#07142b]"></div>

                    <div class="border-b border-[#e3eaf5] pb-6">
                        <p class="text-sm font-bold tracking-[0.2em] text-slate-500">
                            OVERVIEW
                        </p>

                        <p class="mt-4 text-lg leading-9 text-slate-600">
                            @Model.Description
                        </p>
                    </div>

                    <div class="pt-8">
                        <h3 class="text-2xl font-black text-[#07142b]">
                            مميزات الخدمة
                        </h3>

                        <div class="mt-6 grid gap-4 md:grid-cols-2">
                            @foreach (var feature in Model.Features.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <div class="rounded-xl border border-[#d8e1ee] bg-[#f8fbff] px-5 py-4 text-slate-700 shadow-sm">
                                    ✓ @feature.Trim()
                                </div>
                            }
                        </div>

                        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
                            <a asp-controller="Contact"
                               asp-action="Index"
                               class="inline-flex items-center justify-center rounded-xl bg-[#07142b] px-8 py-4 text-sm font-bold tracking-[0.12em] text-white no-underline transition hover:bg-[#0a1d3d]">
                                تواصل معنا
                            </a>

                            <a asp-action="Index"
                               class="inline-flex items-center justify-center rounded-xl border border-[#d8e1ee] bg-white px-8 py-4 text-sm font-bold tracking-[0.12em] text-[#07142b] no-underline transition hover:bg-slate-50">
                                رجوع للخدمات
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
