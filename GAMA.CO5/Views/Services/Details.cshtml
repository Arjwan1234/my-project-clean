@model GAMA.CO5.Models.Service

@{
    ViewData["Title"] = Model.Title;

    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "/images/services-bg.jpg"
        : Model.ImageUrl;

    var features = string.IsNullOrWhiteSpace(Model.Features)
        ? new List<string>()
        : Model.Features.Split(',', StringSplitOptions.RemoveEmptyEntries)
                        .Select(x => x.Trim())
                        .Where(x => !string.IsNullOrWhiteSpace(x))
                        .ToList();

    var leftBenefits = features.Take((features.Count + 1) / 2).ToList();
    var rightBenefits = features.Skip((features.Count + 1) / 2).ToList();

    if (!leftBenefits.Any())
    {
        leftBenefits = new List<string>
        {
            "تنظيم وتتبع العمليات اليومية بفاعلية",
            "تقليل الأخطاء البشرية في مسار العمل",
            "رفع الكفاءة التشغيلية وسهولة المتابعة",
            "تحسين الإنتاجية من خلال البيانات الدقيقة"
        };
    }

    if (!rightBenefits.Any())
    {
        rightBenefits = new List<string>
        {
            "تقنيات متقدمة لتقديم تجربة أسرع وأكثر موثوقية",
            "تكامل سلس مع الأنظمة والبيانات الحيوية",
            "تقارير ذكية تساعد على اتخاذ القرار",
            "إدارة المهام والعمليات بشكل أكثر كفاءة"
        };
    }
}

<section class="bg-[linear-gradient(180deg,#f8fafc_0%,#f4f7fb_100%)] py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

        <div class="mx-auto max-w-4xl text-center">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#6d28d9] text-white shadow-[0_12px_30px_rgba(109,40,217,0.24)]">
                @if (!string.IsNullOrWhiteSpace(Model.Icon) && Model.Icon.Contains("fa-"))
                {
                    <i class="@Model.Icon"></i>
                }
                else if (!string.IsNullOrWhiteSpace(Model.Icon))
                {
                    <span class="text-lg font-black">@Model.Icon</span>
                }
                else
                {
                    <span class="text-lg font-black">✦</span>
                }
            </div>

            <h1 class="mt-5 text-4xl font-black tracking-tight text-[#0f172a] md:text-5xl">
                @Model.Title
            </h1>

            <p class="mx-auto mt-4 max-w-3xl text-base leading-8 text-slate-600 md:text-lg">
                @Model.Description
            </p>
        </div>

        <div class="mx-auto mt-10 max-w-6xl">
            <div class="overflow-hidden rounded-[28px] bg-[#14213d] p-5 shadow-[0_24px_60px_rgba(15,23,42,0.14)]">
                <div class="mb-4 flex items-center justify-between">
                    <span class="rounded-full bg-white/10 px-4 py-2 text-sm font-bold text-white">
                        فيديو تعريفي
                    </span>

                    <span class="text-sm font-bold text-white/80">
                        @Model.Title
                    </span>
                </div>

                <div class="overflow-hidden rounded-[20px] border border-white/10 bg-black/20">
                    @if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
                    {
                        <video class="h-[260px] w-full object-cover md:h-[360px] lg:h-[440px]"
                               controls
                               preload="metadata">
                            <source src="@Model.VideoUrl" type="video/mp4" />
                            متصفحك لا يدعم تشغيل الفيديو.
                        </video>
                    }
                    else
                    {
                        <img src="@imageUrl"
                             alt="@Model.Title"
                             class="h-[260px] w-full object-cover md:h-[360px] lg:h-[440px]"
                             onerror="this.onerror=null;this.src='/images/services-bg.jpg';" />
                    }
                </div>
            </div>
        </div>

        <div class="mt-14 grid gap-10 lg:grid-cols-2">

            <div>
                <div class="mb-5 flex items-center justify-between">
                    <h2 class="text-2xl font-black text-[#0f172a]">
                        المميزات الرئيسية
                    </h2>
                    <span class="text-[#7c3aed]">⦿</span>
                </div>

                <div class="space-y-4">
                    @foreach (var item in rightBenefits)
                    {
                        <div class="flex items-center justify-between rounded-2xl bg-[#f3ecff] px-5 py-4 text-[#374151] shadow-sm">
                            <span class="text-sm leading-7 font-medium">@item</span>
                            <span class="mr-4 text-[#8b5cf6]">◉</span>
                        </div>
                    }
                </div>
            </div>

            <div>
                <div class="mb-5 flex items-center justify-between">
                    <h2 class="text-2xl font-black text-[#0f172a]">
                        الفوائد
                    </h2>
                    <span class="text-[#7c3aed]">⌁</span>
                </div>

                <div class="space-y-4">
                    @foreach (var item in leftBenefits)
                    {
                        <div class="flex items-center justify-between rounded-2xl bg-[#f3ecff] px-5 py-4 text-[#374151] shadow-sm">
                            <span class="text-sm leading-7 font-medium">@item</span>
                            <span class="mr-4 text-[#8b5cf6]">◉</span>
                        </div>
                    }
                </div>
            </div>

        </div>

        <div class="mt-14">
            <div class="mb-6 flex items-center justify-end gap-2">
                <span class="text-[#7c3aed]">◎</span>
                <h2 class="text-2xl font-black text-[#0f172a]">
                    حالات الاستخدام
                </h2>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-2xl border border-[#dbe3ef] bg-white px-6 py-5 shadow-sm">
                    <div class="flex items-center justify-between">
                        <span class="text-[#7c3aed]">⤴</span>
                        <span class="text-sm font-bold text-slate-700">الوزارات والمؤسسات الحكومية</span>
                    </div>
                </div>

                <div class="rounded-2xl border border-[#dbe3ef] bg-white px-6 py-5 shadow-sm">
                    <div class="flex items-center justify-between">
                        <span class="text-[#7c3aed]">⤴</span>
                        <span class="text-sm font-bold text-slate-700">الشركات والمؤسسات الخاصة والمتوسطة</span>
                    </div>
                </div>

                <div class="rounded-2xl border border-[#dbe3ef] bg-white px-6 py-5 shadow-sm">
                    <div class="flex items-center justify-between">
                        <span class="text-[#7c3aed]">⤴</span>
                        <span class="text-sm font-bold text-slate-700">المؤسسات التعليمية</span>
                    </div>
                </div>

                <div class="rounded-2xl border border-[#dbe3ef] bg-white px-6 py-5 shadow-sm">
                    <div class="flex items-center justify-between">
                        <span class="text-[#7c3aed]">⤴</span>
                        <span class="text-sm font-bold text-slate-700">المستخدمون وصنّاع القرار التقني</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-12 overflow-hidden rounded-[24px] bg-gradient-to-r from-[#6d28d9] to-[#7c3aed] px-8 py-10 text-center text-white shadow-[0_20px_50px_rgba(109,40,217,0.26)]">
            <h3 class="text-2xl font-black md:text-3xl">
                هل أنت مهتم بهذه الخدمة؟
            </h3>

            <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-white/90">
                تواصل معنا الآن للحصول على استشارة مخصصة وعرض سعر احترافي يناسب احتياجك.
            </p>

            <div class="mt-6 flex items-center justify-center gap-3">
                <a asp-controller="Contact"
                   asp-action="Index"
                   class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-black text-[#6d28d9] no-underline shadow-sm transition duration-300 hover:-translate-y-0.5">
                    تواصل معنا
                    <span class="mr-2">↔</span>
                </a>

                <a asp-action="Index"
                   class="inline-flex items-center justify-center rounded-full border border-white/25 px-6 py-3 text-sm font-black text-white no-underline transition duration-300 hover:bg-white/10">
                    رجوع للخدمات
                </a>
            </div>
        </div>

    </div>
</section>