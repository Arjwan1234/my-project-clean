<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GAMA.CO5</title>

    <link href="~/css/output.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-slate-50 text-slate-900">

    <nav class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">

            <a asp-controller="Home" asp-action="Index" class="logo">
                <img src="~/images/logo-gama-new.png" alt="GAMA Logo" />
            </a>

            <ul class="hidden items-center gap-2 md:flex">
                <li><a asp-controller="Services" asp-action="Index" class="rounded-xl px-4 py-2 font-bold text-white/90 no-underline transition hover:bg-sky-500/15 hover:text-white">الخدمات</a></li>
                <li><a asp-controller="Products" asp-action="Index" class="rounded-xl px-4 py-2 font-bold text-white/90 no-underline transition hover:bg-sky-500/15 hover:text-white">المنتجات</a></li>
                <li><a asp-controller="DTI" asp-action="Index" class="rounded-xl px-4 py-2 font-bold text-white/90 no-underline transition hover:bg-sky-500/15 hover:text-white">مؤشر التحول الرقمي</a></li>
                <li><a asp-controller="Partners" asp-action="Index" class="rounded-xl px-4 py-2 font-bold text-white/90 no-underline transition hover:bg-sky-500/15 hover:text-white">الشركاء</a></li>
                <li><a asp-controller="Careers" asp-action="Index" class="rounded-xl px-4 py-2 font-bold text-white/90 no-underline transition hover:bg-sky-500/15 hover:text-white">الوظائف</a></li>
                <li><a asp-controller="Contact" asp-action="Index" class="rounded-xl px-4 py-2 font-bold text-white/90 no-underline transition hover:bg-sky-500/15 hover:text-white">التواصل</a></li>
            </ul>

        </div>
    </nav>

    <main class="min-h-screen bg-slate-50">
        @RenderBody()
    </main>

    <footer class="bg-slate-950 text-white">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
            <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">

                <div>
                    <div class="mb-4 flex items-center gap-3">
                        <span class="text-3xl font-black text-sky-400">GAMA</span>
                    </div>

                    <p class="text-sm leading-8 text-slate-300">
                        نقدم حلولاً تقنية مبتكرة تدعم ريادة الشركات
                        على النمو والازدهار في العصر الرقمي
                    </p>

                    <div class="mt-4 flex gap-3 text-sky-400">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-x-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>

                <div>
                    <h3 class="mb-4 text-xl font-extrabold">خدماتنا</h3>
                    <ul class="space-y-3 text-slate-300">
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">أنظمة الحضور والانصراف</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">السحابات</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">التحول الرقمي</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">الفوترة الإلكترونية</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-4 text-xl font-extrabold">الشركة</h3>
                    <ul class="space-y-3 text-slate-300">
                        <li><a asp-controller="Home" asp-action="About" class="hover:text-white">من نحن</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">الخدمات</a></li>
                        <li><a asp-controller="Products" asp-action="Index" class="hover:text-white">المنتجات</a></li>
                        <li><a asp-controller="Contact" asp-action="Index" class="hover:text-white">التواصل</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-4 text-xl font-extrabold">معلومات التواصل</h3>
                    <ul class="space-y-3 text-slate-300">
                        <li>📍 جدة، السعودية</li>
                        <li>📞 +966 XX XXX XXXX</li>
                        <li>✉️ info@gama-ksa.com</li>
                    </ul>
                </div>

            </div>

            <div class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
                <div class="flex gap-4">
                    <a asp-controller="Home" asp-action="Privacy" class="hover:text-white">سياسة الخصوصية</a>
                    <a href="#" class="hover:text-white">الشروط</a>
                </div>

                <div>
                    © 2026 جميع الحقوق محفوظة
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>