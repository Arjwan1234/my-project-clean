@using System.Globalization
@{
    var isEn = CultureInfo.CurrentCulture.Name.StartsWith("en");
    var logoPosition = isEn ? "left-0" : "right-0";
    var langPosition = isEn ? "right-0" : "left-0";
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.Name" dir="@(isEn ? "ltr" : "rtl")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GAMA.CO5</title>

    <link href="~/css/output.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <nav class="sticky top-0 z-50 backdrop-blur-xl bg-slate-950/90 border-b border-white/10">
        <div class="relative mx-auto w-full max-w-[1180px] px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-center">
            <a asp-controller="Home" asp-action="Index"
               class="absolute @logoPosition top-1/2 -translate-y-1/2 flex items-center">
                <img src="~/images/Gama_logo.png"
                     alt="GAMA Logo"
                     class="h-16 w-auto object-contain" />
            </a>

            <ul class="hidden md:flex items-center gap-8">
                <li><a asp-controller="Services" asp-action="Index" class="text-white font-bold hover:text-cyan-300 transition">@(isEn ? "Services" : "الخدمات")</a></li>
                <li><a asp-controller="Products" asp-action="Index" class="text-white font-bold hover:text-cyan-300 transition">@(isEn ? "Products" : "المنتجات")</a></li>
                <li><a asp-controller="DTI" asp-action="Index" class="text-white font-bold hover:text-cyan-300 transition">@(isEn ? "Digital Index" : "مؤشر التحول الرقمي")</a></li>
                <li><a asp-controller="Partners" asp-action="Index" class="text-white font-bold hover:text-cyan-300 transition">@(isEn ? "Partners" : "الشركاء")</a></li>
                <li><a asp-controller="Careers" asp-action="Index" class="text-white font-bold hover:text-cyan-300 transition">@(isEn ? "Careers" : "الوظائف")</a></li>
                <li><a asp-controller="Contact" asp-action="Index" class="text-white font-bold hover:text-cyan-300 transition">@(isEn ? "Contact" : "التواصل")</a></li>
            </ul>

            <div class="absolute @langPosition top-1/2 -translate-y-1/2 flex gap-2">
                <a asp-controller="Home" asp-action="SetLanguage" asp-route-culture="ar"
                   class="px-3 py-1 text-sm font-bold text-white border border-white/20 rounded-lg hover:bg-white/10">
                    عربي
                </a>

                <a asp-controller="Home" asp-action="SetLanguage" asp-route-culture="en"
                   class="px-3 py-1 text-sm font-bold text-white border border-white/20 rounded-lg hover:bg-white/10">
                    EN
                </a>
            </div>
        </div>
    </nav>

    <main class="min-h-screen bg-slate-50 overflow-x-hidden">
    @RenderBody()
</main>

    <footer class="bg-slate-950 text-white">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
            <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">

                <div>
                    <div class="mb-4 flex items-center gap-3">
                        <span class="text-3xl font-black text-sky-400">GAMA</span>
                    </div>

                    <p class="text-sm leading-8 text-slate-300">
                        @(isEn
                                                ? "We provide innovative technology solutions that support business growth and digital excellence."
                                                : "نقدم حلولاً تقنية مبتكرة تدعم ريادة الشركات على النمو والازدهار في العصر الرقمي")
                    </p>

                    <div class="mt-4 flex gap-3 text-sky-400">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-x-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>

                <div>
                    <h3 class="mb-4 text-xl font-extrabold">@(isEn ? "Our Services" : "خدماتنا")</h3>
                    <ul class="space-y-3 text-slate-300">
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">@(isEn ? "Attendance Systems" : "أنظمة الحضور والانصراف")</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">@(isEn ? "Cloud Solutions" : "السحابات")</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">@(isEn ? "Digital Transformation" : "التحول الرقمي")</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">@(isEn ? "E-Invoicing" : "الفوترة الإلكترونية")</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-4 text-xl font-extrabold">@(isEn ? "Company" : "الشركة")</h3>
                    <ul class="space-y-3 text-slate-300">
                        <li><a asp-controller="Home" asp-action="About" class="hover:text-white">@(isEn ? "About Us" : "من نحن")</a></li>
                        <li><a asp-controller="Services" asp-action="Index" class="hover:text-white">@(isEn ? "Services" : "الخدمات")</a></li>
                        <li><a asp-controller="Products" asp-action="Index" class="hover:text-white">@(isEn ? "Products" : "المنتجات")</a></li>
                        <li><a asp-controller="Contact" asp-action="Index" class="hover:text-white">@(isEn ? "Contact" : "التواصل")</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-4 text-xl font-extrabold">@(isEn ? "Contact Info" : "معلومات التواصل")</h3>
                    <ul class="space-y-3 text-slate-300">
                        <li>📍 @(isEn ? "Jeddah, Saudi Arabia" : "جدة، السعودية")</li>
                        <li>📞 +966 XX XXX XXXX</li>
                        <li>✉️ info@gama-ksa.com</li>
                    </ul>
                </div>
            </div>

            <div class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
                <div class="flex gap-4">
                    <a asp-controller="Home" asp-action="Privacy" class="hover:text-white">@(isEn ? "Privacy Policy" : "سياسة الخصوصية")</a>
                    <a href="#" class="hover:text-white">@(isEn ? "Terms" : "الشروط")</a>
                </div>

                <div>
                    @(isEn ? "© 2026 All rights reserved" : "© 2026 جميع الحقوق محفوظة")
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>