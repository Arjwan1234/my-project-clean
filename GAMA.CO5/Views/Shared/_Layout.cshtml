<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GAMA.CO5</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GAMA.CO5.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="site-body">

    <nav class="navbar">
        <div class="container nav-container">

            <a asp-controller="Home" asp-action="Index" class="logo">
                <img src="~/images/logo-gama.jpg" alt="GAMA Logo" />
            </a>

            <button class="mobile-menu-btn" id="mobileMenuBtn" type="button">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="nav-links" id="navLinks">
                <li><a asp-controller="Services" asp-action="Index">الخدمات</a></li>
                <li><a asp-controller="Products" asp-action="Index">المنتجات</a></li>
                <li><a asp-controller="DTI" asp-action="Index">مؤشر التحول الرقمي</a></li>
                <li><a asp-controller="Partners" asp-action="Index">الشركاء</a></li>
                <li><a asp-controller="Careers" asp-action="Index">الوظائف</a></li>
                <li><a asp-controller="Contact" asp-action="Index">التواصل</a></li>
            </ul>

        </div>
    </nav>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">

                <div class="footer-brand">
                    <div class="footer-logo-wrap">
                        <span class="footer-logo-text">GAMA</span>
                        <span class="footer-logo-icon">G</span>
                    </div>

                    <p class="footer-desc">
                        نقدم حلولاً تقنية مبتكرة تدعم ريادة الشركات
                        على النمو والازدهار في العصر الرقمي
                    </p>

                    <div class="footer-social">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-x-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>

                <div class="footer-col">
                    <h3>خدماتنا</h3>
                    <ul>
                        <li><a asp-controller="Services" asp-action="Index">أنظمة الحضور والانصراف</a></li>
                        <li><a asp-controller="Services" asp-action="Index">السحابات</a></li>
                        <li><a asp-controller="Services" asp-action="Index">التحول الرقمي</a></li>
                        <li><a asp-controller="Services" asp-action="Index">الفوترة الإلكترونية</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h3>الشركة</h3>
                    <ul>
                        <li><a asp-controller="Home" asp-action="About">من نحن</a></li>
                        <li><a asp-controller="Services" asp-action="Index">الخدمات</a></li>
                        <li><a asp-controller="Products" asp-action="Index">المنتجات</a></li>
                        <li><a asp-controller="Contact" asp-action="Index">التواصل</a></li>
                    </ul>
                </div>

                <div class="footer-col footer-contact">
                    <h3>معلومات التواصل</h3>
                    <ul>
                        <li>📍 جدة، السعودية</li>
                        <li>📞 +966 XX XXX XXXX</li>
                        <li>✉️ info@gama-ksa.com</li>
                    </ul>
                </div>

            </div>

            <div class="footer-bottom">
                <div class="footer-links">
                    <a asp-controller="Home" asp-action="Privacy">سياسة الخصوصية</a>
                    <a href="#">الشروط</a>
                </div>

                <div class="footer-copy">
                    © 2026 جميع الحقوق محفوظة
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const mobileBtn = document.getElementById("mobileMenuBtn");
            const navLinks = document.getElementById("navLinks");

            if (mobileBtn && navLinks) {
                mobileBtn.addEventListener("click", function () {
                    navLinks.classList.toggle("open");
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>