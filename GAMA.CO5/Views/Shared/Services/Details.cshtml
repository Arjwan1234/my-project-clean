@model GAMA.CO5.Models.Service
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = Model.Title;
}

<section class="section">
    <div class="container">

        <div class="details-card">
            <div class="details-icon">@Model.Icon</div>

            <h2>@Model.Title</h2>

            <p class="details-desc">
                @Model.Description
            </p>

            <ul class="details-features">
                @foreach (var feature in Model.Features.Split(',', StringSplitOptions.RemoveEmptyEntries))
                {
                    <li>@feature.Trim()</li>
                }
            </ul>

            <a asp-action="Index" class="service-btn">
                الرجوع للخدمات
            </a>
        </div>

    </div>
</section>