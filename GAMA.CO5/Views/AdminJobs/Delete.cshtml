@model GAMA.CO5.Models.Job

@{
    ViewData["Title"] = "حذف وظيفة";
}

<div class="container py-5">
    <h2 class="mb-4 text-danger">حذف وظيفة</h2>

    <div class="alert alert-warning">
        هل أنت متأكد من حذف هذه الوظيفة؟
    </div>

    <dl class="row">
        <dt class="col-sm-3">اسم الوظيفة</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">القسم</dt>
        <dd class="col-sm-9">@Model.Department</dd>

        <dt class="col-sm-3">المدينة</dt>
        <dd class="col-sm-9">@Model.Location</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">تأكيد الحذف</button>
        <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
    </form>
</div>