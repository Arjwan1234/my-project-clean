@model IEnumerable<GAMA.CO5.Models.JobApplication>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "طلبات التوظيف";
}

<div class="admin-applications-page" dir="rtl">

    <div class="applications-hero">
        <div>
            <span class="hero-badge">GAMA HR</span>
            <h2>طلبات التوظيف</h2>
            <p>استعراض بيانات المتقدمين، معلومات التواصل، والسير الذاتية.</p>
        </div>

        <a asp-controller="AdminJobs" asp-action="Index" class="btn-back">
            <i class="fa-solid fa-arrow-right"></i>
            رجوع للوظائف
        </a>
    </div>

    <div class="applications-card">
        <table class="applications-table">
            <thead>
                <tr>
                    <th>الاسم</th>
                    <th>الإيميل</th>
                    <th>رقم الهاتف</th>
                    <th>الوظيفة</th>
                    <th>نبذة</th>
                    <th>السيرة الذاتية</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="applicant-name">@item.FullName</td>
                        <td>@item.Email</td>
                        <td>
                            <a href="tel:@item.Phone" class="phone-link">
                                @item.Phone
                            </a>
                        </td>
                        <td>
                            <span class="job-badge">
                                @(string.IsNullOrWhiteSpace(item.JobTitle) ? "غير محدد" : item.JobTitle)
                            </span>
                        </td>
                        <td class="about-text">@item.AboutMe</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.CVFileName))
                            {
                                <div class="cv-actions">
                                    <a href="/uploads/cv/@item.CVFileName" target="_blank" class="btn-view">
                                        عرض
                                    </a>

                                    <a href="/uploads/cv/@item.CVFileName" download class="btn-download">
                                        تحميل
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="no-cv">لا يوجد CV</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@section Styles {
    <style>

        .admin-applications-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: #eef4ff;
        }

        /* HERO */
        .applications-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: #f8fbff;
            border: 1px solid #b6c2d2;
            box-shadow: 0 20px 50px rgba(15,23,42,.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: #eef4ff;
            border: 1px solid #b6c2d2;
            font-size: 12px;
            font-weight: 900;
            color: #07142b;
        }

        .applications-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
            color: #020617;
        }

        .applications-hero p {
            margin-top: 8px;
            color: #64748b;
        }

        /* BUTTON */
        .btn-back {
            background: #07142b;
            color: white;
            border: none;
            padding: 12px 22px;
            border-radius: 18px;
            font-weight: 900;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: #0a1d3d;
            }

        /* CARD */
        .applications-card {
            border-radius: 28px;
            overflow-x: auto;
            background: #f8fbff;
            border: 1px solid #b6c2d2;
            box-shadow: 0 20px 50px rgba(15,23,42,.08);
        }

        /* TABLE */
        .applications-table {
            width: 100%;
            border-collapse: collapse;
            text-align: right;
        }

            .applications-table thead {
                background: #07142b;
                color: white;
            }

            .applications-table th {
                padding: 18px;
                font-size: 14px;
                font-weight: 900;
            }

            .applications-table td {
                padding: 18px;
                border-bottom: 1px solid #dbe5f0;
                color: #334155;
                font-weight: 700;
            }

            .applications-table tbody tr:hover td {
                background: #eef4ff;
            }

        /* ELEMENTS */
        .applicant-name {
            color: #07142b;
            font-weight: 900;
        }

        .phone-link {
            color: #0f3d75;
            text-decoration: none;
            font-weight: 900;
            direction: ltr;
        }

        .job-badge {
            padding: 7px 13px;
            border-radius: 999px;
            background: #eef4ff;
            border: 1px solid #b6c2d2;
            font-size: 12px;
            font-weight: 900;
        }

        .about-text {
            max-width: 320px;
            line-height: 1.8;
        }

        /* BUTTONS */
        .cv-actions {
            display: flex;
            justify-content: center;
            gap: 8px;
        }

        .btn-view {
            background: #eef4ff;
            color: #07142b;
            border: 1px solid #b6c2d2;
            padding: 8px 13px;
            border-radius: 12px;
            font-weight: 900;
        }

        .btn-download {
            background: #07142b;
            color: white;
            padding: 8px 13px;
            border-radius: 12px;
            font-weight: 900;
        }

        .no-cv {
            color: #b91c1c;
            background: #fef2f2;
            border: 1px solid #fecaca;
            padding: 7px 12px;
            border-radius: 999px;
        }

        /* ✅ FIXED (بدون @@) */
        @@media (max-width: 768px) .applications-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .btn-back {
            width: 100%;
            justify-content: center;
        }

        }
    </style>
}