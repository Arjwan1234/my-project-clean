@model IEnumerable<GAMA.CO5.Models.JobApplication>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "طلبات التوظيف";
}

<div class="admin-applications-page">

    <div class="applications-hero">
        <div>
            <span class="hero-badge">GAMA HR</span>
            <h2>طلبات التوظيف</h2>
            <p>استعراض بيانات المتقدمين، معلومات التواصل، والسير الذاتية.</p>
        </div>

        <a asp-controller="AdminJobs" asp-action="Index" class="btn-back">
            <i class="fa-solid fa-arrow-right"></i>
            رجوع للوظائف
        </a>
    </div>

    <div class="applications-card">
        <table class="applications-table">
            <thead>
                <tr>
                    <th>الاسم</th>
                    <th>الإيميل</th>
                    <th>رقم الهاتف</th>
                    <th>الوظيفة</th>
                    <th>نبذة</th>
                    <th>السيرة الذاتية</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="applicant-name">@item.FullName</td>
                        <td>@item.Email</td>
                        <td>
                            <a href="tel:@item.Phone" class="phone-link">
                                @item.Phone
                            </a>
                        </td>
                        <td>
                            <span class="job-badge">
                                @(string.IsNullOrWhiteSpace(item.JobTitle) ? "غير محدد" : item.JobTitle)
                            </span>
                        </td>
                        <td class="about-text">@item.AboutMe</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.CVFileName))
                            {
                                <div class="cv-actions">
                                    <a href="/uploads/cv/@item.CVFileName"
                                       target="_blank"
                                       class="btn-view">
                                        عرض
                                    </a>

                                    <a href="/uploads/cv/@item.CVFileName"
                                       download
                                       class="btn-download">
                                        تحميل
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="no-cv">لا يوجد CV</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .admin-applications-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29,78,216,.16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        .applications-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 12px;
            font-weight: 900;
            color: #dbeafe;
        }

        .applications-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
        }

        .applications-hero p {
            margin: 8px 0 0;
            color: #cbd5f5;
            font-weight: 600;
        }

        .btn-back {
            background: rgba(255,255,255,.12);
            color: white;
            border: 1px solid rgba(255,255,255,.18);
            padding: 12px 22px;
            border-radius: 18px;
            font-weight: 900;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: .25s;
            white-space: nowrap;
        }

            .btn-back:hover {
                color: white;
                background: rgba(255,255,255,.18);
                transform: translateY(-2px);
            }

        .applications-card {
            border-radius: 28px;
            overflow-x: auto;
            background: rgba(255,255,255,.95);
            border: 1px solid #dbe6f5;
            box-shadow: 0 24px 60px rgba(15,23,42,.10);
        }

        .applications-table {
            width: 100%;
            min-width: 1050px;
            border-collapse: collapse;
            text-align: right;
        }

            .applications-table thead {
                background: linear-gradient(135deg, #07142b, #0f3d75);
                color: white;
            }

            .applications-table th {
                padding: 18px;
                font-size: 14px;
                font-weight: 900;
                white-space: nowrap;
            }

            .applications-table td {
                padding: 18px;
                border-bottom: 1px solid #e5edf7;
                color: #334155;
                font-weight: 700;
                vertical-align: middle;
            }

            .applications-table tbody tr {
                transition: .2s;
            }

                .applications-table tbody tr:hover {
                    background: #f1f6ff;
                }

        .applicant-name {
            color: #07142b !important;
            font-weight: 900 !important;
            white-space: nowrap;
        }

        .phone-link {
            color: #0f3d75;
            text-decoration: none;
            font-weight: 900;
            direction: ltr;
            display: inline-block;
        }

        .job-badge {
            display: inline-flex;
            padding: 7px 13px;
            border-radius: 999px;
            background: #eef4ff;
            color: #0f3d75;
            border: 1px solid #dbe6f5;
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
        }

        .about-text {
            max-width: 320px;
            line-height: 1.8;
            color: #475569 !important;
        }

        .cv-actions {
            display: flex;
            justify-content: center;
            gap: 8px;
        }

        .btn-view,
        .btn-download {
            padding: 8px 13px;
            border-radius: 12px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 900;
            transition: .2s;
            white-space: nowrap;
        }

        .btn-view {
            background: #eef4ff;
            color: #0f3d75;
            border: 1px solid #dbe6f5;
        }

        .btn-download {
            background: linear-gradient(135deg, #d4af37, #f6d76b);
            color: #07142b;
        }

            .btn-view:hover,
            .btn-download:hover {
                transform: translateY(-1px);
            }

        .no-cv {
            color: #b91c1c;
            background: #fef2f2;
            border: 1px solid #fecaca;
            padding: 7px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 900;
        }

        @@media(max-width: 768px) {
            .applications-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .btn-back {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}