@model GAMA.CO5.Models.CareersViewModel

@{
    ViewData["Title"] = Model.PageTitle;
}

<!-- HERO -->
<section class="relative overflow-hidden">

    <div class="absolute inset-0">
        <img src="@Url.Content("~/images/services-bg.jpg")"
             alt="الوظائف"
             class="h-full w-full object-cover scale-105" />

        <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative mx-auto flex max-w-7xl flex-col items-end px-6 py-24" dir="rtl">
        <h1 class="text-5xl font-black text-white text-right">
            @Model.PageTitle
        </h1>

        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/90 text-right mr-auto">
            انضم إلى فريقنا وكن جزءًا من رحلة الابتكار والتحول الرقمي
        </p>

    </div>

</section>

<!-- CAREERS -->
<section class="relative overflow-hidden bg-[#eef4ff] py-24">
    <div class="relative mx-auto max-w-7xl px-6">

        @if (TempData["Success"] != null)
        {
            <div class="mb-8 rounded-xl bg-green-100 px-5 py-4 text-right font-bold text-green-800">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-8 rounded-xl bg-red-100 px-5 py-4 text-right font-bold text-red-800">
                @TempData["Error"]
            </div>
        }

        <div class="mb-14 text-right">
            <h2 class="text-3xl font-black text-[#020617]">
                الفرص الوظيفية
            </h2>

            <p class="mt-3 text-slate-700">
                اكتشف الوظائف المتاحة لدينا وابدأ رحلتك المهنية معنا
            </p>
        </div>

        <!-- ✅ هنا التعديل الوحيد -->
        <div class="grid grid-cols-1 gap-10 md:grid-cols-2 xl:grid-cols-3" dir="rtl">

            @foreach (var job in Model.Jobs)
            {
                <div class="group relative overflow-hidden rounded-[30px] border-2 border-[#07142b]/30 bg-white p-6 shadow-[0_20px_50px_rgba(0,0,0,0.15)] transition duration-500 hover:-translate-y-2 hover:border-[#07142b] hover:shadow-[0_30px_80px_rgba(0,0,0,0.25)]">

                    <!-- Header -->
                    <div class="mb-6 flex items-center justify-between">

                        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#07142b] text-white shadow-lg">
                            <i class="fa-solid fa-briefcase"></i>
                        </div>

                        <span class="rounded-full border border-sky-200 bg-sky-50 px-4 py-2 text-xs font-black text-[#07142b]">
                            @job.Type
                        </span>

                    </div>

                    <!-- Title -->
                    <h3 class="text-right text-2xl font-black text-[#07142b]">
                        @job.Title
                    </h3>

                    <!-- Location -->
                    <div class="mt-4 flex justify-end gap-2 text-sm font-bold text-slate-600">
                        <span>@job.Location</span>
                        <span>📍</span>
                    </div>

                    <!-- Description -->
                    <p class="mt-5 min-h-[95px] text-right text-sm leading-8 text-slate-700">
                        @job.Description
                    </p>

                    <!-- Divider -->
                    <div class="mt-6 h-px bg-slate-200"></div>

                    <!-- Button -->
                    <button type="button"
                            onclick="openApplyModal('@job.Title')"
                            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-[#07142b] px-5 py-3 text-sm font-black text-white shadow-lg transition hover:bg-[#0a1d3d] hover:shadow-xl">
                        قدّم الآن
                        <span>←</span>
                    </button>

                </div>
            }

        </div>
    </div>
</section>

<!-- MODAL -->
<div id="applyModal"
     class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4">

    <div class="w-full max-w-xl rounded-[26px] bg-white p-7 shadow-2xl">

        <div class="mb-6 flex items-center justify-between border-b border-slate-200 pb-4">
            <button type="button"
                    onclick="closeApplyModal()"
                    class="rounded-full bg-slate-100 px-3 py-1 text-lg font-black text-slate-700 hover:bg-slate-200">
                ×
            </button>

            <div class="text-right">
                <h2 class="text-2xl font-black text-[#020617]">
                    نموذج التقديم
                </h2>
                <p id="selectedJobTitle" class="mt-1 text-sm font-bold text-slate-600"></p>
            </div>
        </div>

        <form asp-controller="Careers"
              asp-action="Apply"
              method="post"
              enctype="multipart/form-data"
              class="space-y-5">

            @Html.AntiForgeryToken()

            <input type="hidden" id="JobTitleInput" name="JobTitle" />

            <input name="FullName" placeholder="الاسم الكامل" required
                   class="w-full rounded-xl border border-slate-300 px-4 py-3 text-right" />

            <input name="Email" type="email" placeholder="الإيميل" required
                   class="w-full rounded-xl border border-slate-300 px-4 py-3 text-right" />

            <input name="Phone" type="tel" placeholder="رقم الهاتف" required
                   class="w-full rounded-xl border border-slate-300 px-4 py-3 text-right" />

            <textarea name="AboutMe" placeholder="نبذة عنك" required
                      class="w-full rounded-xl border border-slate-300 px-4 py-3 text-right"></textarea>

            <input name="CVFile" type="file" required
                   class="w-full rounded-xl border border-slate-300 px-4 py-3 text-right" />

            <button type="submit"
                    class="w-full rounded-xl bg-[#07142b] px-5 py-4 font-black text-white hover:bg-[#0a1d3d]">
                إرسال الطلب
            </button>
        </form>
    </div>
</div>

<script>
    function openApplyModal(jobTitle) {
        document.getElementById("applyModal").classList.remove("hidden");
        document.getElementById("applyModal").classList.add("flex");

        document.getElementById("selectedJobTitle").innerText = "التقديم على: " + jobTitle;
        document.getElementById("JobTitleInput").value = jobTitle;
    }

    function closeApplyModal() {
        document.getElementById("applyModal").classList.add("hidden");
        document.getElementById("applyModal").classList.remove("flex");
    }
</script>