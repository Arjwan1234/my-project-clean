@model GAMA.CO5.Models.CareersViewModel
@{
    ViewData["Title"] = Model.PageTitle;
}
<section class="hero-section">
    <div class="overlay"></div>

    <div class="container hero-content">
        <span class="hero-badge">الوظائف ✦</span>
        <h1>@Model.PageTitle</h1>
        <p>
            انضم إلى فريقنا وكن جزءًا من رحلة الابتكار والتحول الرقمي
        </p>
    </div>
</section>
<section class="careers-section">
    <div class="container">
        <div class="careers-header">
            <h2>الفرص الوظيفية</h2>
            <p>اكتشف الوظائف المتاحة لدينا وابدأ رحلتك المهنية معنا</p>
        </div>

        <div class="jobs-grid">
            @foreach (var job in Model.Jobs)
            {
                <div class="job-card">
                    <div class="job-type">@job.Type</div>

                    <h3>@job.Title</h3>
                    <p class="job-location">📍 @job.Location</p>
                    <p class="job-desc">@job.Description</p>

                    <a href="#" class="apply-btn">قدّم الآن</a>
                </div>
            }
        </div>
    </div>
</section>

@section Styles {
    <style>
        .careers-section {
            background: #f7f8fc;
            padding: 70px 0;
        }

        .careers-header {
            text-align: center;
            margin-bottom: 40px;
        }

            .careers-header h2 {
                font-size: 2rem;
                font-weight: 800;
                color: #0f172a;
                margin-bottom: 10px;
            }

            .careers-header p {
                color: #6b7280;
                margin: 0;
            }

        .jobs-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .job-card {
            background: #fff;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
            border: 1px solid #e5e7eb;
            transition: .25s ease;
        }

            .job-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 36px rgba(15, 23, 42, 0.10);
            }

        .job-type {
            display: inline-block;
            margin-bottom: 14px;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(37, 150, 190, 0.12);
            color: #2596be;
            font-size: .85rem;
            font-weight: 700;
        }

        .job-card h3 {
            font-size: 1.3rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 10px;
        }

        .job-location {
            color: #475569;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .job-desc {
            color: #64748b;
            line-height: 1.8;
            margin-bottom: 18px;
        }

        .apply-btn {
            display: inline-block;
            width: 100%;
            text-align: center;
            padding: 12px 16px;
            border-radius: 14px;
            background: linear-gradient(135deg, #2596be, #1d4ed8);
            color: #fff;
            font-weight: 800;
            text-decoration: none;
            transition: .25s ease;
        }

            .apply-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 24px rgba(37, 150, 190, 0.22);
                color: #fff;
            }

        @@media (max-width: 991px) {
            .jobs-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 576px) {
            .jobs-grid {
                grid-template-columns: 1fr;
            }

            .careers-section {
                padding: 40px 0;
            }
        }
    </style>
}
