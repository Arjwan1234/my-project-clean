@model GAMA.CO5.Models.CareersViewModel

@{
    ViewData["Title"] = Model.PageTitle;
}
<!-- HERO -->
<section class="relative h-[470px] w-full overflow-hidden bg-[#eef4ff]">

    <!-- HERO IMAGE -->
    <img src="@Url.Content("~/images/hero.png")"
         alt="الوظائف"
         class="block h-full w-full object-cover object-top" />

    <!-- CONTENT -->
    <div class="absolute inset-0 flex items-center"
         dir="rtl">

        <div class="mr-auto ml-[55%] max-w-2xl text-right">

            <!-- TITLE -->
            <h1 class="text-5xl font-black leading-tight text-[#07142b] md:text-7xl">

                الوظائف

            </h1>

            <!-- DESCRIPTION -->
            <p class="mt-7 text-xl font-bold leading-[52px] text-[#07142b] md:text-2xl">

                انضم إلى فريقنا وكن جزءًا من رحلة الابتكار
                <br />
                والتحول الرقمي وصناعة الحلول المستقبلية

            </p>

            <!-- BUTTON -->
            <a href="#jobs"
               class="mt-8 inline-flex items-center justify-center rounded-2xl
                      bg-[#07142b]
                      px-10 py-4
                      text-lg font-black text-white
                      shadow-[0_10px_30px_rgba(7,20,43,0.18)]
                      transition-all duration-300
                      hover:bg-[#0a1d3d]">

                تصفح الوظائف

            </a>

        </div>

    </div>

</section><!-- CAREERS -->
<section id="jobs"
         class="relative overflow-hidden bg-[#eef4ff] pb-24 pt-20">

    <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-[#07142b]/5 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-72 w-72 rounded-full bg-sky-200/40 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-6">

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 rounded-2xl border border-green-200 bg-green-50 px-5 py-4 text-right text-sm font-black text-green-800 shadow-sm">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-right text-sm font-black text-red-800 shadow-sm">
                @TempData["Error"]
            </div>
        }

        <div class="mb-12 text-center">

            <h2 class="text-5xl font-black tracking-tight text-[#07142b]">
                الفرص الوظيفية
            </h2>

            <div class="mx-auto mt-5 h-1 w-24 rounded-full bg-[#07142b]"></div>

            <p class="mx-auto mt-6 max-w-2xl text-lg leading-9 text-slate-600">
                اكتشف الوظائف المتاحة وابدأ رحلتك المهنية معنا
            </p>

        </div>

        <div class="grid grid-cols-1 justify-items-center gap-10 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
             dir="rtl">

            @foreach (var job in Model.Jobs)
            {
                <div class="group relative flex h-[760px] w-[185px] flex-col overflow-hidden rounded-[32px]
                                border border-[#07142b]/10 bg-white p-4
                                shadow-[0_12px_35px_rgba(7,20,43,0.08)]
                                transition-all duration-500
                                hover:-translate-y-2
                                hover:shadow-[0_20px_45px_rgba(7,20,43,0.16)]">

                    <div class="absolute inset-0 bg-gradient-to-br from-white via-[#f8fbff] to-[#eef4ff]"></div>
                    <div class="absolute top-0 left-0 h-1 w-full bg-[#07142b]"></div>

                    <div class="relative z-10 flex h-full flex-col">

                        <div class="mb-7 flex items-center justify-between">

                            <span class="rounded-full bg-[#07142b] px-3 py-[6px] text-[9px] font-black text-white shadow-md">
                                @job.Type
                            </span>

                            <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-[#07142b] text-[10px] text-white shadow-md">
                                <i class="fa-solid fa-briefcase"></i>
                            </div>

                        </div>

                        <h3 class="text-right text-[16px] font-black leading-8 text-[#07142b] line-clamp-3">
                            @job.Title
                        </h3>

                        <div class="mt-5 flex items-center justify-end gap-1 text-[11px] font-bold text-slate-500">
                            <span>@job.Location</span>
                            <span>📍</span>
                        </div>

                        <p class="mt-7 line-clamp-[18] text-right text-[12px] leading-7 text-slate-600">
                            @job.Description
                        </p>

                        <button type="button"
                                onclick="openApplyModal('@job.Title')"
                                class="mt-auto flex h-11 w-full items-center justify-center gap-2 rounded-2xl bg-[#07142b] text-[12px] font-black text-white shadow-lg transition-all duration-300 hover:bg-[#0a1d3d]">
                            قدّم الآن
                            <span>←</span>
                        </button>

                    </div>

                </div>
            }

        </div>

    </div>

</section>

<!-- MODAL -->
<div id="applyModal"
     class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 px-4 backdrop-blur-sm">

    <div class="w-full max-w-lg overflow-hidden rounded-3xl border border-[#07142b]/10 bg-white shadow-[0_25px_80px_rgba(0,0,0,0.25)]">

        <div class="bg-[#07142b] p-6 text-white">

            <div class="flex items-center justify-between">

                <button type="button"
                        onclick="closeApplyModal()"
                        class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-lg font-black text-white transition hover:bg-white/20">
                    ×
                </button>

                <div class="text-right">
                    <h2 class="text-2xl font-black">
                        نموذج التقديم
                    </h2>

                    <p id="selectedJobTitle"
                       class="mt-1 text-sm text-white/80">
                    </p>
                </div>

            </div>

        </div>

        <form asp-controller="Careers"
              asp-action="Apply"
              method="post"
              enctype="multipart/form-data"
              class="space-y-4 p-6">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   id="JobTitleInput"
                   name="JobTitle" />

            <input name="FullName"
                   placeholder="الاسم الكامل"
                   required
                   class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-right text-sm outline-none transition focus:border-[#07142b] focus:bg-white" />

            <input name="Email"
                   type="email"
                   placeholder="الإيميل"
                   required
                   class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-right text-sm outline-none transition focus:border-[#07142b] focus:bg-white" />

            <input name="Phone"
                   type="tel"
                   placeholder="رقم الهاتف"
                   required
                   class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-right text-sm outline-none transition focus:border-[#07142b] focus:bg-white" />

            <textarea name="AboutMe"
                      placeholder="نبذة عنك"
                      required
                      class="h-28 w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-right text-sm outline-none transition focus:border-[#07142b] focus:bg-white"></textarea>

            <input name="CVFile"
                   type="file"
                   required
                   class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-right text-sm" />

            <button type="submit"
                    class="w-full rounded-2xl bg-[#07142b] px-5 py-3 text-sm font-black text-white shadow-lg transition hover:scale-[1.01] hover:bg-[#0a1d3d]">
                إرسال الطلب
            </button>

        </form>

    </div>

</div>

<script>
    function openApplyModal(jobTitle) {
        document.getElementById("applyModal").classList.remove("hidden");
        document.getElementById("applyModal").classList.add("flex");

        document.getElementById("selectedJobTitle").innerText =
            "التقديم على: " + jobTitle;

        document.getElementById("JobTitleInput").value = jobTitle;
    }

    function closeApplyModal() {
        document.getElementById("applyModal").classList.add("hidden");
        document.getElementById("applyModal").classList.remove("flex");
    }
</script>