@model IEnumerable<GAMA.CO5.Models.Product>
@{
    ViewData["Title"] = "المنتجات";
}

<section dir="rtl" class="min-h-screen bg-white text-slate-900">
    <div class="mx-auto max-w-[1180px] px-6 py-14 lg:px-8">
        <div class="text-center">
            <h1 class="text-[44px] font-extrabold tracking-tight text-slate-900">المنتجات</h1>
            <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-slate-500">
                تقدم حلولاً تقنية مبتكرة تخدم المجتمع وتلبي احتياجات العصر الرقمي
            </p>
        </div>

        @{
            var featuredProducts = Model?.Take(3).ToList() ?? new List<GAMA.CO5.Models.Product>();
            var allProducts = Model?.ToList() ?? new List<GAMA.CO5.Models.Product>();
        }

        <div class="mt-14">
            <div class="mb-6 flex items-center justify-between">
                <h2 class="text-3xl font-extrabold text-slate-900">المنتجات المميزة</h2>
                <div class="flex items-center gap-2 text-sm font-semibold text-violet-600">
                    <span>@featuredProducts.Count منتجات</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.719c-.783-.57-.38-1.81.588-1.81H7.03a1 1 0 00.95-.69l1.07-3.292z" />
                    </svg>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
                @foreach (var item in featuredProducts)
                {
                    var badgeColor = item.Name != null && item.Name.Contains("VESA")
                    ? "bg-blue-500"
                    : item.Name != null && (item.Name.Contains("مدار") || item.Name.Contains("Madar"))
                    ? "bg-orange-500"
                    : "bg-fuchsia-500";

                    <article class="group relative overflow-hidden rounded-[22px] border border-slate-200 shadow-[0_8px_30px_rgba(15,23,42,0.08)]">
                        <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "/images/products/default.jpg" : item.ImageUrl)"
                             alt="@item.Name"
                             class="h-[330px] w-full object-cover transition duration-500 group-hover:scale-105" />

                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>

                        <div class="absolute right-4 top-4">
                            <span class="rounded-full @badgeColor px-4 py-1.5 text-xs font-extrabold text-white shadow">
                                @item.Name
                            </span>
                        </div>

                        <div class="absolute inset-x-0 bottom-0 p-6 text-white">
                            <h3 class="mb-3 text-[30px] font-extrabold leading-tight">
                                @item.Name
                            </h3>

                            <p class="line-clamp-3 text-sm leading-7 text-white/85">
                                @(string.IsNullOrWhiteSpace(item.Description) ? "لا يوجد وصف متاح لهذا المنتج حالياً." : item.Description)
                            </p>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-white transition hover:text-violet-200">
                                اكتشف المزيد
                                <span>←</span>
                            </a>
                        </div>
                    </article>
                }
            </div>
        </div>

        <div class="mt-12">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
                <div class="order-2 flex flex-wrap items-center gap-3 lg:order-1">
                    <a asp-action="Index" class="rounded-full border border-slate-200 bg-violet-600 px-5 py-2 text-sm font-bold text-white shadow-sm">الكل</a>
                    <button type="button" class="rounded-full border border-slate-200 bg-slate-50 px-5 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100">الحج والعمرة</button>
                    <button type="button" class="rounded-full border border-slate-200 bg-slate-50 px-5 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100">حكومي</button>
                    <button type="button" class="rounded-full border border-slate-200 bg-slate-50 px-5 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100">أعمال</button>
                    <button type="button" class="rounded-full border border-slate-200 bg-slate-50 px-5 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100">صحة</button>
                    <button type="button" class="rounded-full border border-slate-200 bg-slate-50 px-5 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100">تعليم</button>
                    <button type="button" class="rounded-full border border-slate-200 bg-slate-50 px-5 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100">مالي</button>

                    <button type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-500 hover:bg-slate-50" aria-label="فلترة">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 01.8 1.6L14 13.5V19a1 1 0 01-.553.894l-2 1A1 1 0 0110 20v-6.5L3.2 4.6A1 1 0 013 4z" />
                        </svg>
                    </button>
                </div>

                <div class="order-1 lg:order-2 lg:w-[430px]">
                    <form method="get" asp-action="Index">
                        <label class="relative block">
                            <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-slate-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </span>
                            <input type="text"
                                   name="search"
                                   value="@Context.Request.Query["search"]"
                                   placeholder="ابحث عن منتج..."
                                   class="h-14 w-full rounded-full border border-slate-200 bg-white pr-12 pl-5 text-sm text-slate-700 shadow-sm outline-none placeholder:text-slate-400 focus:border-violet-400 focus:ring-4 focus:ring-violet-100" />
                        </label>
                    </form>
                </div>
            </div>

            <p class="mt-6 text-sm text-slate-400">عرض @allProducts.Count من @allProducts.Count منتج</p>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-7 sm:grid-cols-2 xl:grid-cols-4">
            @foreach (var item in allProducts)
            {
                var badgeColor = item.Name != null && item.Name.Contains("VESA")
                ? "bg-blue-500"
                : item.Name != null && (item.Name.Contains("مدار") || item.Name.Contains("Madar"))
                ? "bg-orange-500"
                : "bg-emerald-500";

                <article class="overflow-hidden rounded-[24px] border border-slate-200 bg-white shadow-[0_10px_30px_rgba(15,23,42,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(15,23,42,0.09)]">
                    <div class="relative h-[250px] overflow-hidden bg-slate-50">
                        <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "/images/products/default.jpg" : item.ImageUrl)"
                             alt="@item.Name"
                             class="h-full w-full object-cover" />

                        <span class="absolute right-4 top-4 rounded-full @badgeColor px-3 py-1 text-xs font-extrabold text-white">
                            @item.Name
                        </span>
                    </div>

                    <div class="p-6">
                        <div class="mb-3 flex items-start justify-between gap-3">
                            <h3 class="text-[25px] font-extrabold leading-tight text-slate-900">
                                @item.Name
                            </h3>
                            <button type="button" class="text-2xl leading-none text-slate-400">⋯</button>
                        </div>

                        <p class="line-clamp-3 text-sm leading-7 text-slate-500">
                            @(string.IsNullOrWhiteSpace(item.Description) ? "لا يوجد وصف متاح لهذا المنتج حالياً." : item.Description)
                        </p>

                        <div class="mt-5">
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="inline-flex items-center rounded-full bg-slate-900 px-4 py-2 text-sm font-bold text-white transition hover:bg-violet-600">
                                عرض التفاصيل
                            </a>
                        </div>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

@* 
    ملاحظات مهمة قبل الاستخدام:
    1) غيّر الـ namespace في Model إلى namespace المشروع عندك إذا مختلف.
    2) يفترض أن Product يحتوي على:
       Id, Name, Description, ImageUrl
    3) إذا الصور مخزنة داخل wwwroot/images/products فاخل ImageUrl يرجع مثل:
       /images/products/mudar.jpg
    4) للحصول على نفس الشكل تقريباً استخدم خط Tajawal أو Cairo في Layout.
*@
