@model IEnumerable<GAMA.CO5.Models.Partner>

@{
    ViewData["Title"] = "الشركاء";
}

<section dir="rtl" class="min-h-screen bg-white text-slate-900">
    <div class="mx-auto max-w-[1180px] px-6 py-14 lg:px-8">

        <div class="text-center">
            <h1 class="text-[44px] font-extrabold tracking-tight text-slate-900">
                الشركاء
            </h1>

            <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-slate-500">
                نفتخر بشراكاتنا الاستراتيجية التي تدعم الابتكار والتحول الرقمي
            </p>
        </div>

        @{
            var partners = Model?.ToList() ?? new List<GAMA.CO5.Models.Partner>();
        }

        <div class="mt-12">
            <p class="text-sm text-slate-400">
                عرض @partners.Count شريك
            </p>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-7 sm:grid-cols-2 xl:grid-cols-4">
            @foreach (var partner in partners)
            {
                <article class="overflow-hidden rounded-[24px] border border-slate-200 bg-white shadow-[0_10px_30px_rgba(15,23,42,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(15,23,42,0.09)]">

                    <div class="relative flex h-[220px] items-center justify-center overflow-hidden bg-slate-50 p-8">
                        <img src="@(string.IsNullOrWhiteSpace(partner.LogoUrl) ? "/images/placeholder.png" : partner.LogoUrl)"
                             alt="@partner.Name"
                             class="max-h-[140px] max-w-full object-contain" />
                    </div>

                    <div class="p-6 text-right">
                        <h3 class="text-[24px] font-extrabold leading-tight text-slate-900">
                            @partner.Name
                        </h3>

                        <p class="mt-4 line-clamp-3 text-sm leading-7 text-slate-500">
                            @(string.IsNullOrWhiteSpace(partner.Description) ? "لا يوجد وصف متاح لهذا الشريك حالياً." : partner.Description)
                        </p>

                        @if (!string.IsNullOrWhiteSpace(partner.WebsiteUrl))
                        {
                            <div class="mt-5">
                                <a href="@partner.WebsiteUrl"
                                   target="_blank"
                                   class="inline-flex items-center rounded-full bg-slate-900 px-4 py-2 text-sm font-bold text-white transition hover:bg-violet-600">
                                    زيارة الموقع
                                </a>
                            </div>
                        }
                    </div>

                </article>
            }
        </div>

    </div>
</section>