@model List<GAMA.CO5.Models.Partner>

@{
    ViewData["Title"] = "الشركاء";
    var partners = Model ?? new List<GAMA.CO5.Models.Partner>();
}

<section class="partners-hero-clean">
    <div class="partners-hero-overlay"></div>
    <div class="partners-hero-left-bars"></div>

    <div class="container partners-hero-inner">
        <span class="partners-hero-badge">شبكة الشراكات</span>
        <h1>شركاؤنا في النمو والابتكار</h1>
        <p>
            نفخر بالتعاون مع نخبة من الشركاء المحليين والعالميين، ونسعى من خلال هذه الشراكات
            إلى تقديم حلول تقنية موثوقة ومتقدمة تدعم النمو والتحول الرقمي.
        </p>
    </div>
</section>

<section class="partners-clean-section">
    <div class="partners-clean-side partners-clean-side-left"></div>
    <div class="partners-clean-side partners-clean-side-right"></div>

    <div class="container">
        <div class="partners-clean-intro">
            <span class="section-badge">شركاء النجاح</span>
            <h2>شراكات تعزز التميز</h2>
            <p>
                نؤمن أن القيمة الحقيقية تبدأ من شراكات استراتيجية قوية، لذلك نعمل مع أفضل الجهات
                لتقديم حلول أعمال وتجارب رقمية بمستوى احترافي راقٍ.
            </p>
        </div>

        <div class="partners-clean-grid">
            @foreach (var partner in partners)
            {
                <div class="partner-clean-item" title="@partner.Name">
                    <div class="partner-clean-circle">
                        <div class="partner-clean-ring ring-outer"></div>
                        <div class="partner-clean-ring ring-inner"></div>

                        <div class="partner-clean-logo-shell">
                            @if (!string.IsNullOrWhiteSpace(partner.LogoUrl))
                            {
                                <img src="@partner.LogoUrl" alt="@partner.Name" class="partner-clean-logo" />
                            }
                            else
                            {
                                <div class="partner-clean-no-logo">Logo</div>
                            }
                        </div>
                    </div>

                    <div class="partner-clean-info">
                        <h3>@partner.Name</h3>
                        <span class="partner-clean-status">شريك استراتيجي</span>
                    </div>
                </div>
            }
        </div>

        <div class="partners-clean-footer">
            <p>
                نفخر بهذه الشراكات التي تمثل جزءًا مهمًا من مسيرتنا في تقديم حلول تقنية عالية الجودة.
            </p>
        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --pc-navy: #0b2344;
            --pc-navy-2: #12335f;
            --pc-purple: #7c3aed;
            --pc-cyan: #38bdf8;
            --pc-text: #5f6f82;
            --pc-dark: #0f172a;
            --pc-bg: #f7fafc;
            --pc-line: rgba(148,163,184,.18);
        }

        .partners-hero-clean {
            position: relative;
            min-height: 430px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(7,27,55,.88), rgba(12,42,84,.78), rgba(44,32,90,.46)), url('/images/services-bg.jpg') center center / cover no-repeat;
        }

        .partners-hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 22%, rgba(56,189,248,.10), transparent 24%), radial-gradient(circle at 82% 20%, rgba(124,58,237,.12), transparent 24%), linear-gradient(180deg, rgba(5,18,36,.16), rgba(5,18,36,.66));
        }

        

        .partners-hero-inner {
            position: relative;
            z-index: 2;
            max-width: 940px;
            padding: 120px 20px 60px;
            color: #fff;
        }

        .partners-hero-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 18px;
            border-radius: 999px;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.16);
            backdrop-filter: blur(12px);
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 22px;
        }

        .partners-hero-inner h1 {
            margin: 0 0 18px;
            font-size: 60px;
            font-weight: 900;
            line-height: 1.1;
            letter-spacing: -1px;
            color: #fff;
            text-shadow: 0 10px 24px rgba(0,0,0,.18);
        }

        .partners-hero-inner p {
            margin: 0 auto;
            max-width: 760px;
            font-size: 20px;
            line-height: 1.95;
            color: rgba(255,255,255,.90);
        }

        .partners-clean-section {
            position: relative;
            padding: 100px 0 110px;
            background: linear-gradient(180deg, #f8fbfd 0%, #f4f8fc 100%);
            overflow: hidden;
        }

        /* زخارف جانبية مؤسسية هادئة جدًا */
        .partners-clean-side {
            position: absolute;
            top: 0;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .partners-clean-side-left {
            left: 0;
            width: 90px;
        }

            .partners-clean-side-left::before {
                content: "";
                position: absolute;
                left: 42px;
                top: 14%;
                width: 1px;
                height: 72%;
                background: linear-gradient(180deg, transparent, rgba(148,163,184,.24), transparent);
            }

            .partners-clean-side-left::after {
                content: "";
                position: absolute;
                left: 28px;
                top: 38%;
                width: 28px;
                height: 28px;
                border-radius: 50%;
                border: 1px solid rgba(56,189,248,.18);
                box-shadow: 0 0 0 10px rgba(56,189,248,.04);
            }

        .partners-clean-side-right {
            right: 0;
            width: 110px;
        }

            .partners-clean-side-right::before {
                content: "";
                position: absolute;
                right: 40px;
                top: 18%;
                width: 1px;
                height: 64%;
                background: linear-gradient(180deg, transparent, rgba(148,163,184,.22), transparent);
            }

            .partners-clean-side-right::after {
                content: "";
                position: absolute;
                right: 20px;
                top: 52%;
                width: 54px;
                height: 18px;
                border-radius: 999px;
                border: 1px solid rgba(148,163,184,.18);
                background: rgba(255,255,255,.20);
            }

        .partners-clean-intro,
        .partners-clean-grid,
        .partners-clean-footer {
            position: relative;
            z-index: 2;
        }

        .partners-clean-intro {
            max-width: 900px;
            margin: 0 auto 60px;
            text-align: center;
            padding: 0 20px;
        }

        .section-badge {
            display: inline-block;
            padding: 10px 18px;
            border-radius: 999px;
            background: rgba(124,58,237,.10);
            color: #6d28d9;
            border: 1px solid rgba(124,58,237,.16);
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 16px;
        }

        .partners-clean-intro h2 {
            margin: 0 0 16px;
            font-size: 48px;
            font-weight: 900;
            line-height: 1.18;
            color: var(--pc-dark);
        }

        .partners-clean-intro p {
            margin: 0;
            font-size: 19px;
            line-height: 2;
            color: var(--pc-text);
        }

        .partners-clean-grid {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 54px;
        }

        .partner-clean-item {
            text-align: center;
        }

        .partner-clean-circle {
            position: relative;
            width: 290px;
            height: 290px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: radial-gradient(circle at 30% 28%, rgba(255,255,255,.98), rgba(246,249,252,.96)), linear-gradient(180deg, #ffffff, #f7f9fc);
            border: 1px solid rgba(226,232,240,.92);
            box-shadow: 0 20px 56px rgba(15,23,42,.07), inset 0 1px 0 rgba(255,255,255,.95);
            transition: transform .25s ease, box-shadow .25s ease;
        }

            .partner-clean-circle:hover {
                transform: translateY(-5px);
                box-shadow: 0 26px 72px rgba(15,23,42,.10), 0 0 24px rgba(124,58,237,.05);
            }

        .partner-clean-ring {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }

        .ring-outer {
            width: 90%;
            height: 90%;
            border: 1px dashed rgba(124,58,237,.14);
        }

        .ring-inner {
            width: 74%;
            height: 74%;
            border: 1px dashed rgba(56,189,248,.14);
        }

        .partner-clean-logo-shell {
            width: 154px;
            height: 154px;
            border-radius: 50%;
            background: #fff;
            border: 1px solid rgba(203,213,225,.92);
            box-shadow: 0 10px 24px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.9);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            z-index: 2;
        }

        .partner-clean-logo {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            display: block;
        }

        .partner-clean-no-logo {
            color: #94a3b8;
            font-size: 13px;
            font-weight: 700;
        }

        .partner-clean-info {
            margin-top: 20px;
        }

            .partner-clean-info h3 {
                margin: 0 0 10px;
                font-size: 30px;
                font-weight: 900;
                color: var(--pc-dark);
                line-height: 1.35;
            }

        .partner-clean-status {
            display: inline-block;
            padding: 8px 16px;
            border-radius: 999px;
            background: linear-gradient(135deg, #e0f2fe, #ede9fe);
            color: #2563eb;
            font-size: 12px;
            font-weight: 800;
        }

        .partners-clean-footer {
            margin-top: 48px;
            text-align: center;
        }

            .partners-clean-footer p {
                margin: 0;
                color: var(--pc-text);
                font-size: 16px;
                line-height: 2;
            }

        @@media (max-width: 992px) {
            .partners-hero-inner h1 {
                font-size: 44px;
            }

            .partners-hero-inner p {
                font-size: 18px;
            }

            .partners-clean-intro h2 {
                font-size: 36px;
            }

            .partners-clean-intro p {
                font-size: 17px;
            }

            .partner-clean-circle {
                width: 245px;
                height: 245px;
            }

            .partner-clean-logo-shell {
                width: 128px;
                height: 128px;
            }

            .partner-clean-info h3 {
                font-size: 22px;
            }
        }

        @@media (max-width: 768px) {
            .partners-hero-clean {
                min-height: 340px;
            }

            .partners-hero-left-bars {
                width: 56px;
                background: radial-gradient(circle at 0 12px, transparent 12px, #7c3aed 13px, #7c3aed 18px, transparent 19px) 0 0 / 56px 52px repeat-y, radial-gradient(circle at 0 12px, transparent 12px, #38bdf8 13px, #38bdf8 18px, transparent 19px) 0 18px / 56px 52px repeat-y, radial-gradient(circle at 0 12px, transparent 12px, #f97316 13px, #f97316 18px, transparent 19px) 0 36px / 56px 52px repeat-y;
                opacity: .84;
            }

            .partners-hero-inner {
                padding: 100px 20px 44px;
            }

                .partners-hero-inner h1 {
                    font-size: 34px;
                }

                .partners-hero-inner p {
                    font-size: 15px;
                }

            .partners-clean-section {
                padding: 82px 0 92px;
            }

            .partners-clean-intro {
                margin-bottom: 38px;
            }

                .partners-clean-intro h2 {
                    font-size: 29px;
                }

                .partners-clean-intro p {
                    font-size: 15px;
                }

            .partner-clean-circle {
                width: 220px;
                height: 220px;
            }

            .partner-clean-logo-shell {
                width: 112px;
                height: 112px;
            }

            .partner-clean-info h3 {
                font-size: 20px;
            }

            .partners-clean-side-left,
            .partners-clean-side-right {
                width: 60px;
                opacity: .65;
            }

                .partners-clean-side-left::before,
                .partners-clean-side-left::after,
                .partners-clean-side-right::before,
                .partners-clean-side-right::after {
                    display: none;
                }
        }
    </style>
}