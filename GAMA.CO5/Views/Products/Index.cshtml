            </p>
            <a asp-controller="Products" asp-action="Details" asp-route-id="1"
            class="mt-4 inline-flex items-center gap-2 text-base font-bold text-violet-600 hover:text-violet-700">
                عرض
                <span>←</span>
            </a>
