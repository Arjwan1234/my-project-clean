    <article class="overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-[0_10px_30px_rgba(15,23,42,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(15,23,42,0.10)]">
        <div class="relative h-[280px] overflow-hidden bg-slate-50">
            <img src="/images/mudar.jpg" alt="رحلة ذكية متكاملة" class="h-full w-full object-cover" />
            <span class="absolute right-4 top-4 rounded-full bg-orange-500 px-3 py-1 text-xs font-extrabold text-white shadow">مدار</span>
