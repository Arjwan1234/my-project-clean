@{
    ViewData["Title"] = "المنتجات";
}

<!-- Header -->
<div class="text-center">
    <h1 class="text-[44px] font-extrabold tracking-tight text-slate-900">
        المنتجات
    </h1>
    <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-slate-500">
        تقدم حلولاً تقنية مبتكرة تخدم المجتمع وتلبي احتياجات العصر الرقمي
    </p>
</div>

<!-- Featured -->
<div class="mt-14">
    <div class="mb-6 flex items-center justify-between">
        <h2 class="text-3xl font-extrabold text-slate-900">المنتجات المميزة</h2>
        <div class="flex items-center gap-2 text-sm font-bold text-violet-600">
            <span>3 منتجات</span>
            <span>★</span>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

        <!-- Featured 1 -->
        <article class="group relative overflow-hidden rounded-[22px] border border-slate-200 bg-white shadow-[0_8px_30px_rgba(15,23,42,0.08)]">
            <img src="/images/qbool.jpg"
                 alt="إدارة الحج والعمرة بكفاءة عالية"
                 class="h-[330px] w-full object-cover transition duration-500 group-hover:scale-105" />

            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>

            <div class="absolute right-4 top-4">
                <span class="rounded-full bg-fuchsia-500 px-4 py-1.5 text-xs font-extrabold text-white shadow">
                    قبول يا حاج
                </span>
            </div>

            <div class="absolute inset-x-0 bottom-0 p-6 text-white">
                <h3 class="mb-3 text-[30px] font-extrabold leading-tight">
                    إدارة الحج والعمرة بكفاءة عالية
                </h3>

                <p class="line-clamp-3 text-sm leading-7 text-white/85">
                    منصة متكاملة لإدارة عمليات الحج والعمرة، وتنظيم الرحلات، وتحسين تجربة المستخدم من خلال واجهات سهلة وحلول رقمية فعالة.
                </p>

                <a asp-controller="Products"
                   asp-action="Details"
                   asp-route-id="1"
                   class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-white transition hover:text-violet-200">
                    اكتشف المزيد
                    <span>←</span>
                </a>
            </div>
        </article>

        <!-- Featured 2 -->
        <article class="group relative overflow-hidden rounded-[22px] border border-slate-200 bg-white shadow-[0_8px_30px_rgba(15,23,42,0.08)]">
            <img src="/images/vesa.jpg"
                 alt="حلول ذكية ومتطورة"
                 class="h-[330px] w-full object-cover transition duration-500 group-hover:scale-105" />

            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>

            <div class="absolute right-4 top-4">
                <span class="rounded-full bg-blue-500 px-4 py-1.5 text-xs font-extrabold text-white shadow">
                    VESA
                </span>
            </div>

            <div class="absolute inset-x-0 bottom-0 p-6 text-white">
                <h3 class="mb-3 text-[30px] font-extrabold leading-tight">
                    حلول ذكية ومتطورة
                </h3>

                <p class="line-clamp-3 text-sm leading-7 text-white/85">
                    تطبيق VESA يقدم حلولاً متكاملة وذكية باستخدام أحدث التقنيات، مع تجربة استخدام سهلة وتصميم حديث يرفع كفاءة العمل.
                </p>
                <a asp-controller="Products"
                   asp-action="Details"
                   asp-route-id="2"
                   class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-white transition hover:text-violet-200">
                    اكتشف المزيد
                    <span>←</span>
                </a>
            </div>
        </article>

        <!-- Featured 3 -->
        <article class="group relative overflow-hidden rounded-[22px] border border-slate-200 bg-white shadow-[0_8px_30px_rgba(15,23,42,0.08)]">
            <img src="/images/mudar.jpg"
                 alt="رحلة ذكية متكاملة"
                 class="h-[330px] w-full object-cover transition duration-500 group-hover:scale-105" />

            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>

            <div class="absolute right-4 top-4">
                <span class="rounded-full bg-orange-500 px-4 py-1.5 text-xs font-extrabold text-white shadow">
                    مدار
                </span>
            </div>

            <div class="absolute inset-x-0 bottom-0 p-6 text-white">
                <h3 class="mb-3 text-[30px] font-extrabold leading-tight">
                    رحلة ذكية متكاملة
                </h3>

                <p class="line-clamp-3 text-sm leading-7 text-white/85">
                    لأن خدمة ضيوف الرحمن تستحق الأفضل، يقدم مدار تجربة متكاملة لإدارة الرحلات والخدمات والمعلومات في منصة واحدة.
                </p>

                <a asp-controller="Products"
                   asp-action="Details"
                   asp-route-id="3"
                   class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-white transition hover:text-violet-200">
                    اكتشف المزيد
                    <span>←</span>
                </a>
            </div>
        </article>
    </div>
</div>

<!-- Filters + Search -->
<div class="mt-12">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">

        <div class="order-2 flex flex-wrap items-center gap-3 lg:order-1">
            <a href="#" class="rounded-full border border-violet-600 bg-violet-600 px-5 py-2 text-sm font-bold text-white shadow-sm">الكل</a>
            <a href="#" class="rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-bold text-slate-600 hover:bg-slate-100">الحج والعمرة</a>
            <a href="#" class="rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-bold text-slate-600 hover:bg-slate-100">حكومي</a>
            <a href="#" class="rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-bold text-slate-600 hover:bg-slate-100">أعمال</a>
            <a href="#" class="rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-bold text-slate-600 hover:bg-slate-100">صحة</a>
            <a href="#" class="rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-bold text-slate-600 hover:bg-slate-100">تعليم</a>
            <a href="#" class="rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-bold text-slate-600 hover:bg-slate-100">مالي</a>

            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 01.8 1.6L14 13.5V19a1 1 0 01-.553.894l-2 1A1 1 0 0110 20v-6.5L3.2 4.6A1 1 0 013 4z" />
                </svg>
            </span>
        </div>

        <div class="order-1 lg:order-2 lg:w-[430px]">
            <label class="relative block">
                <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-slate-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </span>

                <input type="text"
                       placeholder="ابحث عن منتج..."
                       class="h-14 w-full rounded-full border border-slate-200 bg-white pr-12 pl-5 text-sm text-slate-700 shadow-[0_4px_18px_rgba(15,23,42,0.04)] outline-none placeholder:text-slate-400 focus:border-violet-300" />
            </label>
        </div>
    </div>

    <p class="mt-6 text-sm text-slate-400">عرض 20 من 20 منتج</p>
</div>

<!-- Products Grid -->
<div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">

    <article class="overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-[0_10px_30px_rgba(15,23,42,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(15,23,42,0.10)]">
        <div class="relative h-[280px] overflow-hidden bg-slate-50">
            <img src="/images/mudar.jpg" alt="حلول تقنية متطورة" class="h-full w-full object-cover" />
