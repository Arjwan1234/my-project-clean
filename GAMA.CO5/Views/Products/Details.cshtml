@using System.Linq
@model GAMA.CO5.Models.Product

@{
    ViewData["Title"] = Model.Name;

    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "/images/products/placeholder.jpg"
        : Model.ImageUrl;

    var features = string.IsNullOrWhiteSpace(Model.Features)
        ? new List<string>()
        : Model.Features.Split(',', StringSplitOptions.RemoveEmptyEntries)
                        .Select(f => f.Trim())
                        .Where(f => !string.IsNullOrWhiteSpace(f))
                        .ToList();

    var badgeText = string.IsNullOrWhiteSpace(Model.BadgeText) ? "منتج" : Model.BadgeText;
    var categoryText = string.IsNullOrWhiteSpace(Model.Category) ? "منتج" : Model.Category;

    var appStoreUrl = "https://apps.apple.com/sa/app/%D9%85%D8%AF%D8%A7%D8%B1/id6449373358?l=ar";
    var webDemoUrl = "https://www.google.com/";

    Func<string?, string> badgeClass = (badge) =>
    {
        var key = (badge ?? "").Trim().ToLower();

        return key switch
        {
            "success" => "bg-emerald-500 text-white",
            "green" => "bg-emerald-500 text-white",
            "warning" => "bg-amber-500 text-white",
            "yellow" => "bg-amber-500 text-white",
            "danger" => "bg-rose-500 text-white",
            "red" => "bg-rose-500 text-white",
            "info" => "bg-sky-500 text-white",
            "blue" => "bg-blue-500 text-white",
            "primary" => "bg-violet-600 text-white",
            "purple" => "bg-violet-600 text-white",
            "dark" => "bg-slate-900 text-white",
            _ => "bg-violet-600 text-white"
        };
    };
}

<section class="relative overflow-hidden">
    <div class="absolute inset-0">
        <img src="@imageUrl"
             alt="@Model.Name"
             class="h-full w-full object-cover" />
        <div class="absolute inset-0 bg-slate-950/80"></div>
        <div class="absolute inset-0 bg-gradient-to-l from-slate-950/90 via-slate-900/75 to-sky-900/45"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-24">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2">

            <div class="max-w-2xl">
                <a asp-action="Index"
                   class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-medium text-white/90 no-underline backdrop-blur transition hover:bg-white/15">
                    <span>→</span>
                    العودة للمنتجات
                </a>

                <div class="mt-6 flex flex-wrap items-center gap-3">
                    <span class="rounded-full px-3 py-1 text-xs font-bold shadow @badgeClass(Model.BadgeClass)">
                        @badgeText
                    </span>

                    <span class="rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-semibold text-white/80">
                        @categoryText
                    </span>

                    @if (Model.IsFeatured)
                    {
                        <span class="rounded-full border border-violet-300/20 bg-violet-400/15 px-3 py-1 text-xs font-bold text-violet-100">
                            منتج مميز
                        </span>
                    }
                </div>

                <h1 class="mt-6 text-4xl font-black leading-tight text-white lg:text-6xl">
                    @Model.Name
                </h1>

                <p class="mt-5 max-w-2xl text-base leading-8 text-white/75 lg:text-lg">
                    @Model.Description
                </p>

                <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                    <a href="@webDemoUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="inline-flex items-center justify-center rounded-full bg-violet-600 px-6 py-3 text-sm font-bold text-white no-underline shadow-sm transition hover:bg-violet-700">
                        جرّب على الويب
                    </a>

                    <a href="@appStoreUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/10 px-6 py-3 text-sm font-bold text-white no-underline backdrop-blur transition hover:bg-white/15">
                        App Store
                    </a>
                </div>
            </div>

            <div class="lg:justify-self-end">
                <div class="overflow-hidden rounded-[32px] border border-white/10 bg-white/10 p-3 shadow-[0_20px_60px_rgba(2,6,23,0.35)] backdrop-blur">
                    <div class="overflow-hidden rounded-[24px] bg-slate-950">
                        <img src="@imageUrl"
                             alt="@Model.Name"
                             class="h-[260px] w-full object-cover sm:h-[340px] lg:h-[420px]"
                             onerror="this.onerror=null;this.src='/images/products/placeholder.jpg';" />
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="bg-[linear-gradient(180deg,#f8fafc_0%,#f3f6fb_100%)] py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

            <div class="lg:col-span-2">
                <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm lg:p-8">
                    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <span class="inline-flex rounded-full bg-violet-100 px-3 py-1 text-xs font-bold text-violet-700">
                                PRODUCT OVERVIEW
                            </span>
                            <h2 class="mt-4 text-2xl font-black text-slate-900 lg:text-3xl">
                                نبذة عن المنتج
                            </h2>
                        </div>

                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                            @categoryText
                        </span>
                    </div>

                    <p class="text-sm leading-8 text-slate-600 lg:text-base">
                        @Model.Description
                    </p>
                </div>
            </div>

            <div>
                <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm lg:p-7">
                    <h3 class="text-xl font-black text-slate-900">
                        معلومات سريعة
                    </h3>

                    <div class="mt-6 space-y-4">
                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold tracking-[0.18em] text-slate-400">
                                التصنيف
                            </p>
                            <p class="mt-2 text-lg font-bold text-slate-900">
                                @categoryText
                            </p>
                        </div>

                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold tracking-[0.18em] text-slate-400">
                                الشارة
                            </p>
                            <div class="mt-2">
                                <span class="rounded-full px-3 py-1 text-xs font-bold shadow @badgeClass(Model.BadgeClass)">
                                    @badgeText
                                </span>
                            </div>
                        </div>

                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold tracking-[0.18em] text-slate-400">
                                الحالة
                            </p>
                            <p class="mt-2 text-lg font-bold text-slate-900">
                                @(Model.IsFeatured ? "مميز" : "منتج عادي")
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">

            <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm lg:p-8">
                <div class="mb-6">
                    <span class="inline-flex rounded-full bg-sky-100 px-3 py-1 text-xs font-bold text-sky-700">
                        تجربة المنتج
                    </span>

                    <h2 class="mt-4 text-2xl font-black text-slate-900">
                        اختر طريقة التجربة
                    </h2>

                    <p class="mt-3 text-sm leading-7 text-slate-500">
                        جرّب المنتج عبر الويب أو من خلال تطبيق الجوال بحسب القناة المناسبة لك.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <a href="@webDemoUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="group rounded-[24px] border border-slate-200 bg-slate-50 p-5 no-underline transition hover:-translate-y-1 hover:border-violet-200 hover:bg-white hover:shadow-md">
                        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-violet-100 text-violet-700">
                            🌐
                        </div>

                        <h3 class="mt-4 text-lg font-extrabold text-slate-900">
                            تطبيق الويب
                        </h3>

                        <p class="mt-2 text-sm leading-7 text-slate-500">
                            تشغيل مباشر عبر المتصفح بتجربة سريعة وواضحة.
                        </p>

                        <span class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-violet-600">
                            جرّب الآن
                            <span>←</span>
                        </span>
                    </a>

                    <a href="@appStoreUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="group rounded-[24px] border border-slate-200 bg-slate-50 p-5 no-underline transition hover:-translate-y-1 hover:border-violet-200 hover:bg-white hover:shadow-md">
                        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-900 text-white">
                            📱
                        </div>

                        <h3 class="mt-4 text-lg font-extrabold text-slate-900">
                            تطبيق الجوال
                        </h3>

                        <p class="mt-2 text-sm leading-7 text-slate-500">
                            تجربة مرنة على الهاتف للوصول السريع إلى المنتج والخدمات.
                        </p>

                        <span class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-violet-600">
                            فتح المتجر
                            <span>←</span>
                        </span>
                    </a>
                </div>
            </div>

            <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm lg:p-8">
                <div class="mb-6">
                    <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-700">
                        الصورة الرئيسية
                    </span>

                    <h2 class="mt-4 text-2xl font-black text-slate-900">
                        عرض بصري للمنتج
                    </h2>
                </div>

                <div class="overflow-hidden rounded-[24px] border border-slate-200 bg-slate-50">
                    <img src="@imageUrl"
                         alt="@Model.Name"
                         class="h-[280px] w-full object-cover"
                         onerror="this.onerror=null;this.src='/images/products/placeholder.jpg';" />
                </div>
            </div>

        </div>

        @if (features.Any())
        {
            <div class="mt-8 rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm lg:p-8">
                <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-700">
                            FEATURES
                        </span>

                        <h2 class="mt-4 text-2xl font-black text-slate-900 lg:text-3xl">
                            المميزات الرئيسية
                        </h2>
                    </div>

                    <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-bold text-slate-600">
                        @features.Count ميزة
                    </span>
                </div>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
                    @foreach (var feature in features)
                    {
                        <div class="rounded-[22px] border border-slate-200 bg-slate-50 p-5 transition hover:border-violet-200 hover:bg-white hover:shadow-sm">
                            <div class="flex items-start gap-4">
                                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-violet-600 text-sm font-bold text-white">
                                    ✓
                                </span>

                                <p class="m-0 text-sm font-medium leading-7 text-slate-700">
                                    @feature
                                </p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</section>