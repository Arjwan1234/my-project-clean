@model GAMA.CO5.Models.Product

@{
    ViewData["Title"] = Model.Name;

    var features = string.IsNullOrWhiteSpace(Model.Features)
        ? new List<string>()
        : Model.Features
            .Split(new[] { "\r\n", "\n", "," }, StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();
}

<section class="min-h-screen bg-slate-50 text-slate-900" dir="rtl">
    <div class="mx-auto max-w-[1180px] px-4 py-12 sm:px-6 lg:px-8">

        <div class="mb-8">
            <a asp-action="Index"
               class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-bold text-slate-600 shadow-sm transition hover:bg-slate-100">
                <span>→</span>
                رجوع للمنتجات
            </a>
        </div>

        <section class="overflow-hidden rounded-[34px] border border-slate-200 bg-white shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
            <div class="grid grid-cols-1 lg:grid-cols-2">

                <div class="relative min-h-[420px] overflow-hidden bg-slate-100">
                    <img src="@Model.ImageUrl"
                         alt="@Model.Name"
                         class="absolute inset-0 h-full w-full object-cover" />

                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

                    <span class="absolute right-6 top-6 rounded-full bg-violet-600 px-5 py-2 text-xs font-extrabold text-white shadow">
                        @Model.BadgeText
                    </span>

                    <div class="absolute bottom-6 right-6 left-6 text-white">
                        <p class="mb-2 text-sm font-bold text-white/80">@Model.Category</p>
                        <h1 class="text-4xl font-extrabold leading-tight md:text-5xl">
                            @Model.Name
                        </h1>
                    </div>
                </div>

                <div class="flex flex-col justify-center p-7 text-right md:p-12">
                    <span class="mb-4 inline-flex w-fit rounded-full bg-orange-100 px-4 py-2 text-sm font-extrabold text-orange-600">
                        تفاصيل المنتج
                    </span>

                    <h2 class="text-3xl font-extrabold leading-tight text-slate-900 md:text-4xl">
                        تجربة رقمية مصممة بعناية
                    </h2>

                    <p class="mt-5 text-lg leading-9 text-slate-500">
                        @Model.Description
                    </p>

                    <div class="mt-8 flex flex-wrap gap-3">
                        <a href="#try"
                           class="rounded-full bg-orange-500 px-7 py-3 text-sm font-extrabold text-white shadow-[0_8px_24px_rgba(249,115,22,0.25)] transition hover:bg-orange-600">
                            جرب المنتج الآن
                        </a>

                        <a href="#features"
                           class="rounded-full border border-slate-200 bg-white px-7 py-3 text-sm font-extrabold text-slate-700 transition hover:bg-slate-100">
                            عرض المميزات
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section id="try" class="py-16">
            <div class="text-center">
                <h2 class="text-4xl font-extrabold text-orange-500">
                    جرب المنتج الآن
                </h2>
                <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-500">
                    اختر الطريقة المناسبة لك للوصول إلى المنتج والاستفادة من خدماته.
                </p>
            </div>

            <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
                <div class="rounded-[28px] border border-slate-200 bg-white p-8 text-center shadow-[0_10px_30px_rgba(15,23,42,0.06)]">
                    <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-violet-100 text-3xl">
                        📱
                    </div>
                    <h3 class="text-2xl font-extrabold text-slate-900">تطبيق الجوال</h3>
                    <p class="mt-3 leading-7 text-slate-500">
                        استخدم المنتج من خلال الجوال بسهولة وفي أي وقت.
                    </p>
                    <a href="#"
                       class="mt-6 inline-flex rounded-full bg-violet-600 px-7 py-3 text-sm font-extrabold text-white transition hover:bg-violet-700">
                        تحميل التطبيق
                    </a>
                </div>

                <div class="rounded-[28px] border border-slate-200 bg-white p-8 text-center shadow-[0_10px_30px_rgba(15,23,42,0.06)]">
                    <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-orange-100 text-3xl">
                        🌐
                    </div>
                    <h3 class="text-2xl font-extrabold text-slate-900">المتصفح</h3>
                    <p class="mt-3 leading-7 text-slate-500">
                        ادخل على المنصة مباشرة من خلال المتصفح.
                    </p>
                    <a href="#"
                       class="mt-6 inline-flex rounded-full bg-orange-500 px-7 py-3 text-sm font-extrabold text-white transition hover:bg-orange-600">
                        فتح المنصة
                    </a>
                </div>
            </div>
        </section>

        @if (features.Any())
        {
            <section id="features" class="pb-16">
                <div class="text-center">
                    <h2 class="text-4xl font-extrabold text-slate-900">
                        لماذا @Model.Name؟
                    </h2>
                    <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-500">
                        مميزات تساعدك على تحقيق تجربة أفضل وكفاءة أعلى.
                    </p>
                </div>

                <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var feature in features)
                    {
                        <div class="rounded-[28px] border border-slate-200 bg-white p-7 text-center shadow-[0_10px_30px_rgba(15,23,42,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(15,23,42,0.10)]">
                            <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100 text-2xl">
                                ✨
                            </div>
                            <h3 class="text-xl font-extrabold text-slate-900">
                                @feature
                            </h3>
                        </div>
                    }
                </div>
            </section>
        }

    </div>
</section>