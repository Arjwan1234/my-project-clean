@model GAMA.CO5.Models.Product

@{
    ViewData["Title"] = Model.Name;

    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "/images/products/placeholder.jpg"
        : Model.ImageUrl;

    var features = string.IsNullOrWhiteSpace(Model.Features)
        ? new List<string>()
        : Model.Features.Split(',', StringSplitOptions.RemoveEmptyEntries)
                        .Select(f => f.Trim())
                        .ToList();

    var appStoreUrl = "https://apps.apple.com/sa/app/%D9%85%D8%AF%D8%A7%D8%B1/id6449373358?l=ar";
    var webDemoUrl = "https://www.google.com/";
}

<section class="py-5 py-lg-6" style="background: linear-gradient(180deg, #061225 0%, #0b1f3a 45%, #eef4fb 100%);">
    <div class="container">

        <!-- Header -->
        <div class="text-center mx-auto" style="max-width: 850px;">
            <span class="d-inline-flex align-items-center px-3 py-2 rounded-pill fw-bold small"
                  style="background: rgba(59,130,246,.12); color:#93c5fd; border:1px solid rgba(147,197,253,.25); letter-spacing:.12em;">
                EXECUTIVE DIGITAL EXPERIENCE
            </span>

            <h1 class="mt-4 fw-bold" style="color:#ffffff; font-size: clamp(2rem, 4vw, 4rem);">
                جرّب @Model.Name الآن
            </h1>

            <p class="mt-3 mx-auto" style="max-width: 700px; color:#cbd5e1; font-size:1.05rem; line-height:1.9;">
                تجربة قوية وواضحة تمنح المنتج حضورًا احترافيًا وتبرز قيمته بأسلوب تنفيذي عصري.
            </p>
        </div>

        <!-- Main Image -->
        <div class="mx-auto mt-5" style="max-width: 920px;">
            <div class="p-2 rounded-4 shadow-lg" style="background: rgba(8,20,41,.85); border:1px solid rgba(96,165,250,.20);">
                <div class="rounded-4 overflow-hidden" style="border:1px solid rgba(59,130,246,.25); background:#08111f;">
                    <img src="@imageUrl"
                         alt="@Model.Name"
                         class="w-100"
                         style="height: clamp(220px, 42vw, 420px); object-fit: cover; object-position: center;"
                         onerror="this.onerror=null;this.src='/images/products/placeholder.jpg';" />
                </div>
            </div>
        </div>

        <!-- Intro -->
        <div class="text-center mt-5">
            <h2 class="fw-bold" style="color:#0f172a; font-size: clamp(1.6rem, 2vw, 2.2rem);">
                اختر طريقة التجربة
            </h2>

            <p class="mt-2" style="color:#64748b; font-size:1rem;">
                جرّب المنتج عبر الويب أو على الجوال بتجربة بصرية أوضح وأقوى.
            </p>
        </div>

        <!-- Cards -->
        <div class="row g-4 mt-2">

            <!-- WEB CARD -->
            <div class="col-lg-6">
                <div class="h-100 rounded-4 p-4 p-lg-5 shadow-lg"
                     style="background: linear-gradient(180deg, #0b1b33 0%, #10284b 100%); border:1px solid rgba(96,165,250,.22); color:#fff;">

                    <div class="text-center">
                        <div class="mx-auto d-flex align-items-center justify-content-center rounded-4 shadow"
                             style="width:110px; height:150px; background:#ffffff;">
                            <img src="@imageUrl"
                                 alt="@Model.Name"
                                 style="width:86px; height:126px; object-fit:cover; border-radius:16px;"
                                 onerror="this.onerror=null;this.src='/images/products/placeholder.jpg';" />
                        </div>

                        <span class="d-inline-block mt-4 px-3 py-2 rounded-pill fw-bold small"
                              style="background: rgba(14,165,233,.12); color:#7dd3fc; border:1px solid rgba(125,211,252,.18);">
                            🌐 تطبيق ويب
                        </span>

                        <h3 class="mt-4 fw-bold" style="font-size: 2rem; color:#ffffff;">
                            جرّب التطبيق على المتصفح
                        </h3>

                        <p class="mt-3 mb-0" style="color:#dbeafe; font-size:1rem; line-height:1.9;">
                            تجربة فورية وواضحة تمنحك وصولًا مباشرًا للخدمات والمحتوى بأسلوب احترافي سريع وسلس.
                        </p>

                        <p class="mt-3" style="color:#93a9c4; font-size:.95rem;">
                            يعمل بكفاءة على جميع المتصفحات الحديثة
                        </p>

                        <a href="@webDemoUrl"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="btn mt-3 px-4 py-3 rounded-pill fw-bold"
                           style="background: linear-gradient(90deg, #0ea5e9 0%, #2563eb 100%); color:#fff; border:none; min-width:190px;">
                            جرّب الآن
                        </a>
                    </div>
                </div>
            </div>

            <!-- MOBILE CARD -->
            <div class="col-lg-6">
                <div class="h-100 rounded-4 p-4 p-lg-5 shadow-lg"
                     style="background: linear-gradient(180deg, #07162b 0%, #12345c 100%); border:1px solid rgba(147,197,253,.22); color:#fff;">

                    <div class="text-center">
                        <div class="mx-auto d-flex align-items-center justify-content-center rounded-4 shadow"
                             style="width:110px; height:150px; background:#ffffff;">
                            <img src="@imageUrl"
                                 alt="@Model.Name"
                                 style="width:86px; height:126px; object-fit:cover; border-radius:16px;"
                                 onerror="this.onerror=null;this.src='/images/products/placeholder.jpg';" />
                        </div>

                        <span class="d-inline-block mt-4 px-3 py-2 rounded-pill fw-bold small"
                              style="background: rgba(96,165,250,.14); color:#bfdbfe; border:1px solid rgba(191,219,254,.18);">
                            📱 تطبيق الجوال
                        </span>

                        <h3 class="mt-4 fw-bold" style="font-size: 2rem; color:#ffffff;">
                            جرّب التطبيق على الهاتف المحمول
                        </h3>

                        <p class="mt-3 mb-0" style="color:#dbeafe; font-size:1rem; line-height:1.9;">
                            تجربة أكثر مرونة على الجوال مع وصول سريع للمنتج ومميزاته من أي مكان وفي أي وقت.
                        </p>

                        <p class="mt-3" style="color:#93a9c4; font-size:.95rem;">
                            متاح على App Store ويمكن إضافة Google Play لاحقًا
                        </p>

                        <div class="d-flex flex-column align-items-center gap-3 mt-4">
                            <a href="@appStoreUrl"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="btn px-4 py-3 rounded-4 fw-bold"
                               style="background:#000; color:#fff; min-width:190px; border:none;">
                                App Store
                            </a>

                            <a href="#"
                               class="btn px-4 py-3 rounded-4 fw-bold"
                               style="background: transparent; color:#fff; min-width:190px; border:1px solid rgba(255,255,255,.22);">
                                Google Play
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Overview -->
        <div class="mt-5 rounded-4 p-4 p-lg-5 shadow-sm"
             style="background: rgba(255,255,255,.97); border:1px solid #d7e3f4;">

            <div class="row g-4 align-items-start">
                <div class="col-lg-8">
                    <span class="d-inline-flex px-3 py-2 rounded-pill fw-bold small"
                          style="background:#eff6ff; color:#1d4ed8; letter-spacing:.12em;">
                        PRODUCT OVERVIEW
                    </span>

                    <h2 class="mt-4 fw-bold" style="color:#1e293b; font-size:2rem;">
                        نبذة عن المنتج
                    </h2>

                    <p class="mt-4 mb-0" style="color:#475569; font-size:1.02rem; line-height:2;">
                        @Model.Description
                    </p>
                </div>

                <div class="col-lg-4">
                    <div class="rounded-4 p-4" style="background:#f8fbff; border:1px solid #dbe6f5;">
                        <p class="mb-2" style="color:#64748b;">التصنيف</p>
                        <h3 class="mb-0 fw-bold" style="color:#1e293b; font-size:1.6rem;">
                            @(string.IsNullOrWhiteSpace(Model.Category) ? "منتج" : Model.Category)
                        </h3>
                    </div>
                </div>
            </div>

            @if (features.Any())
            {
                <div class="mt-5">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                        <h3 class="fw-bold mb-0" style="color:#1e293b; font-size:1.8rem;">
                            المميزات الرئيسية
                        </h3>

                        <span class="px-3 py-2 rounded-pill fw-bold small"
                              style="background:#dbeafe; color:#2563eb;">
                            @features.Count ميزة
                        </span>
                    </div>

                    <div class="row g-3">
                        @foreach (var feature in features)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="h-100 rounded-4 px-4 py-3"
                                     style="background:#fbfdff; border:1px solid #dbe6f5;">
                                    <div class="d-flex gap-3 align-items-start">
                                        <span class="d-flex align-items-center justify-content-center rounded-circle fw-bold"
                                              style="width:36px; height:36px; background: linear-gradient(90deg,#2563eb 0%,#0ea5e9 100%); color:#fff; flex:0 0 auto;">
                                            ✓
                                        </span>

                                        <p class="mb-0" style="color:#334155; line-height:1.9; font-weight:500;">
                                            @feature
                                        </p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

    </div>
</section>