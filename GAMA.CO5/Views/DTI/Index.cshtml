@model GAMA.CO5.Models.DTIViewModel

@{
    ViewData["Title"] = Model.PageTitle;
}

<section class="dti-hero">
    <div class="overlay"></div>
    <div class="container hero-content">
        <span class="hero-badge">رؤية المملكة 2030</span>
        <h1>مؤشر قياس التحول الرقمي</h1>
        <p>
            هو مؤشر يهدف لقياس التزام الجهات الحكومية الأساسية بالتحول الرقمي، ومساعدتها على تشخيص وضعها
            الراهن وبناء خطط تطوير ترسخ التحول الرقمي في جميع المجالات والخدمات والمعايير بما يسهم في تحقيق
            مستهدفات رؤية المملكة 2030.
        </p>

        <a asp-controller="Contact" asp-action="Index" class="dti-hero-btn">
            تواصل معنا الآن ←
        </a>
    </div>
</section>

<section class="dti-about-section">
    <div class="container">

        <div class="dti-intro text-center">
            <span class="section-badge">ما هو المؤشر؟</span>
            <h2>ما هو المؤشر؟</h2>
        </div>

        <div class="dti-about-grid">
            <div class="dti-about-image-wrap">
                <div class="dti-about-image-card">
                    <img src="/images/dti/dti-card.png" alt="مؤشر التحول الرقمي" />
                </div>
            </div>

            <div class="dti-about-content">
                <p>
                    مؤشر قياس التحول الرقمي هو أداة شاملة ومتطورة تم تصميمها خصيصًا لقياس ومتابعة التزام الجهات
                    الحكومية الأساسية بالتحول الرقمي. يعتمد المؤشر على منهجية علمية دقيقة تشمل مجموعة من المعايير
                    والمؤشرات الفرعية التي تغطي جميع جوانب التحول الرقمي.
                </p>
            </div>
        </div>

        <div class="dti-highlight-card">
            <div class="dti-highlight-icon">
                <span>🛡</span>
            </div>

            <div class="dti-highlight-text">
                <h3>يساهم في تحقيق رؤية المملكة 2030</h3>
                <p>
                    يعد المؤشر أحد الأدوات الرئيسية لتحقيق أهداف رؤية المملكة 2030 في مجال التحول الرقمي الحكومي.
                </p>
            </div>
        </div>

    </div>
</section>

<section class="dti-features-section">
    <div class="container">

        <div class="dti-section-head text-center">
            <span class="section-badge">المميزات الرئيسية</span>
            <h2>المميزات الرئيسية</h2>
            <p>نوفر لك مجموعة شاملة من المميزات التي تساعدك على قياس وتحسين التحول الرقمي</p>
        </div>

        <div class="dti-features-grid">
            <div class="dti-feature-box">
                <div class="dti-feature-icon purple">📊</div>
                <h3>تشخيص الوضع الحالي</h3>
                <p>تحديد نقاط القوة والضعف في رحلة التحول الرقمي</p>
            </div>

            <div class="dti-feature-box">
                <div class="dti-feature-icon blue">🎯</div>
                <h3>قياس دقيق</h3>
                <p>قياس شامل لمستوى التحول الرقمي في الجهات الحكومية</p>
            </div>

            <div class="dti-feature-box">
                <div class="dti-feature-icon orange">⏱</div>
                <h3>أفضل الممارسات</h3>
                <p>مبني على أفضل الممارسات والمعايير العالمية</p>
            </div>

            <div class="dti-feature-box">
                <div class="dti-feature-icon green">📈</div>
                <h3>متابعة التطور</h3>
                <p>رصد ومتابعة التقدم المحرز بشكل دوري ومستمر</p>
            </div>
        </div>

    </div>
</section>

<section class="dti-benefits-section">
    <div class="container">

        <div class="dti-benefits-grid">

            <div class="dti-benefits-content">
                <span class="section-badge green-badge">فوائد المؤشر</span>
                <h2>فوائد المؤشر</h2>

                <div class="dti-benefits-list">
                    <div class="dti-benefit-item">
                        <span class="dti-benefit-check">✓</span>
                        <span>تحسين جودة الخدمات الحكومية المقدمة للمواطنين والمقيمين</span>
                    </div>

                    <div class="dti-benefit-item">
                        <span class="dti-benefit-check">✓</span>
                        <span>رفع كفاءة العمليات الحكومية وتقليل التكاليف التشغيلية</span>
                    </div>

                    <div class="dti-benefit-item">
                        <span class="dti-benefit-check">✓</span>
                        <span>تعزيز الشفافية والمساءلة في القطاع الحكومي</span>
                    </div>

                    <div class="dti-benefit-item">
                        <span class="dti-benefit-check">✓</span>
                        <span>دعم اتخاذ القرارات الاستراتيجية المبنية على البيانات</span>
                    </div>

                    <div class="dti-benefit-item">
                        <span class="dti-benefit-check">✓</span>
                        <span>تسريع وتيرة التطور الرقمي في القطاع الحكومي</span>
                    </div>

                    <div class="dti-benefit-item">
                        <span class="dti-benefit-check">✓</span>
                        <span>المساهمة في تحقيق مستهدفات رؤية المملكة 2030</span>
                    </div>
                </div>
            </div>

            <div class="dti-benefits-image-wrap">
                <img src="/images/dti/dti-benefits.jpg" alt="فوائد المؤشر" />
            </div>

        </div>

    </div>
</section>