    <script src="/js/site.js"></script>
    <script>
        // DTI Calculator - Simple Frontend Calculation
        document.getElementById('dtiForm')?.addEventListener('submit', function(e) {
            e.preventDefault();

            const cloudUsage = parseInt(document.querySelector('input[name="CloudUsage"]:checked')?.value || '0');
            const digitalStrategy = parseInt(document.querySelector('input[name="DigitalStrategy"]:checked')?.value || '0');
            const cyberSecurity = parseInt(document.querySelector('input[name="CyberSecurity"]:checked')?.value || '0');

            const score = Math.round((cloudUsage + digitalStrategy + cyberSecurity) / 3);

            let level, recommendation;
            if (score < 30) {
                level = 'منخفض';
                recommendation = 'مستوى التحول الرقمي في مؤسستك منخفض. نوصي ببدء رحلة التحول الرقمي مع خدماتنا الاستشارية المتخصصة. سنساعدك في وضع استراتيجية واضحة وخطة تنفيذية للتحول الرقمي الناجح.';
            } else if (score < 60) {
                level = 'متوسط';
                recommendation = 'مستوى التحول الرقمي في مؤسستك متوسط. يمكننا مساعدتك في تسريع رحلة التحول الرقمي من خلال حلولنا المتكاملة في الحوسبة السحابية والأمن السيبراني والذكاء الاصطناعي.';
            } else {
                level = 'جيد';
                recommendation = 'مستوى التحول الرقمي في مؤسستك جيد! نوصي بالاستمرار في التطوير المستمر والاستفادة من أحدث التقنيات. يمكننا مساعدتك في الوصول إلى المستوى التالي من التميز الرقمي.';
            }

            document.getElementById('scoreValue').textContent = score + '%';
            document.getElementById('levelValue').textContent = level;
            document.getElementById('recommendationText').textContent = recommendation;
            document.getElementById('progressBar').style.width = score + '%';

            document.getElementById('dtiResult').style.display = 'block';
            document.getElementById('dtiResult').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });

        // Radio button selection styling
        document.querySelectorAll('input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function() {
                // Remove active class from all labels in this group
                const groupName = this.name;
                document.querySelectorAll(`input[name="${groupName}"]`).forEach(r => {
                    r.parentElement.style.borderColor = '#e5e7eb';
                    r.parentElement.style.background = 'white';
                });

                // Add active class to selected label
                this.parentElement.style.borderColor = '#2596be';
                this.parentElement.style.background = '#f0f9ff';
            });
        });
    </script>
</body>
