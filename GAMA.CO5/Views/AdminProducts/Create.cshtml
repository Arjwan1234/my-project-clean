@model GAMA.CO5.Models.Product

@{
    ViewData["Title"] = "إضافة منتج";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-product-form-page">

    <div class="product-form-hero">
        <div>
            <span class="hero-badge">GAMA Products</span>
            <h2>إضافة منتج</h2>
            <p>أدخلي بيانات المنتج كما ستظهر في صفحة المنتجات العامة.</p>
        </div>

        <a asp-action="Index" class="btn-back">
            <i class="fa-solid fa-arrow-right"></i>
            رجوع
        </a>
    </div>

    <div class="product-form-card">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-grid">
                <div class="field">
                    <label asp-for="Name">اسم المنتج</label>
                    <input asp-for="Name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="field">
                    <label asp-for="Category">التصنيف</label>
                    <input asp-for="Category" placeholder="مثال: حكومي / أعمال / صحة" />
                    <span asp-validation-for="Category" class="text-danger small"></span>
                </div>

                <div class="field">
                    <label asp-for="BadgeText">نص الشارة</label>
                    <input asp-for="BadgeText" placeholder="مثال: جديد / مميز / VESA" />
                    <span asp-validation-for="BadgeText" class="text-danger small"></span>
                </div>

                <div class="field">
                    <label asp-for="BadgeClass">لون الشارة</label>
                    <select asp-for="BadgeClass">
                        <option value="">افتراضي</option>
                        <option value="primary">Primary</option>
                        <option value="purple">Purple</option>
                        <option value="success">Success</option>
                        <option value="green">Green</option>
                        <option value="warning">Warning</option>
                        <option value="yellow">Yellow</option>
                        <option value="danger">Danger</option>
                        <option value="red">Red</option>
                        <option value="info">Info</option>
                        <option value="blue">Blue</option>
                        <option value="dark">Dark</option>
                    </select>
                    <span asp-validation-for="BadgeClass" class="text-danger small"></span>
                </div>
            </div>

            <div class="field mt-4">
                <label asp-for="Description">الوصف</label>
                <textarea asp-for="Description" rows="5" placeholder="اكتب وصفًا مختصرًا وواضحًا للمنتج"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="field mt-4">
                <label asp-for="Features">المميزات</label>
                <textarea asp-for="Features" rows="3" placeholder="ميزة 1، ميزة 2، ميزة 3"></textarea>
                <span asp-validation-for="Features" class="text-danger small"></span>
                <small class="hint">افصل بين كل ميزة بفاصلة.</small>
            </div>

            <div class="form-grid mt-4">
                <div class="field">
                    <label asp-for="ImageFile">صورة المنتج</label>
                    <input asp-for="ImageFile" type="file" />
                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                </div>

                <div class="featured-box">
                    <input asp-for="IsFeatured" />
                    <label asp-for="IsFeatured">منتج مميز</label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="fa-solid fa-floppy-disk"></i>
                    حفظ
                </button>

                <a asp-action="Index" class="btn-cancel">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .admin-product-form-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29, 78, 216, .16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        .product-form-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 12px;
            font-weight: 900;
            color: #dbeafe;
        }

        .product-form-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
        }

        .product-form-hero p {
            margin: 8px 0 0;
            color: #cbd5f5;
            font-weight: 600;
        }

        .btn-back {
            background: rgba(255,255,255,.12);
            color: white;
            border: 1px solid rgba(255,255,255,.18);
            padding: 12px 22px;
            border-radius: 18px;
            font-weight: 900;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: .25s;
            white-space: nowrap;
        }

            .btn-back:hover {
                color: white;
                background: rgba(255,255,255,.18);
                transform: translateY(-2px);
            }

        .product-form-card {
            border-radius: 30px;
            background: rgba(255,255,255,.95);
            border: 1px solid #dbe6f5;
            box-shadow: 0 24px 60px rgba(15,23,42,.10);
            padding: 32px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .field {
            text-align: right;
        }

            .field label {
                display: block;
                margin-bottom: 8px;
                font-weight: 900;
                color: #07142b;
            }

            .field input,
            .field textarea,
            .field select {
                width: 100%;
                border: 1px solid #d6e0ee;
                border-radius: 16px;
                padding: 13px 15px;
                outline: none;
                background: #f8fbff;
                color: #0f172a;
                font-weight: 700;
                transition: .2s;
            }

                .field input:focus,
                .field textarea:focus,
                .field select:focus {
                    border-color: #0f3d75;
                    box-shadow: 0 0 0 4px rgba(15,61,117,.10);
                    background: white;
                }

        .hint {
            display: block;
            margin-top: 7px;
            color: #64748b;
            font-weight: 700;
        }

        .featured-box {
            height: 100%;
            min-height: 78px;
            padding: 16px;
            border-radius: 18px;
            background: #f8fbff;
            border: 1px solid #dbe6f5;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            flex-direction: row-reverse;
            gap: 10px;
        }

            .featured-box input {
                width: 18px;
                height: 18px;
                accent-color: #0f3d75;
            }

            .featured-box label {
                margin: 0;
                font-weight: 900;
                color: #07142b;
            }

        .form-actions {
            margin-top: 28px;
            display: flex;
            gap: 12px;
            justify-content: flex-start;
        }

        .btn-save,
        .btn-cancel {
            border: none;
            border-radius: 18px;
            padding: 13px 22px;
            font-weight: 900;
            text-decoration: none;
            transition: .25s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-save {
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 14px 30px rgba(7,20,43,.22);
        }

            .btn-save:hover {
                transform: translateY(-2px);
                box-shadow: 0 18px 38px rgba(7,20,43,.30);
            }

        .btn-cancel {
            background: #eef2f7;
            color: #334155;
        }

            .btn-cancel:hover {
                color: #334155;
                background: #e2e8f0;
                transform: translateY(-2px);
            }

        @@media(max-width: 768px) {
            .product-form-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .btn-back,
            .btn-save,
            .btn-cancel {
                width: 100%;
                justify-content: center;
            }

            .form-actions {
                flex-direction: column;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}