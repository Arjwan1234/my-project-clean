@model GAMA.CO5.Models.Product

@{
    ViewData["Title"] = "حذف المنتج";
    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "/images/products/placeholder.jpg"
        : Model.ImageUrl;
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold text-danger mb-1">حذف المنتج</h2>
        <p class="text-muted mb-0">تأكد من بيانات المنتج قبل الحذف النهائي.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="row g-4 align-items-center">
                <div class="col-md-4 text-center">
                    <img src="@imageUrl"
                         alt="@Model.Name"
                         onerror="this.onerror=null;this.src='/images/products/placeholder.jpg';"
                         class="img-fluid rounded-4 border"
                         style="max-height:240px; object-fit:cover;" />
                </div>

                <div class="col-md-8">
                    <h4 class="fw-bold mb-3">@Model.Name</h4>

                    <div class="mb-2">
                        <strong>التصنيف:</strong>
                        <span class="text-muted">@(string.IsNullOrWhiteSpace(Model.Category) ? "غير محدد" : Model.Category)</span>
                    </div>

                    <div class="mb-2">
                        <strong>الشارة:</strong>
                        <span class="text-muted">@(string.IsNullOrWhiteSpace(Model.BadgeText) ? "—" : Model.BadgeText)</span>
                    </div>

                    <div class="mb-3">
                        <strong>الوصف:</strong>
                        <p class="text-muted mt-2 mb-0">
                            @Model.Description
                        </p>
                    </div>

                    <div class="alert alert-warning rounded-4 mb-0">
                        هل أنت متأكد من حذف هذا المنتج؟ لا يمكن التراجع بعد الحذف.
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger px-4">
                        تأكيد الحذف
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>