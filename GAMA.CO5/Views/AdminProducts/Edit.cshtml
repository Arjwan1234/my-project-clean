@model GAMA.CO5.Models.Product

@{
    ViewData["Title"] = "تعديل منتج";
    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "/images/products/placeholder.jpg"
        : Model.ImageUrl;
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">تعديل منتج</h2>
        <p class="text-muted mb-0">حدّث بيانات المنتج الظاهرة في الموقع.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input asp-for="Id" type="hidden" />
                <input asp-for="ImageUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-lg-4">
                        <label class="form-label fw-semibold">الصورة الحالية</label>
                        <div class="border rounded-4 p-3 bg-light text-center">
                            <img src="@imageUrl"
                                 alt="@Model.Name"
                                 onerror="this.onerror=null;this.src='/images/products/placeholder.jpg';"
                                 class="img-fluid rounded-4"
                                 style="max-height:260px; object-fit:cover;" />
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-semibold">اسم المنتج</label>
                                <input asp-for="Name" class="form-control form-control-lg" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Category" class="form-label fw-semibold">التصنيف</label>
                                <input asp-for="Category" class="form-control form-control-lg" />
                                <span asp-validation-for="Category" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="BadgeText" class="form-label fw-semibold">نص الشارة</label>
                                <input asp-for="BadgeText" class="form-control form-control-lg" />
                                <span asp-validation-for="BadgeText" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="BadgeClass" class="form-label fw-semibold">لون الشارة</label>
                                <select asp-for="BadgeClass" class="form-select form-select-lg">
                                    <option value="">افتراضي</option>
                                    <option value="primary">Primary</option>
                                    <option value="purple">Purple</option>
                                    <option value="success">Success</option>
                                    <option value="green">Green</option>
                                    <option value="warning">Warning</option>
                                    <option value="yellow">Yellow</option>
                                    <option value="danger">Danger</option>
                                    <option value="red">Red</option>
                                    <option value="info">Info</option>
                                    <option value="blue">Blue</option>
                                    <option value="dark">Dark</option>
                                </select>
                                <span asp-validation-for="BadgeClass" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold">الوصف</label>
                                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Features" class="form-label fw-semibold">المميزات</label>
                                <textarea asp-for="Features" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Features" class="text-danger small"></span>
                                <div class="form-text">افصل بين المميزات بفاصلة.</div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ImageFile" class="form-label fw-semibold">تغيير الصورة</label>
                                <input asp-for="ImageFile" type="file" class="form-control" />
                                <span asp-validation-for="ImageFile" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check form-switch fs-5">
                                    <input asp-for="IsFeatured" class="form-check-input" />
                                    <label asp-for="IsFeatured" class="form-check-label fw-semibold">
                                        منتج مميز
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        تحديث
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        رجوع
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}