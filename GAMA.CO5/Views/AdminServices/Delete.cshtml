@model GAMA.CO5.Models.Service

@{
    ViewData["Title"] = "حذف الخدمة";
}

<h2>حذف الخدمة</h2>

<h4>هل أنت متأكد من حذف هذه الخدمة؟</h4>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">العنوان</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">الوصف</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">الأيقونة</dt>
        <dd class="col-sm-10">@Model.Icon</dd>

        <dt class="col-sm-2">التصنيف</dt>
        <dd class="col-sm-10">@Model.BadgeText</dd>

        <dt class="col-sm-2">المميزات</dt>
        <dd class="col-sm-10">@Model.Features</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">تأكيد الحذف</button>
        <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
    </form>
</div>