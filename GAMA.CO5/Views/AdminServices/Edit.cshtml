@model GAMA.CO5.Models.Service

@{
    ViewData["Title"] = "تعديل الخدمة";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-service-form-page">

    <div class="service-form-hero">
        <div>
            <span class="hero-badge">GAMA Services</span>
            <h2>تعديل الخدمة</h2>
            <p>حدّثي بيانات الخدمة والصورة والفيديو والمميزات.</p>
        </div>

        <a asp-action="Index" class="btn-back">
            <i class="fa-solid fa-arrow-right"></i>
            رجوع
        </a>
    </div>

    <div class="service-form-card">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="ImageUrl" type="hidden" />
            <input asp-for="VideoUrl" type="hidden" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="preview-grid">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <div class="preview-box">
                        <label>الصورة الحالية</label>
                        <img src="@Model.ImageUrl" alt="@Model.Title" />
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
                {
                    <div class="preview-box">
                        <label>الفيديو الحالي</label>
                        <video src="@Model.VideoUrl" controls></video>
                    </div>
                }
            </div>

            <div class="form-grid">
                <div class="field">
                    <label asp-for="Title">عنوان الخدمة</label>
                    <input asp-for="Title" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="Icon">الأيقونة</label>
                    <input asp-for="Icon" placeholder="مثال: fa-solid fa-cloud" />
                    <span asp-validation-for="Icon" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="BadgeText">نص الشارة</label>
                    <input asp-for="BadgeText" />
                    <span asp-validation-for="BadgeText" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="BadgeColor">لون الشارة</label>
                    <input asp-for="BadgeColor" />
                    <span asp-validation-for="BadgeColor" class="text-danger"></span>
                </div>
            </div>

            <div class="field mt-4">
                <label asp-for="Description">الوصف</label>
                <textarea asp-for="Description" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="field mt-4">
                <label asp-for="Features">المميزات</label>
                <input asp-for="Features" placeholder="ميزة 1, ميزة 2, ميزة 3" />
                <span asp-validation-for="Features" class="text-danger"></span>
                <small class="hint">افصلي بين كل ميزة بفاصلة.</small>
            </div>

            <div class="form-grid mt-4">
                <div class="field">
                    <label asp-for="ImageFile">تغيير صورة الخدمة</label>
                    <input asp-for="ImageFile" type="file" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="VideoFile">تغيير فيديو الخدمة</label>
                    <input asp-for="VideoFile" type="file" accept="video/*" />
                    <span asp-validation-for="VideoFile" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="fa-solid fa-floppy-disk"></i>
                    حفظ التعديلات
                </button>

                <a asp-action="Index" class="btn-cancel">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .admin-service-form-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29,78,216,.16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        .service-form-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 12px;
            font-weight: 900;
            color: #dbeafe;
        }

        .service-form-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
        }

        .service-form-hero p {
            margin: 8px 0 0;
            color: #cbd5f5;
            font-weight: 600;
        }

        .btn-back {
            background: rgba(255,255,255,.12);
            color: white;
            border: 1px solid rgba(255,255,255,.18);
            padding: 12px 22px;
            border-radius: 18px;
            font-weight: 900;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: .25s;
            white-space: nowrap;
        }

            .btn-back:hover {
                color: white;
                background: rgba(255,255,255,.18);
                transform: translateY(-2px);
            }

        .service-form-card {
            border-radius: 30px;
            background: rgba(255,255,255,.95);
            border: 1px solid #dbe6f5;
            box-shadow: 0 24px 60px rgba(15,23,42,.10);
            padding: 32px;
        }

        .preview-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
            margin-bottom: 24px;
        }

        .preview-box {
            background: #f8fbff;
            border: 1px solid #dbe6f5;
            border-radius: 22px;
            padding: 16px;
            text-align: right;
        }

            .preview-box label {
                display: block;
                margin-bottom: 10px;
                font-weight: 900;
                color: #07142b;
            }

            .preview-box img,
            .preview-box video {
                width: 100%;
                max-height: 260px;
                object-fit: cover;
                border-radius: 18px;
                border: 1px solid #d6e0ee;
                background: white;
            }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .field {
            text-align: right;
        }

            .field label {
                display: block;
                margin-bottom: 8px;
                font-weight: 900;
                color: #07142b;
            }

            .field input,
            .field textarea {
                width: 100%;
                border: 1px solid #d6e0ee;
                border-radius: 16px;
                padding: 13px 15px;
                outline: none;
                background: #f8fbff;
                color: #0f172a;
                font-weight: 700;
                transition: .2s;
            }

                .field input:focus,
                .field textarea:focus {
                    border-color: #0f3d75;
                    box-shadow: 0 0 0 4px rgba(15,61,117,.10);
                    background: white;
                }

        .hint {
            display: block;
            margin-top: 7px;
            color: #64748b;
            font-weight: 700;
        }

        .form-actions {
            margin-top: 28px;
            display: flex;
            gap: 12px;
            justify-content: flex-start;
        }

        .btn-save,
        .btn-cancel {
            border: none;
            border-radius: 18px;
            padding: 13px 22px;
            font-weight: 900;
            text-decoration: none;
            transition: .25s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-save {
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 14px 30px rgba(7,20,43,.22);
        }

            .btn-save:hover {
                transform: translateY(-2px);
                box-shadow: 0 18px 38px rgba(7,20,43,.30);
            }

        .btn-cancel {
            background: #eef2f7;
            color: #334155;
        }

            .btn-cancel:hover {
                color: #334155;
                background: #e2e8f0;
                transform: translateY(-2px);
            }

        @@media(max-width: 768px) {
            .service-form-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .form-grid,
            .preview-grid {
                grid-template-columns: 1fr;
            }

            .btn-back,
            .btn-save,
            .btn-cancel {
                width: 100%;
                justify-content: center;
            }

            .form-actions {
                flex-direction: column;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}