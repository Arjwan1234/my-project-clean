@model List<GAMA.CO5.Models.Partner>

@{
    ViewData["Title"] = "إدارة الشركاء";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var partners = Model ?? new List<GAMA.CO5.Models.Partner>();
}

<div class="container-fluid py-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">إدارة الشركاء</h2>
        <a asp-action="Create" class="btn btn-info text-white rounded-pill px-4">
            إضافة شريك
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover align-middle text-center mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 120px;">الصورة</th>
                        <th>الاسم</th>
                        <th>الوصف</th>
                        <th>رابط الموقع</th>
                        <th style="width: 180px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (partners.Any())
                    {
                        @foreach (var item in partners)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.LogoUrl))
                                    {
                                        <img src="@item.LogoUrl"
                                             alt="@item.Name"
                                             style="width:70px;height:70px;object-fit:cover;border-radius:12px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">لا توجد صورة</span>
                                    }
                            </td>

                            <td class="fw-semibold">@item.Name</td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.Description)
                                                            ? "—"
                                                            : item.Description.Length > 80
                                                            ? item.Description.Substring(0, 80) + "..."
                                                            : item.Description)
                        </td>

                                <td>
                            @if (!string.IsNullOrWhiteSpace(item.WebsiteUrl))
                                    {
                                        <a href="@item.WebsiteUrl" target="_blank" class="text-decoration-none">
                                            فتح الرابط
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-white">
                                            تعديل
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            حذف
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-4 text-muted">لا يوجد شركاء حاليًا</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>