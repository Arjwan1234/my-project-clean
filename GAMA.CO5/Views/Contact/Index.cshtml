@model GAMA.CO5.Models.ContactMessage
@{
    ViewData["Title"] = "تواصل معنا";
}

<section class="contact-luxury-hero">
    <div class="contact-luxury-hero-overlay"></div>

    <div class="container contact-luxury-hero-content">
        <span class="contact-top-badge">
            <i class="fa-regular fa-envelope"></i>
            تواصل معنا
        </span>
        <h1>تواصل معنا</h1>
        <p>نسعد بخدمتكم والإجابة على استفساراتكم</p>
    </div>
</section>

<section class="contact-page">
    <div class="container contact-wrapper">

        @if (ViewBag.Success != null)
        {
            <div class="success-alert">
                تم إرسال رسالتك بنجاح، شكرًا لتواصلك معنا.
            </div>
        }

        <div class="contact-grid">

            <div class="contact-info-card">
                <div class="box-top-line"></div>

                <h2>معلومات التواصل</h2>
                <p class="box-subtitle">
                    يسعدنا استقبال جميع استفساراتكم ومقترحاتكم على مدار الساعة.
                </p>

                <div class="info-item navy-box">
                    <div class="info-icon">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <div class="info-content">
                        <span>الموقع</span>
                        <strong>جدة، المملكة العربية السعودية</strong>
                    </div>
                </div>

                <div class="info-item navy-box">
                    <div class="info-icon">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <div class="info-content">
                        <span>رقم الهاتف</span>
                        <strong dir="ltr">+966 XX XXX XXXX</strong>
                    </div>
                </div>

                <div class="info-item navy-box">
                    <div class="info-icon">
                        <i class="fa-regular fa-envelope"></i>
                    </div>
                    <div class="info-content">
                        <span>البريد الإلكتروني</span>
                        <strong>info@gama-ksa.com</strong>
                    </div>
                </div>

                <div class="map-box">
                    <div class="map-overlay"></div>
                    <div class="map-placeholder">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                </div>
            </div>

            <div class="contact-form-card">
                <div class="box-top-line"></div>

                <h2>أرسل لنا رسالة</h2>
                <p class="box-subtitle">
                    فريقنا جاهز لخدمتكم والرد على جميع الطلبات بسرعة واحترافية.
                </p>

                <form asp-action="Submit" asp-controller="Contact" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="form-group">
                        <label asp-for="Name">الاسم الكامل</label>
                        <input asp-for="Name" class="form-control" placeholder="أدخل اسمك الكامل" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Phone">رقم الهاتف</label>
                        <input asp-for="Phone" class="form-control" placeholder="+966 XX XXX XXXX" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject">الموضوع</label>
                        <input asp-for="Subject" class="form-control" placeholder="موضوع الرسالة" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Message">الرسالة</label>
                        <textarea asp-for="Message" class="form-control textarea" placeholder="اكتب رسالتك هنا..."></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-send">
                        <i class="fa-regular fa-paper-plane"></i>
                        إرسال الرسالة
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --primary: #0f3d75;
            --primary-soft: #1d4f91;
            --dark: #0f172a;
            --text: #64748b;
            --card: rgba(255,255,255,.97);
            --line: #e7edf5;
            --navy: #103b72;
        }

        .contact-luxury-hero {
            position: relative;
            min-height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(8,34,66,.55), rgba(13,52,97,.45)), url('/images/services-bg.jpg') center center / cover no-repeat;
        }

        .contact-luxury-hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 25%, rgba(56,189,248,.10), transparent 28%), radial-gradient(circle at 80% 68%, rgba(15,61,117,.08), transparent 30%);
        }

        .contact-luxury-hero-content {
            position: relative;
            z-index: 2;
            max-width: 980px;
            padding: 120px 20px 55px;
            color: #fff;
        }

        .contact-top-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 999px;
            background: rgba(255,255,255,.14);
            border: 1px solid rgba(255,255,255,.20);
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 22px;
        }

        .contact-luxury-hero-content h1 {
            font-size: 58px;
            font-weight: 900;
            margin-bottom: 14px;
        }

        .contact-luxury-hero-content p {
            font-size: 20px;
            line-height: 1.9;
            color: rgba(255,255,255,.94);
            margin: 0 auto;
            max-width: 780px;
        }

        .contact-page {
            position: relative;
            background: linear-gradient(180deg, #f8fbfd 0%, #f2f6fb 100%);
            padding: 90px 0 100px;
            overflow: hidden;
        }

            .contact-page::before,
            .contact-page::after {
                content: "";
                position: absolute;
                top: 0;
                width: 140px;
                height: 100%;
                pointer-events: none;
                opacity: .8;
            }

            .contact-page::before {
                left: 0;
                background: linear-gradient(180deg, transparent 0%, rgba(16,59,114,.06) 30%, transparent 60%);
            }

            .contact-page::after {
                right: 0;
                background: linear-gradient(180deg, transparent 0%, rgba(16,59,114,.06) 30%, transparent 60%);
            }

        .contact-wrapper {
            position: relative;
            z-index: 2;
            max-width: 1180px;
            margin: 0 auto;
        }

        .success-alert {
            max-width: 700px;
            margin: 0 auto 24px;
            background: #ecfdf3;
            border: 1px solid #b7ebc6;
            color: #166534;
            padding: 14px 18px;
            border-radius: 14px;
            text-align: center;
            font-weight: 700;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 35px;
        }

        .contact-info-card,
        .contact-form-card {
            background: var(--card);
            border-radius: 28px;
            padding: 32px;
            box-shadow: 0 20px 60px rgba(15,23,42,.06);
            border: 1px solid var(--line);
        }

        .box-top-line {
            height: 5px;
            margin: -32px -32px 28px;
            border-radius: 28px 28px 0 0;
            background: linear-gradient(90deg, var(--primary-soft), var(--primary));
        }

        .contact-info-card h2,
        .contact-form-card h2 {
            font-size: 28px;
            font-weight: 900;
            color: var(--dark);
            margin-bottom: 10px;
        }

        .box-subtitle {
            color: var(--text);
            margin-bottom: 24px;
            line-height: 1.8;
            font-size: 15px;
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #fff;
            border-radius: 18px;
            padding: 18px;
            margin-bottom: 16px;
            border: 1px solid #edf0f6;
        }

        .navy-box {
            border-right: 4px solid var(--navy);
        }

        .info-icon {
            width: 50px;
            height: 50px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            background: linear-gradient(135deg, #0f3d75, #133f77);
            font-size: 18px;
            flex-shrink: 0;
        }

        .info-content span {
            display: block;
            color: #94a3b8;
            font-size: 0.9rem;
            margin-bottom: 4px;
        }

        .info-content strong {
            color: #0f172a;
            font-size: 0.98rem;
            font-weight: 800;
        }

        .map-box {
            margin-top: 20px;
            height: 220px;
            border-radius: 22px;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg,#dce9f8,#eef4fb);
        }

        .map-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 20%, rgba(255,255,255,.28), transparent 40%);
        }

        .map-placeholder {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            color: var(--navy);
            position: relative;
            z-index: 1;
        }

        .form-group {
            margin-bottom: 15px;
        }

            .form-group label {
                display: block;
                font-size: 0.95rem;
                font-weight: 700;
                color: #334155;
                margin-bottom: 8px;
            }

        .form-control {
            width: 100%;
            height: 54px;
            border-radius: 16px;
            border: 1px solid #dbe3ef;
            padding: 12px 16px;
            font-size: 0.97rem;
            color: #0f172a;
            background: #fff;
            outline: none;
            transition: .2s ease;
        }

            .form-control::placeholder {
                color: #94a3b8;
            }

            .form-control:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 4px rgba(15,61,117,.10);
            }

        .textarea {
            min-height: 140px;
            height: 140px;
            resize: vertical;
            padding-top: 14px;
        }

        .btn-send {
            width: 100%;
            height: 56px;
            border: none;
            border-radius: 16px;
            background: linear-gradient(90deg, #0f3d75, #1d4f91);
            color: white;
            font-weight: 800;
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            cursor: pointer;
            transition: .25s ease;
        }

            .btn-send:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 26px rgba(16,59,114,.18);
            }

        .text-danger,
        .validation-summary {
            color: #dc2626;
            font-size: 0.88rem;
            margin-top: 6px;
        }

        .validation-summary {
            margin-bottom: 12px;
        }

            .validation-summary ul {
                margin: 0;
                padding-right: 18px;
            }

        @@media(max-width:992px) {
            .contact-grid {
                grid-template-columns: 1fr;
            }

            .contact-luxury-hero-content h1 {
                font-size: 42px;
            }

            .contact-luxury-hero-content p {
                font-size: 18px;
            }
        }
        @@media(max-width:768px) {
            .contact-page::before,
            .contact-page::after {
                width: 70px;
                opacity: .5;
            }

            .contact-luxury-hero {
                min-height: 330px;
            }

            .contact-luxury-hero-content {
                padding: 100px 20px 40px;
            }

                .contact-luxury-hero-content h1 {
                    font-size: 32px;
                }

                .contact-luxury-hero-content p {
                    font-size: 15px;
                }

            .contact-info-card,
            .contact-form-card {
                padding: 24px 20px;
            }

            .box-top-line {
                margin: -24px -20px 24px;
            }
        }
    </style>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}