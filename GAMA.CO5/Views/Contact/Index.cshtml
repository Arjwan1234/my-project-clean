@model GAMA.CO5.Models.ContactMessage

@{
    ViewData["Title"] = "تواصل معنا";
}

<section class="contact-luxury-hero">
    <div class="contact-luxury-hero-overlay"></div>

    <div class="container contact-luxury-hero-content">
        <span class="contact-top-badge">
            <i class="fa-regular fa-envelope"></i>
            تواصل معنا
        </span>
        <h1>تواصل معنا</h1>
        <p>نسعد بخدمتكم والإجابة على استفساراتكم</p>
    </div>
</section>

<section class="contact-page">
    <div class="container contact-wrapper">

        @if (ViewBag.Success != null)
        {
            <div class="success-alert">
                تم إرسال رسالتك بنجاح، شكرًا لتواصلك معنا.
            </div>
        }

        <div class="contact-grid">

            <!-- معلومات التواصل -->
            <div class="contact-info-card">
                <div class="box-top-line"></div>

                <h2>معلومات التواصل</h2>
                <p class="box-subtitle">
                    يسعدنا استقبال جميع استفساراتكم ومقترحاتكم على مدار الساعة.
                </p>

                <div class="info-item navy-box">
                    <div class="info-icon">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <div class="info-content">
                        <span>الموقع</span>
                        <strong>جدة - حي النهضة - شارع عبدالرحمن الداخل</strong>
                    </div>
                </div>

                <div class="info-item navy-box">
                    <div class="info-icon">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <div class="info-content">
                        <span>رقم الهاتف</span>
                        <strong dir="ltr">+966 XX XXX XXXX</strong>
                    </div>
                </div>

                <div class="info-item navy-box">
                    <div class="info-icon">
                        <i class="fa-regular fa-envelope"></i>
                    </div>
                    <div class="info-content">
                        <span>البريد الإلكتروني</span>
                        <strong>info@gama-ksa.com</strong>
                    </div>
                </div>

                <!-- الخريطة -->
                <div class="map-box real-map-box">
                    <iframe src="https://www.google.com/maps?q=21.6186859,39.1320377&z=16&output=embed"
                            allowfullscreen=""
                            loading="lazy">
                    </iframe>
                </div>

                <a href="https://www.google.com/maps/dir//GAMA,+Abdurahman+Al+Dakhel,+النهضة،+جدة+23615"
                   target="_blank"
                   class="map-link-btn">
                    <i class="fa-solid fa-location-dot"></i>
                    فتح الموقع في خرائط Google
                </a>
            </div>

            <!-- الفورم -->
            <div class="contact-form-card">
                <div class="box-top-line"></div>

                <h2>أرسل لنا رسالة</h2>
                <p class="box-subtitle">
                    فريقنا جاهز لخدمتكم والرد على جميع الطلبات بسرعة واحترافية.
                </p>

                <form asp-action="Submit" asp-controller="Contact" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="form-group">
                        <label asp-for="Name">الاسم الكامل</label>
                        <input asp-for="Name" class="form-control" placeholder="أدخل اسمك الكامل" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Phone">رقم الهاتف</label>
                        <input asp-for="Phone" class="form-control" placeholder="+966 XX XXX XXXX" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject">الموضوع</label>
                        <input asp-for="Subject" class="form-control" placeholder="موضوع الرسالة" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Message">الرسالة</label>
                        <textarea asp-for="Message" class="form-control textarea" placeholder="اكتب رسالتك هنا..."></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-send">
                        <i class="fa-regular fa-paper-plane"></i>
                        إرسال الرسالة
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --primary: #0f3d75;
            --primary-soft: #1d4f91;
            --dark: #0f172a;
            --text: #64748b;
            --card: rgba(255,255,255,.97);
            --line: #e7edf5;
            --navy: #103b72;
        }

        .contact-luxury-hero {
            position: relative;
            min-height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(8,34,66,.58), rgba(13,52,97,.48)), url('/images/services-bg.jpg') center center / cover no-repeat;
        }

        .contact-luxury-hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 25%, rgba(56,189,248,.10), transparent 28%), radial-gradient(circle at 80% 68%, rgba(15,61,117,.08), transparent 30%);
        }

        .contact-luxury-hero-content {
            position: relative;
            z-index: 2;
            color: white;
        }

            .contact-luxury-hero-content h1 {
                font-size: 56px;
                font-weight: 900;
            }

        .contact-page {
            background: #f5f8fc;
            padding: 80px 0;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .contact-info-card,
        .contact-form-card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.05);
        }

        .box-top-line {
            height: 4px;
            margin: -30px -30px 20px;
            background: linear-gradient(90deg,#0f3d75,#1d4f91);
        }

        .info-item {
            display: flex;
            gap: 12px;
            margin-bottom: 15px;
        }

        .info-icon {
            width: 45px;
            height: 45px;
            background: #0f3d75;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
        }

        .map-box {
            margin-top: 20px;
            height: 230px;
            border-radius: 20px;
            overflow: hidden;
        }

        .real-map-box iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }

        .map-link-btn {
            margin-top: 12px;
            display: block;
            text-align: center;
            padding: 12px;
            background: #0f3d75;
            color: white;
            border-radius: 12px;
            text-decoration: none;
        }

        .form-control {
            width: 100%;
            height: 50px;
            border-radius: 12px;
            border: 1px solid #ddd;
            padding: 10px;
        }

        .textarea {
            height: 120px;
        }

        .btn-send {
            width: 100%;
            height: 50px;
            background: #0f3d75;
            color: white;
            border: none;
            border-radius: 12px;
        }

        @@media(max-width:900px) {
            .contact-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}