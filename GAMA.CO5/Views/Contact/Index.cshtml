@model GAMA.CO5.Models.ContactMessage
@{
    ViewData["Title"] = "تواصل معنا";
}

<section class="contact-luxury-hero">
    <div class="contact-luxury-hero-overlay"></div>

    <div class="container contact-luxury-hero-content">
        <span class="contact-top-badge">
            <i class="fa-regular fa-envelope"></i>
            تواصل معنا
        </span>
        <h1>تواصل معنا</h1>
        <p>نسعد بخدمتكم والإجابة على استفساراتكم</p>
    </div>
</section>

<section class="contact-page">
    <div class="container contact-wrapper">

        @if (ViewBag.Success != null)
        {
            <div class="success-alert">
                تم إرسال رسالتك بنجاح، شكرًا لتواصلك معنا.
            </div>
        }

        <div class="contact-grid">

            <div class="contact-info-card">
                <h2>معلومات التواصل</h2>

                <div class="info-item">
                    <div class="info-icon blue">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <div class="info-content">
                        <span>الموقع</span>
                        <strong>جدة، المملكة العربية السعودية</strong>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon green">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <div class="info-content">
                        <span>رقم الهاتف</span>
                        <strong dir="ltr">+966 XX XXX XXXX</strong>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon purple">
                        <i class="fa-regular fa-envelope"></i>
                    </div>
                    <div class="info-content">
                        <span>البريد الإلكتروني</span>
                        <strong>info@gama-ksa.com</strong>
                    </div>
                </div>

                <div class="map-box">
                    <div class="map-placeholder">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                </div>
            </div>

            <div class="contact-form-card">
                <h2>أرسل لنا رسالة</h2>

                <form asp-action="Submit" asp-controller="Contact" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="form-group">
                        <label asp-for="Name">الاسم الكامل</label>
                        <input asp-for="Name" class="form-control" placeholder="أدخل اسمك الكامل" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Phone">رقم الهاتف</label>
                        <input asp-for="Phone" class="form-control" placeholder="+966 XX XXX XXXX" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject">الموضوع</label>
                        <input asp-for="Subject" class="form-control" placeholder="موضوع الرسالة" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Message">الرسالة</label>
                        <textarea asp-for="Message" class="form-control textarea" placeholder="اكتب رسالتك هنا..."></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-send">
                        <i class="fa-regular fa-paper-plane"></i>
                        إرسال الرسالة
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --luxury-primary: #0f3d75;
            --luxury-secondary: #7c3aed;
            --luxury-accent: #38bdf8;
            --luxury-dark: #0f172a;
            --luxury-text: #64748b;
        }

        .contact-luxury-hero {
            position: relative;
            min-height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(6,22,45,.82), rgba(9,33,62,.74)), url('/images/services-bg.jpg') center center / cover no-repeat;
        }

        .contact-luxury-hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 25%, rgba(56,189,248,.14), transparent 28%), radial-gradient(circle at 80% 68%, rgba(124,58,237,.18), transparent 32%), linear-gradient(180deg, rgba(4,18,35,.22), rgba(4,18,35,.74));
        }

        .contact-luxury-hero-content {
            position: relative;
            z-index: 2;
            max-width: 980px;
            padding: 120px 20px 50px;
            color: #fff;
        }

        .contact-top-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
            padding: 10px 20px;
            border-radius: 999px;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.18);
            backdrop-filter: blur(14px);
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 22px;
        }

        .contact-luxury-hero-content h1 {
            margin: 0 0 16px;
            font-size: 58px;
            font-weight: 900;
            line-height: 1.15;
            letter-spacing: -1px;
            color: #fff;
            text-shadow: 0 10px 30px rgba(0,0,0,.18);
        }

        .contact-luxury-hero-content p {
            margin: 0 auto;
            max-width: 780px;
            font-size: 20px;
            line-height: 1.95;
            color: rgba(255,255,255,0.88);
        }

        .contact-page {
            position: relative;
            background: linear-gradient(180deg, #f8fbfd 0%, #f2f6fb 100%);
            padding: 90px 0 110px;
            overflow: hidden;
        }

            /* الزخارف الجانبية الفاخرة */
            .contact-page::before,
            .contact-page::after {
                content: "";
                position: absolute;
                top: 0;
                width: 170px;
                height: 100%;
                z-index: 0;
                pointer-events: none;
                opacity: 1;
            }

            .contact-page::before {
                left: 0;
                background: url("data:image/svg+xml;utf8,\
        <svg xmlns='http://www.w3.org/2000/svg' width='170' height='900' viewBox='0 0 170 900'>\
        <g fill='none' stroke='%2338bdf8' stroke-width='1.5' opacity='0.55'>\
        <path d='M0 20 L70 20 L30 60 L100 100'/>\
        <path d='M0 160 L90 160 L40 210 L120 260' opacity='0.45'/>\
        <path d='M0 320 L80 320 L25 380 L110 440' opacity='0.40'/>\
        <path d='M0 520 L95 520 L45 575 L125 630' opacity='0.35'/>\
        <path d='M0 720 L75 720 L20 780 L105 845' opacity='0.30'/>\
        </g>\
        <g fill='none' stroke='%23c084fc' stroke-width='1.3' opacity='0.45'>\
        <path d='M0 95 L60 95 L18 140 L92 188'/>\
        <path d='M0 245 L72 245 L22 300 L102 355' opacity='0.38'/>\
        <path d='M0 455 L68 455 L18 510 L98 565' opacity='0.32'/>\
        <path d='M0 660 L76 660 L28 720 L112 780' opacity='0.28'/>\
        </g>\
        <circle cx='30' cy='120' r='14' fill='%2338bdf8' opacity='0.25'/>\
        <circle cx='42' cy='290' r='8' fill='%23c084fc' opacity='0.28'/>\
        <circle cx='36' cy='520' r='18' fill='%2338bdf8' opacity='0.18'/>\
        <circle cx='48' cy='700' r='10' fill='%23c084fc' opacity='0.22'/>\
        </svg>") left top / 170px 100% no-repeat;
            }

            .contact-page::after {
                right: 0;
                background: url("data:image/svg+xml;utf8,\
        <svg xmlns='http://www.w3.org/2000/svg' width='170' height='900' viewBox='0 0 170 900'>\
        <g fill='none' stroke='%23a78bfa' stroke-width='1.5' opacity='0.55'>\
        <path d='M170 30 L100 30 L140 70 L70 110'/>\
        <path d='M170 170 L80 170 L130 220 L50 270' opacity='0.45'/>\
        <path d='M170 360 L90 360 L145 420 L60 480' opacity='0.40'/>\
        <path d='M170 560 L75 560 L125 615 L45 670' opacity='0.35'/>\
        <path d='M170 760 L95 760 L150 820 L65 880' opacity='0.30'/>\
        </g>\
        <g fill='none' stroke='%2360a5fa' stroke-width='1.3' opacity='0.45'>\
        <path d='M170 110 L110 110 L152 155 L78 203'/>\
        <path d='M170 300 L98 300 L148 355 L68 410' opacity='0.38'/>\
        <path d='M170 500 L102 500 L152 555 L72 610' opacity='0.32'/>\
        <path d='M170 700 L94 700 L142 760 L58 820' opacity='0.28'/>\
        </g>\
        <circle cx='138' cy='130' r='14' fill='%23a78bfa' opacity='0.28'/>\
        <circle cx='126' cy='320' r='8' fill='%2360a5fa' opacity='0.30'/>\
        <circle cx='140' cy='560' r='20' fill='%23a78bfa' opacity='0.20'/>\
        <circle cx='128' cy='760' r='10' fill='%2360a5fa' opacity='0.24'/>\
        </svg>") right top / 170px 100% no-repeat;
            }

        .contact-wrapper {
            position: relative;
            z-index: 2;
            max-width: 1180px;
            margin: 0 auto;
        }

            /* خطوط جانبية ناعمة */
            .contact-wrapper::before,
            .contact-wrapper::after {
                content: "";
                position: absolute;
                top: 50%;
                width: 120px;
                height: 2px;
                transform: translateY(-50%);
                pointer-events: none;
                z-index: 1;
                background: linear-gradient(90deg, transparent, rgba(124,58,237,.28), transparent);
            }

            .contact-wrapper::before {
                left: -10px;
            }

            .contact-wrapper::after {
                right: -10px;
            }

        .success-alert {
            max-width: 700px;
            margin: 0 auto 24px;
            background: #ecfdf3;
            border: 1px solid #b7ebc6;
            color: #166534;
            padding: 14px 18px;
            border-radius: 14px;
            text-align: center;
            font-weight: 700;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 34px;
            align-items: start;
        }

        .contact-form-card,
        .contact-info-card {
            background: rgba(255,255,255,.95);
            border: 1px solid rgba(226,232,240,.95);
            border-radius: 28px;
            box-shadow: 0 20px 60px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.95);
            padding: 32px;
            backdrop-filter: blur(10px);
        }

            .contact-form-card h2,
            .contact-info-card h2 {
                font-size: 28px;
                font-weight: 900;
                color: var(--luxury-dark);
                margin-bottom: 24px;
            }

        .form-group {
            margin-bottom: 15px;
        }

            .form-group label {
                display: block;
                font-size: 0.95rem;
                font-weight: 700;
                color: #334155;
                margin-bottom: 8px;
            }

        .form-control {
            width: 100%;
            height: 54px;
            border-radius: 16px;
            border: 1px solid #dbe3ef;
            background: #fff;
            padding: 12px 16px;
            transition: .2s ease;
            font-size: 0.97rem;
            color: #0f172a;
            outline: none;
        }

            .form-control::placeholder {
                color: #94a3b8;
            }

            .form-control:focus {
                border-color: #7c3aed;
                box-shadow: 0 0 0 4px rgba(124,58,237,.10);
            }

        .textarea {
            min-height: 140px;
            height: 140px;
            resize: vertical;
            padding-top: 14px;
        }

        .btn-send {
            width: 100%;
            height: 56px;
            border: none;
            border-radius: 16px;
            background: linear-gradient(90deg, #6d28d9, #7c3aed);
            color: #fff;
            font-size: 16px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            cursor: pointer;
            transition: .25s ease;
            margin-top: 8px;
        }

            .btn-send:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 26px rgba(124,58,237,.18);
            }

        .info-item {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #fff;
            border: 1px solid #edf0f6;
            border-radius: 18px;
            padding: 18px;
            margin-bottom: 16px;
            box-shadow: 0 8px 20px rgba(15,23,42,.03);
        }

        .info-icon {
            width: 48px;
            height: 48px;
            min-width: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1rem;
        }

        .blue {
            background: #2563eb;
        }

        .green {
            background: #16a34a;
        }

        .purple {
            background: #9333ea;
        }

        .info-content span {
            display: block;
            color: #94a3b8;
            font-size: 0.9rem;
            margin-bottom: 4px;
        }

        .info-content strong {
            color: #0f172a;
            font-size: 0.98rem;
            font-weight: 800;
        }

        .map-box {
            margin-top: 10px;
            height: 240px;
            border-radius: 22px;
            background: linear-gradient(135deg, #dde5f0, #edf2f7);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .map-placeholder {
            font-size: 3rem;
            color: #64748b;
        }

        .text-danger,
        .validation-summary {
            color: #dc2626;
            font-size: 0.88rem;
            margin-top: 6px;
        }

        .validation-summary {
            margin-bottom: 12px;
        }

            .validation-summary ul {
                margin: 0;
                padding-right: 18px;
            }

        @@media (max-width: 992px) {
            .contact-grid {
                grid-template-columns: 1fr;
            }

            .contact-luxury-hero-content h1 {
                font-size: 44px;
            }

            .contact-luxury-hero-content p {
                font-size: 18px;
            }
        }

        @@media (max-width: 768px) {
            .contact-luxury-hero {
                min-height: 330px;
            }

            .contact-luxury-hero-content {
                padding: 100px 20px 40px;
            }

                .contact-luxury-hero-content h1 {
                    font-size: 32px;
                }

                .contact-luxury-hero-content p {
                    font-size: 15px;
                }

            .contact-page::before,
            .contact-page::after {
                width: 90px;
                opacity: .65;
                background-size: 90px 100%;
            }

            .contact-wrapper::before,
            .contact-wrapper::after {
                display: none;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}