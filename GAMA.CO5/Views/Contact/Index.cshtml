@model GAMA.CO5.Models.ContactMessage

@{
    ViewData["Title"] = "تواصل معنا";
}

<section class="contact-luxury-hero">
    <div class="contact-luxury-hero-overlay"></div>

    <div class="container contact-luxury-hero-content">
        <h1>تواصل معنا</h1>
        <p>نسعد بخدمتكم والإجابة على استفساراتكم</p>
    </div>
</section>

<section class="contact-page">
    <div class="contact-wrapper">

        @if (ViewBag.Success != null)
        {
            <div class="success-alert">
                تم إرسال رسالتك بنجاح، شكرًا لتواصلك معنا.
            </div>
        }

        <div class="contact-grid">

            <!-- معلومات التواصل -->
            <div class="contact-info-card">
                <h2>معلومات التواصل</h2>
                <p class="box-subtitle">
                    يسعدنا استقبال جميع استفساراتكم ومقترحاتكم على مدار الساعة.
                </p>

                <div class="info-item">
                    <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
                    <div>
                        <span>الموقع</span>
                        <strong>جدة - حي النهضة - شارع عبدالرحمن الداخل</strong>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
                    <div>
                        <span>رقم الهاتف</span>
                        <strong dir="ltr">+966 XX XXX XXXX</strong>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon"><i class="fa-regular fa-envelope"></i></div>
                    <div>
                        <span>البريد الإلكتروني</span>
                        <strong>info@gama-ksa.com</strong>
                    </div>
                </div>

                <div class="map-box">
                    <iframe src="https://www.google.com/maps?q=21.6186859,39.1320377&z=16&output=embed"
                            allowfullscreen=""
                            loading="lazy">
                    </iframe>
                </div>

                <a href="https://www.google.com/maps/dir//GAMA,+Abdurahman+Al+Dakhel,+النهضة،+جدة+23615"
                   target="_blank"
                   class="map-link-btn">
                    <i class="fa-solid fa-location-dot"></i>
                    فتح الموقع في خرائط Google
                </a>
            </div>

            <!-- الفورم -->
            <div class="contact-form-card">
                <h2>أرسل لنا رسالة</h2>
                <p class="box-subtitle">
                    فريقنا جاهز لخدمتكم والرد على جميع الطلبات بسرعة واحترافية.
                </p>

                <form asp-action="Submit" asp-controller="Contact" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"></div>

                    <div class="form-group">
                        <label asp-for="Name">الاسم الكامل</label>
                        <input asp-for="Name" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Phone">رقم الهاتف</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject">الموضوع</label>
                        <input asp-for="Subject" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Message">الرسالة</label>
                        <textarea asp-for="Message" class="form-control textarea"></textarea>
                    </div>

                    <button type="submit" class="btn-send">
                        إرسال الرسالة
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

@section Styles {
    <style>

        .contact-luxury-hero {
            position: relative;
            min-height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            /* 🔥 فقط التغميق */
            background: linear-gradient(135deg, rgba(8,34,66,.75), rgba(13,52,97,.65)), url('/images/services-bg.jpg') center center / cover no-repeat;
        }

        .contact-luxury-hero-content {
            color: white;
        }

            /* 🔥 رجعنا حجم الخط مثل أول */
            .contact-luxury-hero-content h1 {
                font-size: 56px;
                font-weight: 900;
            }

        .contact-page {
            background: #eef4ff;
            padding: 80px 24px;
        }

        .contact-wrapper {
            max-width: 1180px;
            margin: auto;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px;
        }

        .contact-info-card,
        .contact-form-card {
            background: #fff;
            border-radius: 28px;
            padding: 34px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.10);
            border-top: 5px solid #0f3d75;
        }

        .info-item {
            display: flex;
            flex-direction: row-reverse;
            gap: 12px;
            margin-bottom: 14px;
        }

        .info-icon {
            width: 45px;
            height: 45px;
            background: #0f3d75;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
        }

        .map-box {
            margin-top: 20px;
            height: 240px;
            border-radius: 16px;
            overflow: hidden;
        }

            .map-box iframe {
                width: 100%;
                height: 100%;
            }

        .map-link-btn {
            display: block;
            margin-top: 10px;
            padding: 12px;
            background: #0f3d75;
            color: white;
            text-align: center;
            border-radius: 12px;
        }

        .form-control {
            width: 100%;
            height: 50px;
            border-radius: 12px;
            border: 1px solid #ddd;
            padding: 10px;
        }

        .textarea {
            height: 120px;
        }

        .btn-send {
            width: 100%;
            height: 50px;
            background: #0f3d75;
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: bold;
        }

        @@media(max-width:900px) {
            .contact-grid {
                grid-template-columns: 1fr;
            }
        }

    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}