@model IEnumerable<GAMA.CO5.Models.ContactMessage>

@{
    ViewData["Title"] = "رسائل التواصل";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-messages-page">

    <div class="messages-hero">
        <div>
            <span class="hero-badge">GAMA Contact</span>
            <h2>رسائل التواصل</h2>
            <p>استعراض رسائل العملاء والاستفسارات الواردة من صفحة التواصل.</p>
        </div>
    </div>

    <div class="messages-card">
        <table class="messages-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>الاسم</th>
                    <th>الإيميل</th>
                    <th>الرسالة</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="message-id">@item.Id</td>
                        <td class="sender-name">@item.Name</td>
                        <td>
                            <a href="mailto:@item.Email" class="email-link">@item.Email</a>
                        </td>
                        <td>
                            <div class="message-preview">
                                @item.Message
                            </div>

                            <div id="msg-@item.Id" class="message-full-hidden">
                                @item.Message
                            </div>

                            <button type="button" class="btn-view" onclick="openMessage('@item.Id')">
                                عرض
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="messageModal" class="message-modal">
    <div class="message-modal-content">
        <button type="button" class="close-btn" onclick="closeMessage()">×</button>
        <h3>نص الرسالة</h3>
        <div id="fullMessage" class="full-message"></div>
    </div>
</div>

@section Styles {
    <style>
        .admin-messages-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29,78,216,.16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        .messages-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 12px;
            font-weight: 900;
            color: #dbeafe;
        }

        .messages-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
        }

        .messages-hero p {
            margin: 8px 0 0;
            color: #cbd5f5;
            font-weight: 600;
        }

        .messages-card {
            border-radius: 28px;
            overflow-x: auto;
            background: rgba(255,255,255,.95);
            border: 1px solid #dbe6f5;
            box-shadow: 0 24px 60px rgba(15,23,42,.10);
        }

        .messages-table {
            width: 100%;
            min-width: 850px;
            border-collapse: collapse;
            text-align: right;
        }

            .messages-table thead {
                background: linear-gradient(135deg, #07142b, #0f3d75);
                color: white;
            }

            .messages-table th,
            .messages-table td {
                padding: 18px;
                border-bottom: 1px solid #e5edf7;
                vertical-align: top;
            }

            .messages-table th {
                font-size: 14px;
                font-weight: 900;
            }

            .messages-table td {
                color: #334155;
                font-weight: 700;
            }

        .message-preview {
            max-width: 420px;
            max-height: 52px;
            overflow: hidden;
            white-space: normal;
            word-break: break-word;
            line-height: 1.7;
            color: #475569;
        }

        .message-full-hidden {
            display: none;
        }

        .btn-view {
            margin-top: 8px;
            padding: 7px 14px;
            border-radius: 10px;
            border: none;
            background: #e0f2fe;
            color: #0369a1;
            font-weight: 900;
            cursor: pointer;
        }

        .message-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: rgba(15, 23, 42, .55);
            padding: 20px;
        }

        .message-modal-content {
            position: relative;
            width: min(720px, 100%);
            max-height: 80vh;
            overflow-y: auto;
            margin: 8vh auto;
            background: white;
            border-radius: 24px;
            padding: 28px;
            text-align: right;
            box-shadow: 0 30px 80px rgba(0,0,0,.25);
        }

            .message-modal-content h3 {
                margin: 0 0 18px;
                color: #07142b;
                font-weight: 900;
            }

        .full-message {
            white-space: pre-wrap;
            word-break: break-word;
            overflow-wrap: anywhere;
            line-height: 1.9;
            color: #334155;
            font-weight: 700;
        }

        .close-btn {
            position: absolute;
            left: 18px;
            top: 14px;
            border: none;
            background: #f1f5f9;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            font-size: 22px;
            cursor: pointer;
        }

        @@media(max-width: 768px) {
            .admin-messages-page {
                padding: 14px;
            }

            .messages-hero {
                padding: 22px;
                border-radius: 22px;
            }

                .messages-hero h2 {
                    font-size: 24px;
                }

            .messages-table {
                min-width: 760px;
            }

            .message-modal-content {
                margin: 10vh auto;
                padding: 22px;
                border-radius: 20px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        function openMessage(id) {
            const source = document.getElementById("msg-" + id);
            const target = document.getElementById("fullMessage");

            target.innerText = source ? source.innerText.trim() : "";
            document.getElementById("messageModal").style.display = "block";
        }

        function closeMessage() {
            document.getElementById("messageModal").style.display = "none";
        }

        document.getElementById("messageModal").addEventListener("click", function (event) {
            if (event.target === this) {
                closeMessage();
            }
        });
    </script>
}