@model IEnumerable<GAMA.CO5.Models.ContactMessage>

@{
    ViewData["Title"] = "رسائل التواصل";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-messages-page">

    <div class="messages-hero">
        <div>
            <span class="hero-badge">GAMA Contact</span>
            <h2>رسائل التواصل</h2>
            <p>استعراض رسائل العملاء والاستفسارات الواردة من صفحة التواصل.</p>
        </div>
    </div>

    <div class="messages-card">
        <table class="messages-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>الاسم</th>
                    <th>الإيميل</th>
                    <th>الرسالة</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="message-id">@item.Id</td>
                        <td class="sender-name">@item.Name</td>
                        <td>
                            <a href="mailto:@item.Email" class="email-link">
                                @item.Email
                            </a>
                        </td>
                        <td class="message-text">@item.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .admin-messages-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29,78,216,.16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        .messages-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 12px;
            font-weight: 900;
            color: #dbeafe;
        }

        .messages-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
        }

        .messages-hero p {
            margin: 8px 0 0;
            color: #cbd5f5;
            font-weight: 600;
        }

        .messages-card {
            border-radius: 28px;
            overflow-x: auto;
            background: rgba(255,255,255,.95);
            border: 1px solid #dbe6f5;
            box-shadow: 0 24px 60px rgba(15,23,42,.10);
        }

        .messages-table {
            width: 100%;
            min-width: 850px;
            border-collapse: collapse;
            text-align: right;
        }

            .messages-table thead {
                background: linear-gradient(135deg, #07142b, #0f3d75);
                color: white;
            }

            .messages-table th {
                padding: 18px;
                font-size: 14px;
                font-weight: 900;
            }

            .messages-table td {
                padding: 18px;
                border-bottom: 1px solid #e5edf7;
                color: #334155;
                font-weight: 700;
                vertical-align: top;
            }

            .messages-table tbody tr:hover {
                background: #f1f6ff;
            }

        .message-id {
            color: #64748b;
            font-weight: 900;
        }

        .sender-name {
            color: #07142b !important;
            font-weight: 900 !important;
            white-space: nowrap;
        }

        .email-link {
            color: #0f3d75;
            font-weight: 900;
            text-decoration: none;
        }

        .message-text {
            max-width: 520px;
            line-height: 1.8;
            color: #475569 !important;
        }
    </style>
}