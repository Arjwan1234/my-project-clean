@model List<GAMA.CO5.Models.HomeNews>

@{
    ViewData["Title"] = "إدارة الصفحة الرئيسية";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var hero = ViewBag.Hero as GAMA.CO5.Models.HomeHero;
    var about = ViewBag.About as GAMA.CO5.Models.HomeAbout;
}

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-slate-50 p-7">

    <div class="mb-7 rounded-[30px] bg-gradient-to-br from-[#07142b] to-[#0f3d75] p-8 text-white shadow-2xl flex items-center justify-between gap-5">
        <div>
            <span class="inline-flex mb-3 rounded-full border border-white/20 bg-white/10 px-4 py-1 text-xs font-black text-blue-100">
                GAMA Home
            </span>
            <h2 class="text-3xl font-black">إدارة الصفحة الرئيسية</h2>
            <p class="mt-2 font-semibold text-blue-100">
                تحكم في الفيديو، التعريف، الإحصائيات، والأخبار والتحديثات.
            </p>
        </div>

        <a asp-action="CreateNews"
           class="rounded-2xl bg-gradient-to-br from-[#d4af37] to-[#f6d76b] px-6 py-3 font-black text-[#07142b] no-underline">
            + إضافة خبر
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-7">

        <div class="rounded-[26px] border border-blue-100 bg-white p-7 shadow-xl">
            <span class="inline-flex mb-3 rounded-full bg-blue-50 px-4 py-1 text-xs font-black text-[#0f3d75]">
                Hero Video
            </span>

            <h3 class="text-xl font-black text-[#07142b]">الفيديو الرئيسي</h3>

            <p class="mt-2 font-bold text-slate-500">
                @(string.IsNullOrWhiteSpace(hero?.Title) ? "لم يتم إضافة عنوان بعد" : hero.Title)
            </p>

            <a asp-action="EditHero"
               class="mt-5 inline-flex rounded-xl border border-orange-200 bg-orange-50 px-4 py-2 text-sm font-black text-orange-700 no-underline">
                تعديل
            </a>
        </div>

        <div class="rounded-[26px] border border-blue-100 bg-white p-7 shadow-xl">
            <span class="inline-flex mb-3 rounded-full bg-blue-50 px-4 py-1 text-xs font-black text-[#0f3d75]">
                About Section
            </span>

            <h3 class="text-xl font-black text-[#07142b]">سكشن التعريف</h3>

            <p class="mt-2 font-bold text-slate-500">
                @(string.IsNullOrWhiteSpace(about?.Title) ? "لم يتم إضافة عنوان بعد" : about.Title)
            </p>

            <a asp-action="EditAbout"
               class="mt-5 inline-flex rounded-xl border border-orange-200 bg-orange-50 px-4 py-2 text-sm font-black text-orange-700 no-underline">
                تعديل
            </a>
        </div>

    </div>

    <div class="overflow-x-auto rounded-[28px] border border-blue-100 bg-white shadow-2xl">
        <table class="w-full min-w-[900px] text-right">
            <thead class="bg-gradient-to-br from-[#07142b] to-[#0f3d75] text-white">
                <tr>
                    <th class="p-5 font-black">الصورة</th>
                    <th class="p-5 font-black">العنوان</th>
                    <th class="p-5 font-black">التاريخ</th>
                    <th class="p-5 font-black">الرابط</th>
                    <th class="p-5 font-black">إجراءات</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var imageUrl = string.IsNullOrWhiteSpace(item.ImageUrl)
                        ? "/images/news/placeholder.jpg"
                        : item.ImageUrl;

                        <tr class="border-b border-slate-100 hover:bg-blue-50">
                            <td class="p-5">
                                <div class="h-[72px] w-[96px] overflow-hidden rounded-2xl border border-blue-100 bg-slate-50">
                                    <img src="@imageUrl"
                                         class="h-full w-full object-cover"
                                         onerror="this.onerror=null;this.src='/images/news/placeholder.jpg';" />
                                </div>
                            </td>

                            <td class="p-5 font-black text-[#07142b]">
                                @item.Title
                            </td>

                            <td class="p-5">
                                <span class="rounded-full bg-blue-50 px-4 py-2 text-xs font-black text-[#0f3d75]">
                                    @item.NewsDate.ToString("yyyy/MM/dd")
                                </span>
                            </td>

                            <td class="p-5">
                                <span class="rounded-full bg-[#07142b] px-4 py-2 text-xs font-black text-white">
                                    @(string.IsNullOrWhiteSpace(item.LinkUrl) ? "—" : "يوجد رابط")
                                </span>
                            </td>

                            <td class="p-5">
                                <div class="flex gap-2 justify-center">
                                    <a asp-action="EditNews"
                                       asp-route-id="@item.Id"
                                       class="rounded-xl border border-orange-200 bg-orange-50 px-3 py-2 text-xs font-black text-orange-700 no-underline">
                                        تعديل
                                    </a>

                                    <a asp-action="DeleteNews"
                                       asp-route-id="@item.Id"
                                       class="rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-xs font-black text-red-700 no-underline">
                                        حذف
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="p-12 text-center font-black text-slate-500">
                            لا توجد أخبار حالياً.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>