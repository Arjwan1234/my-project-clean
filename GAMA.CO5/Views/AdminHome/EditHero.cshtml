@model GAMA.CO5.Models.HomeHero

@{
    ViewData["Title"] = "تعديل الفيديو الرئيسي";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-slate-50 p-7">

    <div class="mb-7 rounded-[30px] bg-gradient-to-br from-[#07142b] to-[#0f3d75] p-8 text-white shadow-2xl flex items-center justify-between gap-5">
        <div>
            <span class="inline-flex mb-3 rounded-full border border-white/20 bg-white/10 px-4 py-1 text-xs font-black text-blue-100">
                GAMA Home
            </span>
            <h2 class="text-3xl font-black">تعديل الفيديو الرئيسي</h2>
            <p class="mt-2 font-semibold text-blue-100">عدّل عنوان الهيرو، النص، والفيديو.</p>
        </div>

        <a asp-action="Index" class="rounded-2xl border border-white/20 bg-white/10 px-6 py-3 font-black text-white no-underline">
            رجوع
        </a>
    </div>

    <div class="rounded-[30px] border border-blue-100 bg-white p-8 shadow-2xl">
        <form asp-action="EditHero" method="post" enctype="multipart/form-data">
            <input asp-for="Id" type="hidden" />
            <input asp-for="VideoUrl" type="hidden" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="mb-2 block font-black text-[#07142b]">العنوان</label>
                    <input asp-for="Title" class="w-full rounded-2xl border border-blue-100 bg-slate-50 p-4 font-bold outline-none focus:border-[#0f3d75]" />
                    <span asp-validation-for="Title" class="text-sm text-red-600"></span>
                </div>

                <div>
                    <label class="mb-2 block font-black text-[#07142b]">نص الشارة</label>
                    <input asp-for="BadgeText" class="w-full rounded-2xl border border-blue-100 bg-slate-50 p-4 font-bold outline-none focus:border-[#0f3d75]" />
                </div>
            </div>

            <div class="mt-5">
                <label class="mb-2 block font-black text-[#07142b]">النص الفرعي</label>
                <textarea asp-for="Subtitle" rows="4" class="w-full rounded-2xl border border-blue-100 bg-slate-50 p-4 font-bold outline-none focus:border-[#0f3d75]"></textarea>
            </div>

            <div class="mt-5">
                <label class="mb-2 block font-black text-[#07142b]">تغيير الفيديو</label>
                <input asp-for="VideoFile" type="file" accept="video/*" class="w-full rounded-2xl border border-blue-100 bg-slate-50 p-4 font-bold" />
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
            {
                <div class="mt-6">
                    <label class="mb-2 block font-black text-[#07142b]">الفيديو الحالي</label>
                    <video controls class="w-full max-h-[360px] rounded-3xl bg-[#07142b]">
                        <source src="@Model.VideoUrl" type="video/mp4" />
                    </video>
                </div>
            }

            <div class="mt-8 flex gap-3">
                <button type="submit" class="rounded-2xl bg-gradient-to-br from-[#07142b] to-[#0f3d75] px-6 py-3 font-black text-white">
                    حفظ
                </button>

                <a asp-action="Index" class="rounded-2xl bg-slate-100 px-6 py-3 font-black text-slate-700 no-underline">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}