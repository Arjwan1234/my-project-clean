@model IEnumerable<GAMA.CO5.Models.Partner>

@{
    ViewData["Title"] = "إدارة الشركاء";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-products-page">

    <div class="products-hero">
        <div>
            <span class="hero-badge">GAMA Partners</span>
            <h2>إدارة الشركاء</h2>
            <p>إدارة شركاء المنصة وعرضهم في الموقع بشكل احترافي.</p>
        </div>

        <a asp-action="Create" class="btn-add">
            <i class="fa-solid fa-plus"></i>
            إضافة شريك
        </a>
    </div>

    <div class="products-card">
        <table class="products-table">
            <thead>
                <tr>
                    <th>الشعار</th>
                    <th>الاسم</th>
                    <th>الوصف</th>
                    <th>إجراءات</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var partner in Model)
                    {
                        var logo = string.IsNullOrWhiteSpace(partner.LogoUrl)
                        ? "/images/placeholder.png"
                        : partner.LogoUrl;

                        <tr>
                            <td>
                                <div class="product-image-box">
                                    <img src="@logo"
                                         alt="@partner.Name"
                                         onerror="this.onerror=null;this.src='/images/placeholder.png';" />
                                </div>
                            </td>

                            <td class="product-name">@partner.Name</td>

                            <td>
                                <span class="tag tag-blue">
                                    @(string.IsNullOrWhiteSpace(partner.Description) ? "لا يوجد وصف" : partner.Description)
                                </span>
                            </td>

                            <td>
                                <div class="actions">
                                    <a asp-action="Edit"
                                       asp-route-id="@partner.Id"
                                       class="btn-edit">
                                        تعديل
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@partner.Id"
                                       class="btn-delete">
                                        حذف
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty">
                            لا توجد شركاء حالياً.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .admin-products-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29, 78, 216, .16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        .products-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 12px;
            font-weight: 900;
            color: #dbeafe;
        }

        .products-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
        }

        .products-hero p {
            margin-top: 8px;
            color: #cbd5f5;
            font-weight: 600;
        }

        .btn-add {
            background: linear-gradient(135deg, #d4af37, #f6d76b);
            color: #07142b;
            padding: 12px 22px;
            border-radius: 18px;
            font-weight: 900;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: .25s;
        }

            .btn-add:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 30px rgba(212,175,55,.28);
            }

        .products-card {
            border-radius: 28px;
            overflow-x: auto;
            background: rgba(255,255,255,.95);
            border: 1px solid #dbe6f5;
            box-shadow: 0 24px 60px rgba(15,23,42,.1);
        }

        .products-table {
            width: 100%;
            min-width: 800px;
            border-collapse: collapse;
            text-align: right;
        }

            .products-table thead {
                background: linear-gradient(135deg, #07142b, #0f3d75);
                color: white;
            }

            .products-table th {
                padding: 18px;
                font-size: 14px;
                font-weight: 900;
            }

            .products-table td {
                padding: 18px;
                border-bottom: 1px solid #e5edf7;
                color: #334155;
                font-weight: 700;
            }

            .products-table tbody tr:hover {
                background: #f1f6ff;
            }

        .product-image-box {
            width: 96px;
            height: 72px;
            background: #f8fbff;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #dbe6f5;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .product-image-box img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

        .product-name {
            color: #07142b;
            font-weight: 900;
        }

        .tag {
            display: inline-flex;
            padding: 7px 13px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 900;
        }

        .tag-blue {
            background: #eef4ff;
            color: #0f3d75;
        }

        .actions {
            display: flex;
            justify-content: center;
            gap: 8px;
        }

        .btn-edit {
            background: #fff7ed;
            color: #c2410c;
            padding: 8px 12px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 900;
        }

        .btn-delete {
            background: #fef2f2;
            color: #b91c1c;
            padding: 8px 12px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 900;
        }

        .empty {
            padding: 40px;
            text-align: center;
            color: #64748b;
            font-weight: 900;
        }
    </style>
}