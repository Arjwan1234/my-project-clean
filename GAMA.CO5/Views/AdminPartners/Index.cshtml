@model List<GAMA.CO5.Models.Partner>

@{
    ViewData["Title"] = "إدارة الشركاء";
}

<h2 class="mb-4">إدارة الشركاء</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">إضافة شريك</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<table class="table table-bordered align-middle">
    <thead>
        <tr>
            <th>الشعار</th>
            <th>الاسم</th>
            <th>الوصف</th>
            <th>رابط الموقع</th>
            <th>إجراءات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var partner in Model)
        {
            <tr>
                <td style="width:110px;">
                    @if (!string.IsNullOrWhiteSpace(partner.LogoUrl))
                    {
                        <img src="@partner.LogoUrl"
                             alt="@partner.Name"
                             style="width:80px;height:80px;object-fit:cover;border-radius:50%;" />
                    }
                </td>
                <td>@partner.Name</td>
                <td>@partner.Description</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(partner.WebsiteUrl))
                    {
                        <a href="@partner.WebsiteUrl" target="_blank">@partner.WebsiteUrl</a>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@partner.Id" class="btn btn-sm btn-warning">تعديل</a>
                    <a asp-action="Delete" asp-route-id="@partner.Id" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
        }
    </tbody>
</table>