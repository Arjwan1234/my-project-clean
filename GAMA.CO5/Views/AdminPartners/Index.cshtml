@model IEnumerable<GAMA.CO5.Models.Partner>

@{
    ViewData["Title"] = "إدارة الشركاء";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">إدارة الشركاء</h2>

        <a asp-action="Create" class="btn btn-primary">
            إضافة شريك جديد
        </a>
    </div>

    <table class="table table-bordered table-striped text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>الشعار</th>
                <th>الاسم</th>
                <th>الوصف</th>
                <th>الموقع</th>
                <th>العمليات</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var partner in Model)
            {
                <tr>
                    <td>
                        <img src="@partner.LogoUrl"
                             style="width:80px;height:60px;object-fit:contain;" />
                    </td>

                    <td>@partner.Name</td>
                    <td>@partner.Description</td>

                    <td>
                        @if (!string.IsNullOrEmpty(partner.WebsiteUrl))
                        {
                            <a href="@partner.WebsiteUrl" target="_blank" class="btn btn-sm btn-info">
                                زيارة
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">لا يوجد</span>
                        }
                    </td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@partner.Id" class="btn btn-warning btn-sm">
                            تعديل
                        </a>

                        <a asp-action="Delete" asp-route-id="@partner.Id" class="btn btn-danger btn-sm">
                            حذف
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>