@model List<GAMA.CO5.Models.Partner>

@{
    ViewData["Title"] = "الشركاء";
    var partners = Model ?? new List<GAMA.CO5.Models.Partner>();
}

<section class="partners-luxury-section">

    <div class="partners-luxury-intro">
        <span class="section-badge">شركاء النجاح</span>
        <h1>شركاؤنا في النمو والابتكار</h1>
        <p>
            نؤمن أن القيمة الحقيقية تبدأ من شراكات استراتيجية قوية، لذلك نعمل مع أفضل الجهات
            لتقديم حلول أعمال وتجارب رقمية بمستوى احترافي راقٍ.
        </p>
    </div>

    <div class="partners-luxury-grid">
        @foreach (var partner in partners)
        {
            <div class="partner-wrapper">
                <div class="partner-luxury-card">
                    <div class="partner-ring ring-one"></div>
                    <div class="partner-ring ring-two"></div>

                    <div class="partner-logo-shell">
                        @if (!string.IsNullOrWhiteSpace(partner.LogoUrl))
                        {
                            <img src="@partner.LogoUrl" alt="@partner.Name" class="partner-logo-full" />
                        }
                        else
                        {
                            <div class="partner-no-logo">Logo</div>
                        }
                    </div>
                </div>

                <div class="partner-info">
                    <h3>@partner.Name</h3>
                    <span class="partner-status">شريك استراتيجي</span>
                </div>
            </div>
        }
    </div>

    <div class="partners-luxury-footer">
        نفخر بهذه الشراكات التي تمثل جزءاً مهماً من مسيرتنا في تقديم حلول تقنية عالية الجودة.
    </div>
</section>

<style>
    .partners-luxury-section {
        position: relative;
        padding: 100px 0 110px;
        background: linear-gradient(180deg, #f8fbfd 0%, #f2f6fb 100%);
        overflow: hidden;
    }

        /* زخرفة يسار */
        .partners-luxury-section::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 120px;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background: url("data:image/svg+xml;utf8,\
    <svg xmlns='http://www.w3.org/2000/svg' width='120' height='1200' viewBox='0 0 120 1200'>\
    <g fill='none' stroke='%235fb5ff' stroke-width='1.6' opacity='0.65'>\
    <path d='M0 36 L38 36 L10 64 L68 96'/>\
    <path d='M0 190 L46 190 L14 224 L76 262' opacity='0.55'/>\
    <path d='M0 360 L42 360 L12 394 L72 434' opacity='0.48'/>\
    <path d='M0 560 L50 560 L16 598 L84 640' opacity='0.42'/>\
    <path d='M0 790 L44 790 L12 826 L74 868' opacity='0.36'/>\
    </g>\
    <g fill='none' stroke='%23c084fc' stroke-width='1.4' opacity='0.55'>\
    <path d='M0 112 L34 112 L8 140 L60 174'/>\
    <path d='M0 290 L40 290 L10 324 L66 360' opacity='0.46'/>\
    <path d='M0 490 L36 490 L8 524 L62 560' opacity='0.38'/>\
    <path d='M0 710 L42 710 L12 746 L70 784' opacity='0.32'/>\
    </g>\
    <circle cx='38' cy='128' r='18' fill='%235fb5ff' opacity='0.30'/>\
    <circle cx='46' cy='304' r='10' fill='%23c084fc' opacity='0.28'/>\
    <circle cx='34' cy='540' r='24' fill='%235fb5ff' opacity='0.20'/>\
    <circle cx='40' cy='786' r='14' fill='%23c084fc' opacity='0.24'/>\
    </svg>") left top / 120px 100% no-repeat;
        }

        /* زخرفة يمين */
        .partners-luxury-section::after {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: 120px;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background: url("data:image/svg+xml;utf8,\
    <svg xmlns='http://www.w3.org/2000/svg' width='120' height='1200' viewBox='0 0 120 1200'>\
    <circle cx='84' cy='86' r='18' fill='%23a78bfa' opacity='0.36'/>\
    <circle cx='92' cy='232' r='8' fill='%2360a5fa' opacity='0.34'/>\
    <circle cx='96' cy='430' r='22' fill='%23a78bfa' opacity='0.28'/>\
    <circle cx='88' cy='620' r='10' fill='%2360a5fa' opacity='0.32'/>\
    <circle cx='98' cy='842' r='18' fill='%23a78bfa' opacity='0.28'/>\
    <path d='M26 516 C42 516, 58 516, 74 516' stroke='%23a78bfa' stroke-width='2' opacity='0.35' fill='none'/>\
    <rect x='66' y='507' width='34' height='18' rx='9' ry='9' stroke='%2360a5fa' stroke-width='1.3' opacity='0.32' fill='none'/>\
    </svg>") right top / 120px 100% no-repeat;
        }

    .partners-luxury-intro,
    .partners-luxury-grid,
    .partners-luxury-footer {
        position: relative;
        z-index: 2;
    }

    .partners-luxury-intro {
        text-align: center;
        max-width: 900px;
        margin: 0 auto 70px;
        padding: 0 20px;
    }

    .section-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: #ede9fe;
        color: #7c3aed;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 18px;
    }

    .partners-luxury-intro h1 {
        font-size: 62px;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 18px;
    }

    .partners-luxury-intro p {
        font-size: 18px;
        color: #64748b;
        line-height: 2;
    }

    .partners-luxury-grid {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 80px;
    }

    .partner-wrapper {
        text-align: center;
    }

    .partner-luxury-card {
        position: relative;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: #fff;
        border: 1px solid rgba(226,232,240,.8);
        box-shadow: 0 18px 45px rgba(15,23,42,.08);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .partner-ring {
        position: absolute;
        border-radius: 50%;
    }

    .ring-one {
        width: 88%;
        height: 88%;
        border: 1px dashed rgba(124,58,237,.18);
    }

    .ring-two {
        width: 72%;
        height: 72%;
        border: 1px dashed rgba(56,189,248,.18);
    }

    .partner-logo-shell {
        width: 128px;
        height: 128px;
        border-radius: 50%;
        overflow: hidden;
        z-index: 2;
    }

    .partner-logo-full {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .partner-info {
        margin-top: 24px;
    }

        .partner-info h3 {
            font-size: 22px;
            font-weight: 900;
            color: #0f172a;
            margin-bottom: 10px;
        }

    .partner-status {
        display: inline-block;
        padding: 8px 18px;
        border-radius: 999px;
        background: #dbeafe;
        color: #2563eb;
        font-size: 12px;
        font-weight: 800;
    }

    .partners-luxury-footer {
        text-align: center;
        margin-top: 60px;
        font-size: 16px;
        color: #64748b;
    }

    @@media (max-width: 768px) {
        .partners-luxury-section::before,
        .partners-luxury-section::after {
            width: 72px;
            background-size: 72px 100%;
            opacity: .75;
        }

        .partners-luxury-intro h1 {
            font-size: 38px;
        }

        .partner-luxury-card {
            width: 220px;
            height: 220px;
        }
    }
</style>