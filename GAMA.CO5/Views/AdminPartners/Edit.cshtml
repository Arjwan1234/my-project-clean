@model GAMA.CO5.Models.Partner
@{
    ViewData["Title"] = "تعديل العميل";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-client-form-page">

    <div class="client-form-hero">
        <div>
            <span class="hero-badge">GAMA Clients</span>
            <h2>تعديل العميل</h2>
            <p>تحديث اسم العميل وشعاره فقط</p>
        </div>

        <a asp-action="Index" class="btn-back">
            رجوع
        </a>
    </div>

    <div class="client-form-card">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="LogoUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- الشعار الحالي -->
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <div class="preview-box">
                    <label>الشعار الحالي</label>
                    <img src="@Model.LogoUrl" />
                </div>
            }

            <!-- اسم العميل -->
            <div class="field">
                <label asp-for="Name">اسم العميل</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- تغيير الشعار -->
            <div class="field mt-4">
                <label asp-for="ImageFile">تغيير الشعار</label>
                <input asp-for="ImageFile" type="file" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <!-- أزرار -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    حفظ التعديلات
                </button>

                <a asp-action="Index" class="btn-cancel">
                    إلغاء
                </a>
            </div>

        </form>
    </div>
</div>

@section Styles {
    <style>

        .admin-client-form-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29,78,216,.16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        /* HERO */
        .client-form-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            font-size: 12px;
            font-weight: 900;
        }

        /* CARD */
        .client-form-card {
            border-radius: 30px;
            background: white;
            padding: 32px;
            box-shadow: 0 20px 60px rgba(0,0,0,.08);
        }

        /* PREVIEW */
        .preview-box {
            margin-bottom: 24px;
            padding: 18px;
            border-radius: 22px;
            background: #f8fbff;
            border: 1px solid #dbe6f5;
        }

            .preview-box img {
                width: 130px;
                height: 100px;
                object-fit: contain;
                background: white;
                border-radius: 18px;
                padding: 10px;
            }

        /* FIELDS */
        .field label {
            display: block;
            margin-bottom: 8px;
            font-weight: 900;
        }

        .field input {
            width: 100%;
            padding: 12px;
            border-radius: 14px;
            border: 1px solid #dbe6f5;
        }

        /* BUTTONS */
        .form-actions {
            margin-top: 25px;
            display: flex;
            gap: 10px;
        }

        .btn-save {
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            padding: 12px 22px;
            border-radius: 14px;
            border: none;
            font-weight: 900;
        }

        .btn-cancel {
            background: #e2e8f0;
            padding: 12px 22px;
            border-radius: 14px;
            text-decoration: none;
            color: #334155;
            font-weight: 900;
        }

    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}