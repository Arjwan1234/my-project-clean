@model GAMA.CO5.Models.Partner

@{
    ViewData["Title"] = "تعديل الشريك";
}

<h2 class="mb-4">تعديل الشريك</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input asp-for="Id" type="hidden" />
    <input asp-for="LogoUrl" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">اسم الشريك</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">الوصف</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="WebsiteUrl" class="form-label">رابط الموقع</label>
        <input asp-for="WebsiteUrl" class="form-control" />
        <span asp-validation-for="WebsiteUrl" class="text-danger"></span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
    {
        <div class="mb-3">
            <label class="form-label">الصورة الحالية</label><br />
            <img src="@Model.LogoUrl" alt="@Model.Name" style="width:100px;height:100px;border-radius:50%;object-fit:cover;" />
        </div>
    }

    <div class="mb-3">
        <label asp-for="ImageFile" class="form-label">تغيير الصورة</label>
        <input asp-for="ImageFile" type="file" class="form-control" />
        <span asp-validation-for="ImageFile" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">حفظ التعديلات</button>
    <a asp-action="Index" class="btn btn-secondary">رجوع</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}