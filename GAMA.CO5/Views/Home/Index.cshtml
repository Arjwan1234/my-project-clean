<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>الرئيسية - GAMA</title>

    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">

            <!-- 🔥 الشعار الجديد -->
            <a href="/Home/Index" class="logo">
                <img src="/images/logo-gama.jpg" alt="GAMA Logo">
            </a>

            <button class="mobile-menu-btn" id="mobileMenuBtn">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="nav-links" id="navLinks">
                <li><a href="/Services/Index">الخدمات</a></li>
                <li><a href="/Products/Index">المنتجات</a></li>
                <li><a href="/DTI/Index">مؤشر التحول الرقمي</a></li>
                <li><a href="/Partners/Index">الشركاء</a></li>
                <li><a href="/Careers/Index">الوظائف</a></li>
                <li><a href="/Contact/Index">التواصل</a></li>
            </ul>

        </div>
    </nav>

    <!-- Hero Video -->
    <section class="hero-video">
        <video autoplay muted loop playsinline class="hero-bg">
            <source src="/Videos/video_2026-02-17_10-52-27.mp4" type="video/mp4">
        </video>

        <div class="hero-overlay">
            <div class="hero-content">
                <h1>الشركة العربية الشاملة للتطبيقات المحدودة</h1>
                <p>شريكك الموثوق في التحول الرقمي</p>
                <a href="/Services/Index" class="btn btn-primary">استكشف خدماتنا</a>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="section">
        <div class="container">
            <h2>خدماتنا التقنية</h2>

            <div class="grid">
                <div class="card">
                    <div class="icon">☁️</div>
                    <h3>الحوسبة السحابية</h3>
                    <p>حلول سحابية متقدمة ومرنة تساعدك على توسيع أعمالك بسهولة</p>
                </div>

                <div class="card">
                    <div class="icon">🔐</div>
                    <h3>الأمن السيبراني</h3>
                    <p>حماية شاملة لبياناتك ومعلوماتك من التهديدات الإلكترونية</p>
                </div>

                <div class="card">
                    <div class="icon">🤖</div>
                    <h3>الذكاء الاصطناعي</h3>
                    <p>تطبيقات ذكية تعتمد على التعلم الآلي والذكاء الاصطناعي</p>
                </div>

                <div class="card">
                    <div class="icon">📊</div>
                    <h3>تحليل البيانات</h3>
                    <p>استخراج رؤى قيمة من بياناتك لاتخاذ قرارات استراتيجية</p>
                </div>
            </div>

            <div style="text-align: center; margin-top: 3rem;">
                <a href="/Services/Index" class="btn btn-primary">عرض كل الخدمات</a>
            </div>

        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <div class="footer-logo">GAMA</div>
                    <h4>الشركة العربية الشاملة للتطبيقات المحدودة</h4>
                    <p>شريكك الموثوق في التحول الرقمي منذ 2020</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="/js/site.js"></script>

</body>
</html>
