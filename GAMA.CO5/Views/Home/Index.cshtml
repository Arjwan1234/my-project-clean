@model GAMA.CO5.Models.HomeViewModel
@using System.Globalization

@{
    var isEn = CultureInfo.CurrentCulture.Name.StartsWith("en");
    var textAlign = isEn ? "text-left" : "text-right";
    var featureDirection = isEn ? "flex-row-reverse" : "flex-row-reverse";
    var linePosition = isEn ? "mr-auto ml-0" : "mr-0 ml-auto";
}

<div class="relative text-white overflow-x-hidden" style="background: linear-gradient(180deg, #071225 0%, #0b1730 45%, #10233f 100%);">

    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0" style="background: linear-gradient(180deg, #071225 0%, #0b1730 45%, #10233f 100%);"></div>
        <div class="absolute inset-0 page-grid opacity-60"></div>
        <div class="parallax absolute left-[6%] top-[8%] h-60 w-60 rounded-full bg-blue-500/10 blur-3xl" data-speed="0.08"></div>
        <div class="parallax absolute right-[8%] top-[14%] h-64 w-64 rounded-full bg-cyan-400/10 blur-3xl" data-speed="0.12"></div>
        <div class="parallax absolute left-[15%] top-[38%] h-72 w-72 rounded-full bg-blue-500/10 blur-3xl" data-speed="0.06"></div>
        <div class="parallax absolute right-[12%] top-[62%] h-64 w-64 rounded-full bg-fuchsia-400/10 blur-3xl" data-speed="0.09"></div>
    </div>

    <div class="relative z-10">
        <section class="relative w-full overflow-hidden" style="height: 104vh;">
            <video class="absolute inset-0"
                   style="width:100%; height:100%; object-fit:cover;"
                   autoplay muted loop playsinline>
                <source src="/Videos/hero.mp4" type="video/mp4">
            </video>

            <div class="absolute inset-0 bg-black/55"></div>

            <div class="relative z-10 flex items-center justify-center text-center px-6"
                 style="height:104vh;">
                <div class="reveal max-w-5xl">
                    <span class="inline-flex items-center gap-2 rounded-full border border-cyan-400/25 bg-cyan-400/10 px-5 py-2 text-sm mb-6">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        @(isEn ? "Intro Video" : "فيديو تعريفي")
                    </span>

                    <h1 class="text-5xl md:text-6xl lg:text-7xl font-black leading-[1.1]">
                        @if (isEn)
                        {
                            <text>We create digital solutions<br />that make impact</text>
                        }
                        else
                        {
                            <text>نبتكر حلولًا رقمية<br />تصنع الأثر</text>
                        }
                    </h1>

                    <p class="mt-6 text-lg md:text-2xl text-white/85 leading-relaxed max-w-3xl mx-auto">
                        @(isEn
                                                ? "Advanced technology solutions for government entities and enterprises"
                                                : "حلول تقنية متقدمة تدعم الجهات الحكومية والمؤسسات")
                    </p>
                </div>
            </div>
        </section>

        <section class="relative flex items-center justify-center py-8 px-6">
            <div class="max-w-[1050px] w-full mx-auto grid grid-cols-1 lg:grid-cols-2 items-center gap-8">

                <!-- CONTENT LEFT -->
                <div class="max-w-[460px] w-full text-right reveal justify-self-center lg:justify-self-start">

                    <div class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1.5 text-xs mb-4">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        @(isEn ? "Your trusted partner" : "شريكك الموثوق")
                    </div>

                    <h1 class="text-3xl md:text-4xl lg:text-5xl font-black leading-[1.15]">
                        @(isEn ? "Your partner in" : "شريكك في التحول")<br />
                        @(isEn ? "digital transformation" : "الرقمي")
                    </h1>

                    <div class="w-16 h-1 bg-gradient-to-l from-cyan-400 to-blue-500 rounded-full mt-4 mr-0 ml-auto"></div>

                    <p class="mt-5 text-base md:text-lg leading-loose">
                        @(isEn
                                                ? "We provide advanced technology solutions for government entities and enterprises to support Saudi Vision 2030"
                                                : "نقدم حلول تقنية متطورة للجهات الحكومية والمؤسسات لتحقيق رؤية المملكة 2030")
                    </p>

                    <div class="mt-6 space-y-4">
                        <div class="flex flex-row-reverse items-start gap-3 reveal">
                            <div class="w-9 h-9 shrink-0 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center text-sm">🚀</div>
                            <div>
                                <h3 class="text-lg font-extrabold">@(isEn ? "Continuous Innovation" : "ابتكار مستمر")</h3>
                                <p class="text-sm mt-1">@(isEn ? "Innovative solutions aligned with Saudi Vision 2030" : "حلول تقنية مبتكرة ومتوافقة مع رؤية المملكة 2030")</p>
                            </div>
                        </div>

                        <div class="flex flex-row-reverse items-start gap-3 reveal">
                            <div class="w-9 h-9 shrink-0 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center text-sm">👥</div>
                            <div>
                                <h3 class="text-lg font-extrabold">@(isEn ? "Expert Team" : "فريق الخبراء")</h3>
                                <p class="text-sm mt-1">@(isEn ? "A team of experts and specialists across technical fields" : "فريق من الخبراء والمتخصصين في جميع المجالات التقنية")</p>
                            </div>
                        </div>

                        <div class="flex flex-row-reverse items-start gap-3 reveal">
                            <div class="w-9 h-9 shrink-0 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center text-sm">🛡️</div>
                            <div>
                                <h3 class="text-lg font-extrabold">@(isEn ? "Continuous Support" : "دعم متواصل")</h3>
                                <p class="text-sm mt-1">@(isEn ? "Continuous technical support and maintenance to ensure business continuity" : "دعم فني متواصل وصيانة مستمرة لضمان استمرارية العمل")</p>
                            </div>
                        </div>
                    </div>

                    <a asp-controller="Contact"
                       asp-action="Index"
                       class="mt-7 inline-flex rounded-2xl bg-gradient-to-l from-blue-500 to-cyan-400 px-6 py-2.5 text-sm font-bold shadow-[0_0_20px_rgba(34,211,238,0.30)] no-underline text-white">
                        @(isEn ? "Start your digital journey →" : "ابدأ رحلتك الرقمية ←")
                    </a>
                </div>

                <!-- STATS RIGHT -->
                <div class="relative space-y-3 max-w-[360px] w-full justify-self-center lg:justify-self-end">

                    <div class="float-soft reveal rounded-[20px] glass-strong px-4 py-4 shadow-[0_8px_30px_rgba(0,0,0,0.22)]">
                        <div class="flex items-center justify-between">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center text-sm">↗</div>
                            <div class="text-right">
                                <div class="text-3xl font-black">+30</div>
                                <div class="text-sm mt-1">@(isEn ? "Years of experience" : "عامًا من الخبرة")</div>
                            </div>
                        </div>
                    </div>

                    <div class="float-soft-delay reveal rounded-[20px] glass-strong px-4 py-4 shadow-[0_8px_30px_rgba(0,0,0,0.22)]">
                        <div class="flex items-center justify-between">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center text-sm">◎</div>
                            <div class="text-right">
                                <div class="text-3xl font-black">+500</div>
                                <div class="text-sm mt-1">@(isEn ? "Successful projects" : "مشروع ناجح")</div>
                            </div>
                        </div>
                    </div>

                    <div class="float-soft reveal rounded-[20px] glass-strong px-4 py-4 shadow-[0_8px_30px_rgba(0,0,0,0.22)]">
                        <div class="flex items-center justify-between">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center text-sm">🏅</div>
                            <div class="text-right">
                                <div class="text-3xl font-black">100%</div>
                                <div class="text-sm mt-1">@(isEn ? "Customer satisfaction" : "نسبة رضا العملاء")</div>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </section>
      

  
        <section class="relative py-16 px-6 text-center">
            <div class="max-w-[1200px] mx-auto">
                <div class="text-center mb-12 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-400/25 text-cyan-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        @(isEn ? "Our Services" : "خدماتنا")
                    </span>

                    <h2 class="mt-5 text-3xl md:text-4xl font-black">@(isEn ? "Our Technical Solutions" : "حلولنا التقنية")</h2>

                    <p class="mt-4 text-white/80 text-base max-w-2xl mx-auto leading-8">
                        @(isEn
                                                ? "We provide integrated technical services that support digital transformation for government entities and enterprises"
                                                : "نقدم مجموعة متكاملة من الخدمات التقنية التي تدعم التحول الرقمي للجهات الحكومية والمؤسسات")
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    <div class="reveal rounded-3xl glass-card p-6 text-center flex flex-col items-center">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-xl mb-5">💻</div>
                        <h3 class="text-xl font-bold mb-3">@(isEn ? "System Development" : "تطوير الأنظمة")</h3>
                        <p class="text-white/80 leading-8 text-sm md:text-base">@(isEn ? "Design and development of custom systems, portals, and advanced dashboards." : "تصميم وتطوير أنظمة مخصصة وبوابات إلكترونية ولوحات تحكم متقدمة.")</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-6 text-center flex flex-col items-center">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-xl mb-5">☁️</div>
                        <h3 class="text-xl font-bold mb-3">@(isEn ? "Cloud Solutions" : "الحلول السحابية")</h3>
                        <p class="text-white/80 leading-8 text-sm md:text-base">@(isEn ? "Modern and secure cloud infrastructure that improves performance." : "بنية تحتية سحابية حديثة وآمنة تساعد في رفع الأداء.")</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-6 text-center flex flex-col items-center">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-xl mb-5">🔒</div>
                        <h3 class="text-xl font-bold mb-3">@(isEn ? "Cybersecurity" : "الأمن السيبراني")</h3>
                        <p class="text-white/80 leading-8 text-sm md:text-base">@(isEn ? "Protecting systems and data from digital threats." : "حماية الأنظمة والبيانات من التهديدات الرقمية.")</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-6 text-center flex flex-col items-center">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-xl mb-5">📊</div>
                        <h3 class="text-xl font-bold mb-3">@(isEn ? "Data Analytics" : "تحليل البيانات")</h3>
                        <p class="text-white/80 leading-8 text-sm md:text-base">@(isEn ? "Smart dashboards and reports that support decision-making." : "لوحات بيانات وتقارير ذكية تساعد في اتخاذ القرار.")</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-6 text-center flex flex-col items-center">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-xl mb-5">🤖</div>
                        <h3 class="text-xl font-bold mb-3">@(isEn ? "Artificial Intelligence" : "الذكاء الاصطناعي")</h3>
                        <p class="text-white/80 leading-8 text-sm md:text-base">@(isEn ? "Smart solutions to improve efficiency and automate operations." : "حلول ذكية لتحسين الكفاءة وأتمتة العمليات.")</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-6 text-center flex flex-col items-center">
                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-xl mb-5">🛠️</div>
                        <h3 class="text-xl font-bold mb-3">@(isEn ? "Support & Maintenance" : "الدعم والصيانة")</h3>
                        <p class="text-white/80 leading-8 text-sm md:text-base">@(isEn ? "Continuous support and maintenance to ensure system stability." : "دعم فني وصيانة مستمرة لضمان استقرار الأنظمة.")</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="relative py-16 px-6">
            <div class="max-w-[1200px] mx-auto">
                <div class="text-center mb-12 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-400/25 text-cyan-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        @(isEn ? "Success Partners" : "شركاء النجاح")
                    </span>

                    <h2 class="mt-5 text-3xl md:text-4xl font-black">@(isEn ? "Our Partners" : "شركاؤنا")</h2>
                </div>

                @if (Model.Partners != null && Model.Partners.Any())
                {
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5">
                        @foreach (var partner in Model.Partners)
                        {
                            <div class="reveal rounded-3xl glass-card p-5 min-h-[140px] flex flex-col items-center justify-center">
                                <img src="@Url.Content(partner.ImagePath ?? "")"
                                     alt="@partner.Name"
                                     class="max-h-10 object-contain" />
                                <h3 class="font-bold text-base mt-4 text-center">@partner.Name</h3>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-white/60">@(isEn ? "No partners available currently." : "لا توجد شركاء حالياً.")</p>
                }
            </div>
        </section>

        <section class="relative py-16 px-6">
            <div class="max-w-[1200px] mx-auto">
                <div class="text-center mb-12 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-fuchsia-500/10 border border-fuchsia-300/25 text-fuchsia-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-fuchsia-400"></span>
                        @(isEn ? "We are proud of" : "نحن نفخر")
                    </span>

                    <h2 class="mt-5 text-3xl md:text-4xl font-black">@(isEn ? "Our Clients" : "عملاؤنا")</h2>
                </div>

                @if (Model.Clients != null && Model.Clients.Any())
                {
                    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-5">
                        @foreach (var client in Model.Clients)
                        {
                            var logo = string.IsNullOrWhiteSpace(client.ImagePath)
                            ? "/images/placeholder.png"
                            : client.ImagePath;

                            <a href="@(string.IsNullOrWhiteSpace(client.Url) ? "#" : client.Url)"
                               target="@(string.IsNullOrWhiteSpace(client.Url) ? "_self" : "_blank")"
                               class="reveal rounded-3xl glass-card p-4 min-h-[150px] flex flex-col items-center justify-center no-underline text-white transition hover:-translate-y-1">

                                <img src="@Url.Content(logo)"
                                     alt="@client.Name"
                                     class="h-16 w-auto object-contain" />
                                <h3 class="font-bold mt-4 text-center text-sm md:text-base">@client.Name</h3>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-white/60">@(isEn ? "No clients available currently." : "لا يوجد عملاء حالياً.")</p>
                }
            </div>
        </section>

        <section class="relative py-16 px-6">
            <div class="max-w-[1100px] mx-auto">
                <div class="text-center mb-12 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-400/15 border border-cyan-400/30 text-cyan-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        @(isEn ? "News" : "الأخبار")
                    </span>

                    <h2 class="mt-4 text-3xl md:text-4xl font-black">@(isEn ? "News & Updates" : "أخبار وتحديثات")</h2>

                    <p class="mt-4 text-white/70 text-base">
                        @(isEn
                                                ? "Follow our latest news and updates in technology and digital transformation"
                                                : "تابع آخر أخبارنا ومستجداتنا في عالم التقنية والتحول الرقمي")
                    </p>
                </div>

                <div class="rounded-[30px] bg-white/5 border border-white/10 overflow-hidden reveal">
                    <div class="grid grid-cols-1 lg:grid-cols-2">
                        <div class="relative min-h-[300px]">
                            <img src="/images/news-saudi.png" class="absolute inset-0 w-full h-full object-cover grayscale opacity-90">
                            <div class="absolute inset-0 bg-gradient-to-t from-[#071225] via-transparent to-transparent"></div>
                        </div>

                        <div class="p-7 md:p-10 @textAlign flex flex-col justify-center">
                            <div class="text-cyan-300 mb-5 text-sm md:text-base">
                                @(isEn ? "📅 February 10, 2026" : "📅 فبراير 10 2026")
                            </div>

                            <h3 class="text-2xl md:text-3xl font-black leading-snug">
                                @if (isEn)
                                {
                                    <text>Our participation in the Saudi<br />Technology and Innovation Forum 2026</text>
                                }
                                else
                                {
                                    <text>مشاركتنا في المنتدى السعودي<br />للتقنية والابتكار 2026</text>
                                }
                            </h3>

                            <p class="mt-5 text-white/75 text-base leading-8">
                                @(isEn
                                                                ? "The company participated in one of the leading technology events in the Kingdom, showcasing its latest solutions and innovations."
                                                                : "شاركت الشركة في أحد أبرز الأحداث التقنية في المملكة، حيث عرضت أحدث حلولها وابتكاراتها التقنية.")
                            </p>

                            <a href="#" class="mt-7 inline-flex w-fit rounded-2xl bg-gradient-to-l from-blue-500 to-cyan-400 px-6 py-3 font-bold text-white no-underline">
                                @(isEn ? "Read more →" : "اقرأ المزيد ←")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </div>

    <script>
        const revealItems = document.querySelectorAll('.reveal');

        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('show');
                }
            });
        }, { threshold: 0.12 });

        revealItems.forEach((item, index) => {
            item.style.transitionDelay = `${Math.min(index * 40, 240)}ms`;
            revealObserver.observe(item);
        });

        const parallaxItems = document.querySelectorAll('.parallax');

        function updateParallax() {
            const scrollY = window.scrollY;
            parallaxItems.forEach((item) => {
                const speed = parseFloat(item.dataset.speed || '0.08');
                item.style.transform = `translateY(${scrollY * speed}px)`;
            });
        }

        updateParallax();
        window.addEventListener('scroll', updateParallax, { passive: true });
    </script>
</div>