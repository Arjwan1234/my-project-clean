@model GAMA.CO5.Models.HomeViewModel

<div class="relative min-h-screen text-white overflow-x-hidden"
     style="background: linear-gradient(180deg, #071225 0%, #0b1730 45%, #10233f 100%);">

    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0" style="background: linear-gradient(180deg, #071225 0%, #0b1730 45%, #10233f 100%);"></div>
        <div class="absolute inset-0 page-grid opacity-60"></div>
        <div class="parallax absolute left-[6%] top-[8%] h-72 w-72 rounded-full bg-blue-500/10 blur-3xl" data-speed="0.08"></div>
        <div class="parallax absolute right-[8%] top-[14%] h-80 w-80 rounded-full bg-cyan-400/10 blur-3xl" data-speed="0.12"></div>
        <div class="parallax absolute left-[15%] top-[38%] h-96 w-96 rounded-full bg-blue-500/10 blur-3xl" data-speed="0.06"></div>
        <div class="parallax absolute right-[12%] top-[62%] h-80 w-80 rounded-full bg-fuchsia-400/10 blur-3xl" data-speed="0.09"></div>
    </div>

    <div class="relative z-10">

        <section class="relative h-screen w-full overflow-hidden">
            <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
                <source src="/Videos/hero.mp4" type="video/mp4">
            </video>

            <div class="absolute inset-0 bg-black/55"></div>

            <div class="relative z-10 h-full flex items-center justify-center text-center px-6">
                <div class="reveal">
                    <span class="inline-flex items-center gap-2 rounded-full border border-cyan-400/25 bg-cyan-400/10 px-5 py-2 text-sm mb-6">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        فيديو تعريفي
                    </span>

                    <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-[1.2]">
                        نبتكر حلولًا رقمية
                        <br />
                        تصنع الأثر
                    </h1>

                    <p class="mt-6 text-lg md:text-2xl text-white/85">
                        حلول تقنية متقدمة تدعم الجهات الحكومية والمؤسسات
                    </p>
                </div>
            </div>
        </section>

        <!-- DIGITAL PARTNER -->
        <section class="relative min-h-screen flex items-center justify-center py-24 px-6">
            <div class="max-w-[1180px] w-full mx-auto grid grid-cols-1 lg:grid-cols-2 items-center gap-20">

                <!-- الإحصائيات - يسار -->
                <div class="relative space-y-5 max-w-[430px] w-full justify-self-center lg:justify-self-start">
                    <div class="float-soft reveal rounded-[24px] glass-strong px-5 py-6 shadow-[0_10px_40px_rgba(0,0,0,0.25)]">
                        <div class="flex items-center justify-between">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center">↗</div>
                            <div class="text-right">
                                <div class="text-5xl font-black">+30</div>
                                <div class="text-lg mt-2">عامًا من الخبرة</div>
                            </div>
                        </div>
                    </div>

                    <div class="float-soft-delay reveal rounded-[24px] glass-strong px-5 py-6 shadow-[0_10px_40px_rgba(0,0,0,0.25)]">
                        <div class="flex items-center justify-between">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center">◎</div>
                            <div class="text-right">
                                <div class="text-5xl font-black">+500</div>
                                <div class="text-lg mt-2">مشروع ناجح</div>
                            </div>
                        </div>
                    </div>

                    <div class="float-soft reveal rounded-[24px] glass-strong px-5 py-6 shadow-[0_10px_40px_rgba(0,0,0,0.25)]">
                        <div class="flex items-center justify-between">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center">🏅</div>
                            <div class="text-right">
                                <div class="text-5xl font-black">100%</div>
                                <div class="text-lg mt-2">نسبة رضا العملاء</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- النص - يمين -->
                <div class="max-w-[560px] w-full text-right reveal justify-self-center lg:justify-self-end">
                    <div class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-5 py-2 text-sm mb-6">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        شركتك الموثوق
                    </div>

                    <h1 class="text-5xl md:text-6xl lg:text-7xl font-black leading-[1.15]">
                        شريكك في التحول
                        <br />
                        الرقمي
                    </h1>

                    <div class="w-24 h-1.5 bg-gradient-to-l from-cyan-400 to-blue-500 rounded-full mt-5 mr-0 ml-auto"></div>

                    <p class="mt-8 text-xl md:text-2xl leading-loose">
                        نقدم حلول تقنية متطورة للجهات الحكومية والمؤسسات
                        لتحقيق رؤية المملكة 2030
                    </p>

                    <div class="mt-10 space-y-7">
                        <div class="flex flex-row-reverse items-start gap-4 reveal">
                            <div class="w-12 h-12 shrink-0 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center">🚀</div>
                            <div>
                                <h3 class="text-2xl font-extrabold">ابتكار مستمر</h3>
                                <p class="text-lg mt-1">حلول تقنية مبتكرة ومتوافقة مع رؤية المملكة 2030</p>
                            </div>
                        </div>

                        <div class="flex flex-row-reverse items-start gap-4 reveal">
                            <div class="w-12 h-12 shrink-0 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center">👥</div>
                            <div>
                                <h3 class="text-2xl font-extrabold">فريق الخبراء</h3>
                                <p class="text-lg mt-1">فريق من الخبراء والمتخصصين في جميع المجالات التقنية</p>
                            </div>
                        </div>

                        <div class="flex flex-row-reverse items-start gap-4 reveal">
                            <div class="w-12 h-12 shrink-0 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center">🛡️</div>
                            <div>
                                <h3 class="text-2xl font-extrabold">دعم متواصل</h3>
                                <p class="text-lg mt-1">دعم فني متواصل وصيانة مستمرة لضمان استمرارية العمل</p>
                            </div>
                        </div>
                    </div>

                    <a asp-controller="Contact"
                       asp-action="Index"
                       class="mt-10 inline-flex rounded-2xl bg-gradient-to-l from-blue-500 to-cyan-400 px-8 py-4 text-lg font-bold shadow-[0_0_30px_rgba(34,211,238,0.35)] no-underline text-white">
                        ابدأ رحلتك الرقمية ←
                    </a>
                </div>

            </div>
        </section>

     



           

        <!-- SERVICES -->
        <section class="relative py-24 px-6 text-center">
            <div class="max-w-[1400px] mx-auto">
                <div class="text-center mb-16 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-400/25 text-cyan-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        خدماتنا
                    </span>

                    <h2 class="mt-5 text-4xl md:text-5xl font-black">حلولنا التقنية</h2>

                    <p class="mt-4 text-white/80 text-lg max-w-2xl mx-auto leading-8">
                        نقدم مجموعة متكاملة من الخدمات التقنية التي تدعم التحول الرقمي للجهات الحكومية والمؤسسات
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                    <div class="reveal rounded-3xl glass-card p-8 text-center flex flex-col items-center">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-2xl mb-6">💻</div>
                        <h3 class="text-2xl font-bold mb-3">تطوير الأنظمة</h3>
                        <p class="text-white/80 leading-8">تصميم وتطوير أنظمة مخصصة وبوابات إلكترونية ولوحات تحكم متقدمة.</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-8 text-center flex flex-col items-center">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-2xl mb-6">☁️</div>
                        <h3 class="text-2xl font-bold mb-3">الحلول السحابية</h3>
                        <p class="text-white/80 leading-8">بنية تحتية سحابية حديثة وآمنة تساعد في رفع الأداء.</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-8 text-center flex flex-col items-center">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-2xl mb-6">🔒</div>
                        <h3 class="text-2xl font-bold mb-3">الأمن السيبراني</h3>
                        <p class="text-white/80 leading-8">حماية الأنظمة والبيانات من التهديدات الرقمية.</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-8 text-center flex flex-col items-center">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-2xl mb-6">📊</div>
                        <h3 class="text-2xl font-bold mb-3">تحليل البيانات</h3>
                        <p class="text-white/80 leading-8">لوحات بيانات وتقارير ذكية تساعد في اتخاذ القرار.</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-8 text-center flex flex-col items-center">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-2xl mb-6">🤖</div>
                        <h3 class="text-2xl font-bold mb-3">الذكاء الاصطناعي</h3>
                        <p class="text-white/80 leading-8">حلول ذكية لتحسين الكفاءة وأتمتة العمليات.</p>
                    </div>

                    <div class="reveal rounded-3xl glass-card p-8 text-center flex flex-col items-center">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-2xl mb-6">🛠️</div>
                        <h3 class="text-2xl font-bold mb-3">الدعم والصيانة</h3>
                        <p class="text-white/80 leading-8">دعم فني وصيانة مستمرة لضمان استقرار الأنظمة.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PARTNERS -->
        <section class="relative py-24 px-6">
            <div class="max-w-[1400px] mx-auto">
                <div class="text-center mb-16 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-400/25 text-cyan-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        شركاء النجاح
                    </span>

                    <h2 class="mt-5 text-4xl md:text-5xl font-black">شركاؤنا</h2>
                </div>

                @if (Model.Partners != null && Model.Partners.Any())
                {
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
                        @foreach (var partner in Model.Partners)
                        {
                            <div class="reveal rounded-3xl glass-card p-6 min-h-[170px] flex flex-col items-center justify-center">
                                <img src="@Url.Content(partner.ImagePath ?? "")"
                                     alt="@partner.Name"
                                     class="max-h-12 object-contain" />
                                <h3 class="font-bold text-lg mt-4 text-center">@partner.Name</h3>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-white/60">لا توجد شركاء حالياً.</p>
                }
            </div>
        </section>

        <!-- CLIENTS -->
        <section class="relative py-24 px-6">
            <div class="max-w-[1400px] mx-auto">
                <div class="text-center mb-16 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-fuchsia-500/10 border border-fuchsia-300/25 text-fuchsia-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-fuchsia-400"></span>
                        نحن نفخر
                    </span>

                    <h2 class="mt-5 text-4xl md:text-5xl font-black">عملاؤنا</h2>
                </div>

                @if (Model.Clients != null && Model.Clients.Any())
                {
                    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-6">
                        @foreach (var client in Model.Clients)
                        {
                            var logo = string.IsNullOrWhiteSpace(client.ImagePath)
                            ? "/images/placeholder.png"
                            : client.ImagePath;

                            <a href="@(string.IsNullOrWhiteSpace(client.Url) ? "#" : client.Url)"
                               target="@(string.IsNullOrWhiteSpace(client.Url) ? "_self" : "_blank")"
                               class="reveal rounded-3xl glass-card p-5 min-h-[190px] flex flex-col items-center justify-center no-underline text-white transition hover:-translate-y-1">

                                <img src="@Url.Content(logo)"
                                     alt="@client.Name"
                                     class="h-24 w-auto object-contain" />
                                <h3 class="font-bold mt-4 text-center">@client.Name</h3>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-white/60">لا يوجد عملاء حالياً.</p>
                }
            </div>
        </section>

        <!-- NEWS -->
        <section class="relative py-24 px-6">
            <div class="max-w-[1200px] mx-auto">
                <div class="text-center mb-14 reveal">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-400/15 border border-cyan-400/30 text-cyan-200 text-sm">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        الأخبار
                    </span>

                    <h2 class="mt-4 text-4xl md:text-5xl font-black">أخبار وتحديثات</h2>

                    <p class="mt-4 text-white/70 text-lg">
                        تابع آخر أخبارنا ومستجداتنا في عالم التقنية والتحول الرقمي
                    </p>
                </div>

                <div class="rounded-[34px] bg-white/5 border border-white/10 overflow-hidden reveal">
                    <div class="grid grid-cols-1 lg:grid-cols-2">
                        <div class="relative min-h-[360px]">
                            <img src="/images/news-saudi.png" class="absolute inset-0 w-full h-full object-cover grayscale opacity-90">
                            <div class="absolute inset-0 bg-gradient-to-t from-[#071225] via-transparent to-transparent"></div>
                        </div>

                        <div class="p-8 md:p-12 text-right flex flex-col justify-center">
                            <div class="text-cyan-300 mb-6">📅 فبراير 10 2026</div>

                            <h3 class="text-3xl md:text-4xl font-black leading-snug">
                                مشاركتنا في المنتدى السعودي
                                <br>
                                للتقنية والابتكار 2026
                            </h3>

                            <p class="mt-6 text-white/75 text-lg leading-9">
                                شاركت الشركة في أحد أبرز الأحداث التقنية في المملكة، حيث عرضت أحدث حلولها وابتكاراتها التقنية.
                            </p>

                            <a href="#" class="mt-8 inline-flex w-fit rounded-2xl bg-gradient-to-l from-blue-500 to-cyan-400 px-7 py-3 font-bold text-white no-underline">
                                اقرأ المزيد ←
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </div>

    <script>
        const revealItems = document.querySelectorAll('.reveal');

        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('show');
                }
            });
        }, { threshold: 0.12 });

        revealItems.forEach((item, index) => {
            item.style.transitionDelay = `${Math.min(index * 40, 240)}ms`;
            revealObserver.observe(item);
        });

        const parallaxItems = document.querySelectorAll('.parallax');

        function updateParallax() {
            const scrollY = window.scrollY;
            parallaxItems.forEach((item) => {
                const speed = parseFloat(item.dataset.speed || '0.08');
                item.style.transform = `translateY(${scrollY * speed}px)`;
            });
        }

        updateParallax();
        window.addEventListener('scroll', updateParallax, { passive: true });
    </script>

</div>