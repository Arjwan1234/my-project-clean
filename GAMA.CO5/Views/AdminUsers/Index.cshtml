@model IEnumerable<GAMA.CO5.Models.ApplicationUser>

@{
    ViewData["Title"] = "إدارة المستخدمين";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-users-page">

    <div class="users-hero">
        <div>
            <span class="hero-badge">GAMA Users</span>
            <h2>إدارة المستخدمين</h2>
            <p>مراجعة المستخدمين والموافقة عليهم أو رفض دخولهم للوحة التحكم.</p>
        </div>

        <a href="/AdminUsers/Create" class="btn-add">
            <i class="fa-solid fa-user-plus"></i>
            إضافة مستخدم
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert-box error">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert-box success">@TempData["Success"]</div>
    }

    <div class="users-card">
        <table class="users-table">
            <thead>
                <tr>
                    <th>البريد الإلكتروني</th>
                    <th>اسم المستخدم</th>
                    <th>رقم الجوال</th>
                    <th>تأكيد البريد</th>
                    <th>الموافقة</th>
                    <th>الحالة</th>
                    <th>العمليات</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    var isDisabled = user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.Now;

                    <tr>
                        <td>
                            <a href="mailto:@user.Email" class="email-link">
                                @user.Email
                            </a>
                        </td>

                        <td class="username">@user.UserName</td>

                        <td>
                            @if (!string.IsNullOrEmpty(user.PhoneNumber))
                            {
                                <a href="tel:@user.PhoneNumber" class="phone-link">
                                    @user.PhoneNumber
                                </a>
                            }
                            else
                            {
                                <span class="no-data">—</span>
                            }
                        </td>

                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="status confirmed">مؤكد</span>
                            }
                            else
                            {
                                <span class="status not-confirmed">غير مؤكد</span>
                            }
                        </td>

                        <td>
                            @if (user.IsApproved)
                            {
                                <span class="status active">مقبول</span>
                            }
                            else
                            {
                                <span class="status pending">بانتظار الموافقة</span>
                            }
                        </td>

                        <td>
                            @if (isDisabled)
                            {
                                <span class="status disabled">معطّل</span>
                            }
                            else
                            {
                                <span class="status active">نشط</span>
                            }
                        </td>

                        <td>
                            <div class="actions">
                                @if (!user.IsApproved || isDisabled)
                                {
                                    <form action="/AdminUsers/Approve" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />

                                        <button type="submit" class="btn-enable">
                                            موافقة
                                        </button>
                                    </form>
                                }

                                @if (user.IsApproved && !isDisabled)
                                {
                                    <form action="/AdminUsers/Reject" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />

                                        <button type="submit"
                                                class="btn-disable"
                                                onclick="return confirm('هل تريد رفض هذا المستخدم؟ لن يتمكن من الدخول.');">
                                            رفض
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@section Styles {
    <style>
        .admin-users-page {
            padding: 28px;
            min-height: calc(100vh - 80px);
            background: radial-gradient(circle at top right, rgba(29,78,216,.16), transparent 28%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #ffffff 100%);
        }

        .users-hero {
            margin-bottom: 28px;
            padding: 32px;
            border-radius: 30px;
            background: linear-gradient(135deg, #07142b, #0f3d75);
            color: white;
            box-shadow: 0 24px 60px rgba(7,20,43,.22);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .hero-badge {
            display: inline-flex;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 12px;
            font-weight: 900;
            color: #dbeafe;
        }

        .users-hero h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
        }

        .users-hero p {
            margin: 8px 0 0;
            color: #cbd5f5;
            font-weight: 600;
        }

        .btn-add {
            background: linear-gradient(135deg, #d4af37, #f6d76b);
            color: #07142b;
            padding: 12px 22px;
            border-radius: 18px;
            font-weight: 900;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: .25s;
            white-space: nowrap;
        }

            .btn-add:hover {
                color: #07142b;
                transform: translateY(-2px);
                box-shadow: 0 14px 30px rgba(212,175,55,.28);
            }

        .alert-box {
            padding: 15px 18px;
            border-radius: 18px;
            margin-bottom: 18px;
            font-weight: 900;
            text-align: right;
        }

            .alert-box.error {
                background: #fef2f2;
                color: #991b1b;
                border: 1px solid #fecaca;
            }

            .alert-box.success {
                background: #dcfce7;
                color: #166534;
                border: 1px solid #bbf7d0;
            }

        .users-card {
            border-radius: 28px;
            overflow-x: auto;
            background: rgba(255,255,255,.95);
            border: 1px solid #dbe6f5;
            box-shadow: 0 24px 60px rgba(15,23,42,.10);
        }

        .users-table {
            width: 100%;
            min-width: 1050px;
            border-collapse: collapse;
            text-align: right;
        }

            .users-table thead {
                background: linear-gradient(135deg, #07142b, #0f3d75);
                color: white;
            }

            .users-table th {
                padding: 18px;
                font-size: 14px;
                font-weight: 900;
                white-space: nowrap;
            }

            .users-table td {
                padding: 18px;
                border-bottom: 1px solid #e5edf7;
                color: #334155;
                font-weight: 700;
                vertical-align: middle;
            }

            .users-table tbody tr {
                transition: .2s;
            }

                .users-table tbody tr:hover {
                    background: #f1f6ff;
                }

        .username {
            font-weight: 900 !important;
            color: #07142b !important;
            white-space: nowrap;
        }

        .email-link,
        .phone-link {
            color: #0f3d75;
            font-weight: 900;
            text-decoration: none;
            direction: ltr;
            display: inline-block;
        }

        .no-data {
            color: #94a3b8;
            font-weight: 900;
        }

        .status {
            display: inline-flex;
            padding: 7px 13px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
        }

        .confirmed,
        .active {
            background: #dcfce7;
            color: #166534;
        }

        .pending {
            background: #fff7ed;
            color: #c2410c;
        }

        .not-confirmed,
        .disabled {
            background: #fee2e2;
            color: #991b1b;
        }

        .actions {
            display: flex;
            justify-content: center;
            gap: 8px;
        }

        .inline-form {
            display: inline;
        }

        .btn-enable,
        .btn-disable {
            border: none;
            padding: 8px 14px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 900;
            transition: .2s;
        }

        .btn-enable {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .btn-disable {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

            .btn-enable:hover,
            .btn-disable:hover {
                transform: translateY(-1px);
            }

        @@media(max-width: 768px) {
            .users-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .btn-add {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}